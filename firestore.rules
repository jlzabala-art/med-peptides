rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---

    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Determine if user is an administrator (via email or role)
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'jose@mediluxeme.com' ||
        request.auth.token.email == 'kasia@mediluxeme.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Helper: Check if user is the owner of the document.
    function isOwner(data) {
      return isAuthenticated() && (
        data.userId == request.auth.uid ||
        data.user_id == request.auth.uid ||
        data.ownerId == request.auth.uid ||
        data.created_by == request.auth.uid ||
        data.doctorId == request.auth.uid ||
        data.uid == request.auth.uid
      );
    }

    // --- Collection Rules ---

    // ── 1. PUBLIC DATA — Anyone can read, Admins can write ─────────────────
    match /products/{id}               { allow read: if true; allow write: if isAdmin(); }
    match /catalogProducts/{id}        { allow read: if true; allow write: if isAdmin(); }
    match /categories/{id}             { allow read: if true; allow write: if isAdmin(); }
    match /subcategories/{id}          { allow read: if true; allow write: if isAdmin(); }
    match /settings/{id}               { allow read: if true; allow write: if isAdmin(); }
    match /product_variants/{id}       { allow read: if true; allow write: if isAdmin(); }
    match /protocol_templates/{id}     { allow read: if true; allow write: if isAdmin(); }
    match /monitoring_profiles/{id}    { allow read: if true; allow write: if isAdmin(); }

    // ── 2. FAQ & CONTENT DATA — Public read ────────────────────────────────
    match /peptide_faq/{id}            { allow read: if true; allow write: if isAdmin(); }
    match /faq_peptide_mapping/{id}    { allow read: if true; allow write: if isAdmin(); }
    match /faq_categories/{id}         { allow read: if true; allow write: if isAdmin(); }
    match /faq_landing_config/{id}     { allow read: if true; allow write: if isAdmin(); }
    match /peptide_compare_blocks/{id} { allow read: if true; allow write: if isAdmin(); }
    match /peptide_related_engine/{id} { allow read: if true; allow write: if isAdmin(); }
    match /discovery_config/{id}       { allow read: if true; allow write: if isAdmin(); }
    match /pubmed_cache/{id}           { allow read: if true; allow write: if isAdmin(); }

    // ── 3. AUTHENTICATED DATA — Login required ─────────────────────────────
    match /saved_protocols/{id} {
      allow read: if isAuthenticated() && (isOwner(resource.data) || isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data) || isAdmin();
    }

    match /protocol_builder_sessions/{id} {
      allow read: if isAuthenticated() && (isOwner(resource.data) || isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data) || isAdmin();
    }

    // ── 4. USER PROFILES ────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId || isAdmin();

      match /{allSubcollections=**} {
        allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
        allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
    }

    // ── 5. GENERIC AUTHENTICATED RULE (fallback for remaining collections) ──
    match /{collection}/{docId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.user_id == request.auth.uid ||
        request.resource.data.ownerId == request.auth.uid ||
        request.resource.data.created_by == request.auth.uid ||
        isAdmin()
      );

      allow update, delete: if isOwner(resource.data) || isAdmin();
    }

    // ── 6. EMAIL LOGS ───────────────────────────────────────────────────────
    match /mail/{mailId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // ── 7. GLOBAL CATCH-ALL FOR ADMINS ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
