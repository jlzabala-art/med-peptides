{
  "project": "med-peptides protocol builder v3",
  "version": "3.0-clinical-guided",
  "objective": "Guide doctors in selecting valid primary conditions and contraindications and generate deterministic protocol logic.",
  "guidedInputs": {
    "primaryCondition": {
      "mode": "guided_select_plus_optional_text",
      "categories": [
        "Weight Management / Obesity",
        "Metabolic Health",
        "Recovery / Injury",
        "Cognitive Support",
        "Sleep Support",
        "Hormonal Support",
        "Skin / Anti-Aging",
        "Immune / Inflammation",
        "Energy / Mitochondrial"
      ]
    },
    "contraindications": {
      "mode": "guided_multi_select_plus_optional_text",
      "options": [
        "Avoid injectables",
        "Oral only",
        "Needle aversion",
        "Budget sensitive",
        "Simple protocol required",
        "Advanced allowed",
        "Sleep sensitive",
        "High adherence required",
        "Prefer ready protocols",
        "Avoid blends"
      ]
    }
  },
  "protocolGenerationLogic": {
    "steps": [
      "Read primary condition",
      "Map to structured goals",
      "Apply contraindication exclusions",
      "Apply patient modifiers",
      "Score existing protocols",
      "Fallback to grouped products if needed",
      "Generate alternatives",
      "Compute confidence score",
      "Build timeline",
      "Calculate cost summary"
    ]
  },
  "outputBlocks": [
    "Primary Condition Summary",
    "Contraindication Summary",
    "Confidence Panel",
    "Timeline Visualization",
    "Cost Summary",
    "Alternative Reasoning"
  ]
}