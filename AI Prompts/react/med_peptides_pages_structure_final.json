{
  "project": "med-peptides multipage architecture",
  "version": "2.0-safe",
  "routing_mode": "progressive_enhancement",
  "routes": [
    {
      "path": "/",
      "page": "HomePage",
      "template": "HomeTemplate",
      "data": "minimal",
      "fallback": "render_static_home"
    },
    {
      "path": "/product/:slug",
      "page": "ProductPage",
      "template": "ProductTemplate",
      "data": "product_by_slug",
      "fallback": "render_404_if_missing"
    },
    {
      "path": "/collection/:slug",
      "page": "CollectionPage",
      "template": "CollectionTemplate",
      "data": "collection_by_slug",
      "fallback": "render_empty_collection"
    },
    {
      "path": "/protocol/:slug",
      "page": "ProtocolPage",
      "template": "ProtocolTemplate",
      "data": "protocol_by_slug",
      "fallback": "render_404_if_missing"
    },
    {
      "path": "/faq",
      "page": "FAQPage",
      "template": "FAQTemplate",
      "data": "faq_all"
    },
    {
      "path": "/faq/:topic",
      "page": "FAQTopicPage",
      "template": "FAQTemplate",
      "data": "faq_by_topic",
      "fallback": "render_empty_topic"
    },
    {
      "path": "/contact",
      "page": "ContactPage",
      "template": "ContactTemplate"
    },
    {
      "path": "/search",
      "page": "SearchPage",
      "template": "SearchTemplate"
    },
    {
      "path": "/compare/:slug1/:slug2",
      "page": "ComparePage",
      "template": "CompareTemplate",
      "validation": "validate_both_slugs",
      "fallback": "redirect_to_product_slug1"
    }
  ],
  "templates_contract": {
    "HomeTemplate": {
      "required_props": [
        "featuredCollections",
        "featuredProtocols",
        "featuredProducts",
        "faqHighlights"
      ]
    },
    "ProductTemplate": {
      "required_props": [
        "product",
        "relatedPeptides",
        "faqItems",
        "protocolUsage"
      ]
    },
    "CollectionTemplate": {
      "required_props": [
        "collection",
        "products",
        "recommendedProtocols"
      ]
    },
    "ProtocolTemplate": {
      "required_props": [
        "protocol",
        "includedPeptides",
        "relatedFaqItems"
      ]
    },
    "FAQTemplate": {
      "required_props": [
        "faqItems",
        "topic",
        "relatedProducts",
        "relatedProtocols"
      ]
    },
    "SearchTemplate": {
      "required_props": [
        "query",
        "productResults",
        "protocolResults",
        "faqResults"
      ]
    },
    "ContactTemplate": {
      "required_props": [
        "contactChannels",
        "contactFormConfig"
      ]
    },
    "CompareTemplate": {
      "required_props": [
        "baseProduct",
        "comparedProducts",
        "comparisonDimensions"
      ]
    }
  },
  "layouts": [
    "MainLayout",
    "ProfessionalLayout"
  ],
  "collections_to_preserve": [
    "products",
    "faq",
    "product_faq_mapping",
    "protocols",
    "protocol_faq_mapping",
    "discovery_engine"
  ],
  "fields_to_preserve": [
    "slug",
    "semanticKeywords",
    "tags",
    "visibility",
    "relatedGoals",
    "relatedProtocolSlugs",
    "faqTags"
  ],
  "performance_rules": {
    "lazy_loading": true,
    "fetch_per_page": true,
    "avoid_global_data_load": true,
    "enable_route_cache": true,
    "cache_ttl_seconds": 300,
    "prefetch_on_intent": false
  },
  "error_handling": {
    "product_missing": "render_404",
    "protocol_missing": "render_404",
    "collection_missing": "render_empty_collection",
    "faq_topic_missing": "render_empty_topic",
    "compare_invalid": "redirect_to_product_slug1"
  },
  "compatibility_rules": [
    "Do not delete existing routes before validating replacements",
    "Do not rename existing slugs",
    "Do not rewrite Firebase collections",
    "Do not break semantic search",
    "Do not break FAQ relationships",
    "Do not break protocol pages or PubMed integration"
  ]
}