const API_ENDPOINT = 'https://clinicalaiassistant-jtlgnxrofa-ew.a.run.app';

const DEFAULT_GREETING = "Hey! 👋 Ask me about peptides, protocols, recovery goals, or where to start — I'll guide you step by step. No need to know the science yet.";

// ─── Greeting resolver (page + user context + recent views aware) ───────────
/**
 * Build the opening assistant message.
 * @param {string} pathname
 * @param {Array}  products
 * @param {object|null} userCtx
 * @param {Array}  recentViews  — items from getRecentViews(), newest first
 */
function getInitialMsg(pathname, products = [], userCtx = null, recentViews = []) {
  const firstName = userCtx?.firstName || '';
  const isReturning = userCtx?.isReturning || false;
  const hasOrders = (userCtx?.recentOrders || []).length > 0;

  // ── Product page ──────────────────────────────────────────────────────────
  const productMatch = pathname.match(/^\/product\/(.+)/);
  if (productMatch) {
    const slug = productMatch[1];
    const product = products.find(p => p.slug === slug || p.id === slug);
    if (product) {
      const name = product.displayName || product.name;
      const greeting = firstName ? `Hey **${firstName}** 👋 ` : `Hey there! `;
      return {
        role: 'assistant',
        content: `${greeting}I see you're researching **${name}**. Let me start with what it is, why researchers explore it, and its primary research areas — then we can look at forms, similar peptides, and related protocols. What would you like to know?`,
        timestamp: new Date()
      };
    }
  }

  // ── Protocol page ─────────────────────────────────────────────────────────
  const protocolMatch = pathname.match(/^\/protocol\/(.+)/);
  if (protocolMatch) {
    const greeting = firstName ? `Hi **${firstName}**! ` : '';
    return {
      role: 'assistant',
      content: `${greeting}Questions about this protocol? I can explain the included peptides, phase structure, beginner suitability, and similar alternatives. What would you like to understand first?`,
      timestamp: new Date()
    };
  }

  // ── Category / Collection page ────────────────────────────────────────────
  const categoryMatch = pathname.match(/^\/(category|collection)\/(.+)/);
  if (categoryMatch) {
    const catName = categoryMatch[2].replace(/-/g, ' ');
    const greeting = firstName ? `Hi **${firstName}**! ` : '';
    return {
      role: 'assistant',
      content: `${greeting}Exploring ${catName}-focused peptides? I can help narrow options based on beginner vs advanced suitability, protocol complexity, common stacks, and related peptides. What are you looking for?`,
      timestamp: new Date()
    };
  }

  // ── Search results page ───────────────────────────────────────────────────
  if (pathname.startsWith('/search')) {
    return {
      role: 'assistant',
      content: `Not finding what you need? Tell me your goal or the peptide you're exploring — I'll guide you from there.`,
      timestamp: new Date()
    };
  }

  // ── Protocols / Knowledge Hub ────────────────────────────────────────────────
  if (pathname.startsWith('/protocols') || pathname.startsWith('/collection/protocols')) {
    const greeting = firstName ? `Hi **${firstName}**! ` : '';
    return {
      role: 'assistant',
      content: `${greeting}Looking for the right protocol? I can help narrow options based on your goal, experience level, and preferred complexity. Where would you like to start — recovery, energy, cognitive support, or something else?`,
      timestamp: new Date()
    };
  }

  // ── Checkout / cart page ──────────────────────────────────────────────────
  if (pathname.startsWith('/checkout') || pathname.startsWith('/cart')) {
    const greeting = firstName ? `Hi **${firstName}**! ` : '';
    return {
      role: 'assistant',
      content: `${greeting}Need help before you complete your order? I can answer questions about the peptides in your cart, reconstitution, storage, or shipping. Just ask!`,
      timestamp: new Date()
    };
  }

  // ── Orders / account page ─────────────────────────────────────────────────
  if (pathname.startsWith('/account') || pathname.startsWith('/orders')) {
    if (hasOrders && firstName) {
      const lastOrder = userCtx.recentOrders[0];
      const orderRef = lastOrder?.orderNumber ? ` (Order #${lastOrder.orderNumber})` : '';
      return {
        role: 'assistant',
        content: `Welcome back, **${firstName}**! Your most recent order${orderRef} has status: **${lastOrder?.status || 'Processing'}**. Need help with anything — tracking, returns, or reordering?`,
        timestamp: new Date()
      };
    }
    if (firstName) {
      return {
        role: 'assistant',
        content: `Hi **${firstName}**! I can help you with order status, payment questions, or anything else account-related. What do you need?`,
        timestamp: new Date()
      };
    }
  }

  // ── Build a recent-views hint (shared across guest + logged-in defaults) ────
  // Take the 3 most recent unique item names and format them as a callout.
  const recentNames = (recentViews || [])
    .filter((v) => v?.name)
    .slice(0, 3)
    .map((v) => `**${v.name}**`);
  const recentHint = recentNames.length > 0
    ? ` I noticed you were recently looking at ${recentNames.join(', ')} — want to pick up from there, or explore something new?`
    : '';

  // ── Default: differentiate first-time vs returning ────────────────────────
  if (!userCtx?.isLoggedIn) {
    // Guest / anonymous — beginner-friendly, non-technical
    if (recentHint) {
      return {
        role: 'assistant',
        content: `Hey! 👋${recentHint} Or just tell me your goal and I'll guide you step by step.`,
        timestamp: new Date()
      };
    }
    return {
      role: 'assistant',
      content: `Hey! 👋 Ask me about peptides, protocols, recovery goals, or where to start — I'll guide you step by step. No need to know the science yet.`,
      timestamp: new Date()
    };
  }

  if (isReturning && hasOrders && firstName) {
    return {
      role: 'assistant',
      content: `Welcome back, **${firstName}**! 👋 Great to see you.${recentHint || ' Want to continue exploring something, or start somewhere new? I can help with peptides, protocols, or your recent orders.'}`,
      timestamp: new Date()
    };
  }

  if (isReturning && firstName) {
    return {
      role: 'assistant',
      content: `Welcome back, **${firstName}**! 👋${recentHint || ' Ready to explore? Ask me about peptides, protocols, or goals — I\'ll guide you from there.'}`,
      timestamp: new Date()
    };
  }

  if (!isReturning && firstName) {
    // First visit after login
    return {
      role: 'assistant',
      content: `Hi **${firstName}**! 👋 Welcome.${recentHint || ' Not sure where to start? That\'s completely fine — tell me your goal and I\'ll guide you step by step. Or just ask about any peptide you\'ve heard of.'}`,
      timestamp: new Date()
    };
  }

  return { role: 'assistant', content: DEFAULT_GREETING, timestamp: new Date() };
}

import { getActiveProducts } from '../../repositories/productRepository';
import { getAllProtocols } from '../../repositories/protocolRepository';
import { db } from '../../firebase';
import { collection, addDoc, serverTimestamp, query, where, orderBy, limit, getDocs } from 'firebase/firestore';

// ─── Feedback writer ─────────────────────────────────────────────────────────
async function submitFeedback({ sessionId, messageIndex, rating, messageContent }) {
  try {
    await addDoc(collection(db, 'ai_feedback'), {
      sessionId,
      messageIndex,
      rating,            // 'up' | 'down'
      messageContent: (messageContent || '').slice(0, 500), // trim for storage
      createdAt: serverTimestamp(),
    });
  } catch (err) {
    console.warn('[ClinicalAI] Feedback write failed:', err);
  }
}

// ─── Follow-up Suggestion Generator ────────────────────────────────────────
// Classifies the AI reply locally and returns 2–3 contextual follow-up chips.
// No backend needed — pure heuristic on the reply text + user message.
// ── Phase 7 (Guided Engine) — Intent-aware follow-up suggestions ────────────
// generateFollowUps now accepts intent and layer for context-appropriate chips.
function generateFollowUps(reply = '', userMsg = '', protocols = [], products = [], intent = 'unknown', layer = 1) {
  const r = reply.toLowerCase();
  const q = userMsg.toLowerCase();

  const productTagMatch = reply.match(/\[PRODUCT:(.*?)\]/g);
  const protocolTagMatch = reply.match(/\[PROTOCOL:(.*?)\]/g);
  const hasReconTag = reply.includes('[RECON_TOOL:');

  const firstProductSlug = productTagMatch?.[0]?.match(/\[PRODUCT:(.*?)\]/)?.[1];
  const firstProduct = firstProductSlug
    ? products.find(p => p.slug === firstProductSlug || p.id === firstProductSlug)
    : null;
  const compoundName = firstProduct ? (firstProduct.displayName || firstProduct.name) : null;
  const firstProtocolSlug = protocolTagMatch?.[0]?.match(/\[PROTOCOL:(.*?)\]/)?.[1];

  const followUps = [];

  // ── RECONSTITUTION path (always wins if detected) ─────────────────────
  if (hasReconTag || r.includes('reconstitut') || q.includes('reconstitut') || q.includes('mix') || q.includes('bac water')) {
    if (compoundName) followUps.push({ label: `📖 Full ${compoundName} profile`, action: 'MESSAGE', payload: `Tell me more about ${compoundName} mechanism and research applications` });
    followUps.push({ label: '📋 See related protocols', action: 'MESSAGE', payload: 'What protocols use this peptide?' });
    followUps.push({ label: '❄️ Storage guidelines', action: 'MESSAGE', payload: 'How should I store reconstituted peptides?' });
    return followUps.slice(0, 3);
  }

  // ── Intent-specific follow-ups ─────────────────────────────────────────
  switch (intent) {
    case 'peptide': {
      if (compoundName) {
        followUps.push({ label: `🧪 Reconstitute ${compoundName}`, action: 'MESSAGE', payload: `How do I reconstitute ${compoundName}?` });
        followUps.push({ label: `📋 Protocols using ${compoundName}`, action: 'MESSAGE', payload: `Which protocols include ${compoundName}?` });
        followUps.push({ label: '⚖️ Compare with a similar peptide', action: 'MESSAGE', payload: `Compare ${compoundName} vs similar peptides` });
      }
      if (firstProductSlug) followUps.push({ label: '📄 View peptide page', action: 'NAVIGATE', payload: `/product/${firstProductSlug}` });
      break;
    }
    case 'comparison': {
      followUps.push({ label: '📋 Build a protocol with both', action: 'MESSAGE', payload: 'Can I combine both compounds in a protocol?' });
      if (firstProductSlug) followUps.push({ label: '📄 View top compound', action: 'NAVIGATE', payload: `/product/${firstProductSlug}` });
      followUps.push({ label: '💊 What about side effects?', action: 'MESSAGE', payload: 'What are the safety profiles of these compounds?' });
      break;
    }
    case 'protocol': {
      if (firstProtocolSlug) followUps.push({ label: '🔬 View full protocol', action: 'NAVIGATE', payload: `/protocol/${firstProtocolSlug}` });
      followUps.push({ label: '💊 Alternative without injectables?', action: 'MESSAGE', payload: 'Is there an alternative approach without injectables for the same goal?' });
      followUps.push({ label: '⚖️ Compare with another protocol', action: 'MESSAGE', payload: 'How does this compare to other protocols for the same goal?' });
      break;
    }
    case 'safety': {
      if (compoundName) followUps.push({ label: `📖 Full ${compoundName} profile`, action: 'MESSAGE', payload: `Tell me more about ${compoundName}` });
      followUps.push({ label: '💊 Safer alternatives?', action: 'MESSAGE', payload: 'Are there safer alternatives for the same goal?' });
      followUps.push({ label: '📋 Recommended protocols', action: 'MESSAGE', payload: 'What protocols use this compound safely?' });
      break;
    }
    case 'supplement': {
      followUps.push({ label: '💊 Peptides that pair well', action: 'MESSAGE', payload: 'Which peptides work well alongside this supplement?' });
      followUps.push({ label: '📋 Browse relevant protocols', action: 'MESSAGE', payload: 'What protocols include this supplement?' });
      followUps.push({ label: '🔬 More supplement science', action: 'MESSAGE', payload: 'What does the research say about this supplement?' });
      break;
    }
    case 'availability': {
      if (firstProductSlug) followUps.push({ label: '📄 View product page', action: 'NAVIGATE', payload: `/product/${firstProductSlug}` });
      followUps.push({ label: '📋 See all protocols', action: 'MESSAGE', payload: 'What research protocols are available?' });
      followUps.push({ label: '🔬 Tell me more about this compound', action: 'MESSAGE', payload: compoundName ? `Tell me about ${compoundName}` : 'Tell me about this compound' });
      break;
    }
    case 'education': {
      followUps.push({ label: '🔬 Show me a real peptide example', action: 'MESSAGE', payload: 'Can you give me a specific peptide example for this concept?' });
      if (layer >= 2) {
        followUps.push({ label: '⚗️ Deep-dive on the mechanism', action: 'MESSAGE', payload: 'Explain the mechanism of action in more depth' });
      }
      followUps.push({ label: '📋 Browse protocols using this', action: 'MESSAGE', payload: 'What research protocols relate to this?' });
      break;
    }
    case 'goal':
    default: {
      if (firstProtocolSlug) followUps.push({ label: '🔬 View full protocol', action: 'NAVIGATE', payload: `/protocol/${firstProtocolSlug}` });
      followUps.push({ label: '💊 Alternative without injectables?', action: 'MESSAGE', payload: 'Is there an alternative approach without injectables for the same goal?' });
      if (layer <= 1) {
        followUps.push({ label: '❓ Tell me more about my options', action: 'MESSAGE', payload: 'Can you explain my options in more detail?' });
      } else {
        followUps.push({ label: '⚖️ Compare approaches', action: 'MESSAGE', payload: 'How does this compare to other protocols for the same goal?' });
      }
      break;
    }
  }

  return followUps.slice(0, 3);
}

// ─── Rich Markdown Renderer ─────────────────────────────────────────────────
// Full-featured inline markdown → React elements (no external deps).
// Supports: ## headings, **bold**, *italic*, `code`, unordered lists,
// ordered lists (1. 2.), blockquotes (> text), horizontal rules, paragraphs.
// ── Markdown Table renderer ─────────────────────────────────────────────────
function renderMarkdownTable(lines, key) {
  const parseRow = (row) =>
    row.trim().split('|').map(c => c.trim()).filter((_, i, arr) => i > 0 && i < arr.length - 1);
  const isSeparator = (row) => /^[\s|:\-]+$/.test(row);
  const nonSep = lines.filter(l => !isSeparator(l));
  if (!nonSep.length) return null;
  const headers = parseRow(nonSep[0]);
  const dataRows = nonSep.slice(1).map(parseRow);
  return (
    <div key={key} style={{ overflowX: 'auto', margin: '0.5rem 0', borderRadius: '10px', border: '1px solid #e2eaf5', overflow: 'hidden' }}>
      <table style={{ width: '100%', borderCollapse: 'collapse', fontSize: '0.84rem' }}>
        {headers.length > 0 && (
          <thead>
            <tr style={{ background: 'rgba(0,54,102,0.06)' }}>
              {headers.map((h, i) => (
                <th key={i} style={{ padding: '0.5rem 0.8rem', textAlign: 'left', fontWeight: 700, color: 'var(--primary)', borderBottom: '1px solid #e2eaf5', whiteSpace: 'nowrap', fontSize: '0.75rem', textTransform: 'uppercase', letterSpacing: '0.05em' }}>
                  {h}
                </th>
              ))}
            </tr>
          </thead>
        )}
        <tbody>
          {dataRows.map((row, ri) => (
            <tr key={ri} style={{ borderBottom: ri < dataRows.length - 1 ? '1px solid #f0f5fb' : 'none', background: ri % 2 === 1 ? 'rgba(0,54,102,0.018)' : 'transparent' }}>
              {row.map((cell, ci) => (
                <td key={ci} style={{ padding: '0.45rem 0.8rem', color: ci === 0 ? '#1e3a5f' : '#374151', fontWeight: ci === 0 ? 600 : 400, lineHeight: 1.5, fontSize: '0.85rem' }}>
                  {inlineFormat(cell)}
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  );
}

function renderAIMarkdown(raw) {
  if (!raw) return null;

  const rawText = raw.replace(/\[RECON_TOOL:.*?\]/g, '').trim();

  // ── Normalise: isolate headings, HRs, and table rows into own blocks ──────
  const allLines = rawText.split('\n');
  const normLines = [];
  allLines.forEach((line, i) => {
    const isTable   = /^\s*\|/.test(line);
    const isHeading = /^\s*(#{1,3})\s/.test(line);
    const isHR      = /^\s*(---+|\*\*\*+|___)\s*$/.test(line);
    const prevLine  = i > 0 ? allLines[i - 1] : '';
    const nextLine  = i < allLines.length - 1 ? allLines[i + 1] : '';
    const prevIsTable   = /^\s*\|/.test(prevLine);
    const nextIsTable   = /^\s*\|/.test(nextLine);
    // Insert blank line BEFORE special lines if previous wasn't blank
    if ((isTable || isHeading || isHR) && normLines.length > 0 && normLines[normLines.length - 1] !== '') {
      normLines.push('');
    }
    normLines.push(line);
    // Insert blank line AFTER special lines if next isn't blank
    if ((isTable && !nextIsTable) || isHeading || isHR) {
      if (nextLine.trim() !== '') normLines.push('');
    }
  });
  const text = normLines.join('\n');
  const blocks = text.split(/\n{2,}/);

  return blocks.map((block, bi) => {
    const trimmed = block.trim();
    if (!trimmed) return null;

    // ── Horizontal rule ──────────────────────────────────────────────────
    if (/^(---+|\*\*\*+|___)$/.test(trimmed)) {
      return <hr key={bi} style={{ border: 'none', borderTop: '1px solid #dde3ec', margin: '0.6rem 0' }} />;
    }

    // ── Heading H1 ────────────────────────────────────────────────────────
    if (/^#\s/.test(trimmed) && !/^##/.test(trimmed)) {
      const firstLine = trimmed.split('\n')[0];
      return (
        <p key={bi} style={{ margin: '0.05rem 0 0', fontSize: '1.05rem', fontWeight: 900, color: 'var(--primary)', letterSpacing: '-0.02em', lineHeight: 1.25 }}>
          {inlineFormat(firstLine.replace(/^#\s+/, ''))}
        </p>
      );
    }

    // ── Heading H2 ───────────────────────────────────────────────────────
    if (/^##\s/.test(trimmed) && !/^###/.test(trimmed)) {
      const firstLine = trimmed.split('\n')[0];
      return (
        <p key={bi} style={{ margin: '0.1rem 0 0', fontSize: '0.97rem', fontWeight: 800, color: 'var(--primary)', letterSpacing: '-0.01em', lineHeight: 1.3 }}>
          {inlineFormat(firstLine.replace(/^##\s+/, ''))}
        </p>
      );
    }

    // ── Heading H3 — left accent bar ─────────────────────────────────────
    if (/^###\s/.test(trimmed)) {
      const firstLine = trimmed.split('\n')[0];
      return (
        <div key={bi} style={{ display: 'flex', alignItems: 'center', gap: '0.45rem', margin: '0.3rem 0 0.05rem' }}>
          <div style={{ width: '3px', height: '13px', borderRadius: '2px', background: 'var(--primary)', opacity: 0.65, flexShrink: 0 }} />
          <span style={{ fontSize: '0.78rem', fontWeight: 800, color: '#1e3a5f', textTransform: 'uppercase', letterSpacing: '0.055em', lineHeight: 1.3 }}>
            {inlineFormat(firstLine.replace(/^###\s+/, ''))}
          </span>
        </div>
      );
    }

    // ── Markdown Table ────────────────────────────────────────────────────
    {
      const tableLines = trimmed.split('\n');
      if (tableLines.length >= 1 && tableLines.every(l => /^\|/.test(l.trim()))) {
        return renderMarkdownTable(tableLines, bi);
      }
    }

    // ── Blockquote (> text) ───────────────────────────────────────────────
    if (/^>[ \t]/.test(trimmed) || trimmed.startsWith('> ')) {
      const bqText = trimmed.split('\n').map(l => l.replace(/^>\s*/, '')).join(' ');
      return (
        <div key={bi} style={{
          borderLeft: '3px solid var(--primary)',
          margin: '0.15rem 0',
          color: '#334155',
          fontStyle: 'italic',
          fontSize: '0.88rem',
          lineHeight: 1.6,
          background: 'rgba(0,75,135,0.04)',
          borderRadius: '0 8px 8px 0',
          padding: '0.5rem 0.85rem'
        }}>
          {inlineFormat(bqText)}
        </div>
      );
    }

    // Note: includes '.' so the AI's ". item" bullet style is parsed correctly
    const listLineRe = /^[-•*.]\ +/;
    const orderedLineRe = /^\d+\.\s+/;
    const lines = trimmed.split('\n');

    // ── Pure unordered list ───────────────────────────────────────────────
    if (lines.every(l => listLineRe.test(l.trim()))) {
      return (
        <ul key={bi} style={{ margin: '0.2rem 0', paddingLeft: '1.1rem', display: 'flex', flexDirection: 'column', gap: '0.35rem' }}>
          {lines.map((l, li) => (
            <li key={li} style={{ fontSize: '0.91rem', lineHeight: 1.6, color: 'inherit' }}>
              {inlineFormat(l.replace(listLineRe, '').trim())}
            </li>
          ))}
        </ul>
      );
    }

    // ── Pure ordered list ─────────────────────────────────────────────────
    if (lines.every(l => orderedLineRe.test(l.trim()))) {
      return (
        <ol key={bi} style={{ margin: '0.2rem 0', paddingLeft: '1.3rem', display: 'flex', flexDirection: 'column', gap: '0.35rem' }}>
          {lines.map((l, li) => (
            <li key={li} style={{ fontSize: '0.91rem', lineHeight: 1.6, color: 'inherit' }}>
              {inlineFormat(l.replace(orderedLineRe, '').trim())}
            </li>
          ))}
        </ol>
      );
    }

    // ── Mixed block (list items + plain text on consecutive lines) ────────
    if (lines.length > 1 && lines.some(l => listLineRe.test(l.trim()) || orderedLineRe.test(l.trim()))) {
      return (
        <div key={bi} style={{ display: 'flex', flexDirection: 'column', gap: '0.3rem' }}>
          {lines.map((l, li) => {
            const t = l.trim();
            if (listLineRe.test(t)) {
              return (
                <div key={li} style={{ display: 'flex', gap: '0.55rem', alignItems: 'flex-start' }}>
                  <span style={{ color: 'var(--primary)', fontWeight: 800, marginTop: '0.1rem', flexShrink: 0, fontSize: '1rem' }}>·</span>
                  <span style={{ fontSize: '0.91rem', lineHeight: 1.6 }}>{inlineFormat(t.replace(listLineRe, ''))}</span>
                </div>
              );
            }
            if (orderedLineRe.test(t)) {
              const num = t.match(/^(\d+)\.\s+/)?.[1];
              return (
                <div key={li} style={{ display: 'flex', gap: '0.55rem', alignItems: 'flex-start' }}>
                  <span style={{
                    color: 'white', background: 'var(--primary)', fontWeight: 800,
                    fontSize: '0.65rem', borderRadius: '50%', width: '18px', height: '18px',
                    display: 'flex', alignItems: 'center', justifyContent: 'center',
                    flexShrink: 0, marginTop: '0.15rem'
                  }}>{num}</span>
                  <span style={{ fontSize: '0.91rem', lineHeight: 1.6 }}>{inlineFormat(t.replace(orderedLineRe, ''))}</span>
                </div>
              );
            }
            return (
              <p key={li} style={{ margin: 0, fontSize: '0.91rem', lineHeight: 1.68 }}>{inlineFormat(t)}</p>
            );
          })}
        </div>
      );
    }

    // ── Single-line that looks like a list item ───────────────────────────
    if (listLineRe.test(trimmed)) {
      return (
        <div key={bi} style={{ display: 'flex', gap: '0.55rem', alignItems: 'flex-start' }}>
          <span style={{ color: 'var(--primary)', fontWeight: 800, fontSize: '1rem', flexShrink: 0 }}>·</span>
          <span style={{ fontSize: '0.91rem', lineHeight: 1.6 }}>{inlineFormat(trimmed.replace(listLineRe, ''))}</span>
        </div>
      );
    }

    // ── AI Section Headers (GOAL, NEXT STEP, etc.) ────────────────────────
    // Matches lines like: **GOAL**, **RECOMMENDED PROTOCOL**, **NEXT STEP**
    {
      const AI_SECTION_MAP = {
        'GOAL':                   { icon: '🎯', color: '#0f766e', bg: 'rgba(15,118,110,0.06)', accentBg: 'rgba(15,118,110,0.12)', accent: '#0f766e' },
        'RECOMMENDED PROTOCOL':   { icon: '📋', color: '#1d4ed8', bg: 'rgba(29,78,216,0.06)',  accentBg: 'rgba(29,78,216,0.12)',  accent: '#1d4ed8' },
        'PROTOCOL':               { icon: '📋', color: '#1d4ed8', bg: 'rgba(29,78,216,0.06)',  accentBg: 'rgba(29,78,216,0.12)',  accent: '#1d4ed8' },
        'NEXT STEP':              { icon: '➡️', color: '#7c3aed', bg: 'rgba(124,58,237,0.06)', accentBg: 'rgba(124,58,237,0.12)', accent: '#7c3aed' },
        'NEXT STEPS':             { icon: '➡️', color: '#7c3aed', bg: 'rgba(124,58,237,0.06)', accentBg: 'rgba(124,58,237,0.12)', accent: '#7c3aed' },
        'MECHANISM':              { icon: '⚙️', color: '#b45309', bg: 'rgba(180,83,9,0.06)',   accentBg: 'rgba(180,83,9,0.12)',   accent: '#b45309' },
        'MECHANISM OF ACTION':    { icon: '⚙️', color: '#b45309', bg: 'rgba(180,83,9,0.06)',   accentBg: 'rgba(180,83,9,0.12)',   accent: '#b45309' },
        'DOSING':                 { icon: '💊', color: '#0369a1', bg: 'rgba(3,105,161,0.06)',  accentBg: 'rgba(3,105,161,0.12)',  accent: '#0369a1' },
        'DOSAGE':                 { icon: '💊', color: '#0369a1', bg: 'rgba(3,105,161,0.06)',  accentBg: 'rgba(3,105,161,0.12)',  accent: '#0369a1' },
        'SAFETY':                 { icon: '🛡️', color: '#15803d', bg: 'rgba(21,128,61,0.06)',  accentBg: 'rgba(21,128,61,0.12)',  accent: '#15803d' },
        'CONTRAINDICATIONS':      { icon: '⚠️', color: '#b91c1c', bg: 'rgba(185,28,28,0.06)', accentBg: 'rgba(185,28,28,0.12)', accent: '#b91c1c' },
        'SUMMARY':                { icon: '📝', color: '#475569', bg: 'rgba(71,85,105,0.06)',  accentBg: 'rgba(71,85,105,0.12)',  accent: '#475569' },
        'RESEARCH NOTE':          { icon: '🔬', color: '#7c3aed', bg: 'rgba(124,58,237,0.06)', accentBg: 'rgba(124,58,237,0.12)', accent: '#7c3aed' },
        'CLINICAL NOTE':          { icon: '🏥', color: '#0f766e', bg: 'rgba(15,118,110,0.06)', accentBg: 'rgba(15,118,110,0.12)', accent: '#0f766e' },
        'SYNERGY':                { icon: '🔗', color: '#d97706', bg: 'rgba(217,119,6,0.06)',  accentBg: 'rgba(217,119,6,0.12)',  accent: '#d97706' },
        'STACK':                  { icon: '🧬', color: '#0369a1', bg: 'rgba(3,105,161,0.06)',  accentBg: 'rgba(3,105,161,0.12)',  accent: '#0369a1' },
        'COMPOUNDS':              { icon: '🔬', color: '#0369a1', bg: 'rgba(3,105,161,0.06)',  accentBg: 'rgba(3,105,161,0.12)',  accent: '#0369a1' },
        'SUPPLEMENTS':            { icon: '💉', color: '#15803d', bg: 'rgba(21,128,61,0.06)',  accentBg: 'rgba(21,128,61,0.12)',  accent: '#15803d' },
        'LIFESTYLE':              { icon: '🏃', color: '#d97706', bg: 'rgba(217,119,6,0.06)',  accentBg: 'rgba(217,119,6,0.12)',  accent: '#d97706' },
        'MONITORING':             { icon: '📊', color: '#475569', bg: 'rgba(71,85,105,0.06)',  accentBg: 'rgba(71,85,105,0.12)',  accent: '#475569' },
      };
      // Match **LABEL** or **LABEL:** at start of line (case-insensitive)
      const headerMatch = trimmed.match(/^\*\*([A-Z][A-Z0-9 _\-]+?):?\*\*\s*(.*)$/i);
      if (headerMatch) {
        const labelRaw = headerMatch[1].trim().toUpperCase();
        const restText = headerMatch[2].trim();
        const style = AI_SECTION_MAP[labelRaw];
        if (style) {
          return (
            <div key={bi} style={{
              display: 'flex', flexDirection: 'column',
              margin: '0.55rem 0 0.2rem',
              borderLeft: `3px solid ${style.accent}`,
              borderRadius: '0 8px 8px 0',
              background: style.bg,
              overflow: 'hidden'
            }}>
              {/* Header row */}
              <div style={{
                display: 'flex', alignItems: 'center', gap: '0.45rem',
                padding: '0.35rem 0.7rem 0.35rem 0.65rem',
              }}>
                <span style={{ fontSize: '0.85rem', lineHeight: 1, flexShrink: 0 }}>{style.icon}</span>
                <span style={{
                  fontSize: '0.65rem', fontWeight: 800, letterSpacing: '0.09em',
                  textTransform: 'uppercase', color: style.color
                }}>{labelRaw.replace(/_/g, ' ')}</span>
                {restText && (
                  <span style={{
                    marginLeft: '0.15rem', fontSize: '0.88rem', fontWeight: 500,
                    color: 'var(--text-main)', lineHeight: 1.5, flexShrink: 1
                  }}>{inlineFormat(restText)}</span>
                )}
              </div>
            </div>
          );
        }
      }
    }

    // ── Plain paragraph ───────────────────────────────────────────────────
    return (
      <p key={bi} style={{ margin: 0, fontSize: '0.91rem', lineHeight: 1.68 }}>
        {inlineFormat(trimmed)}
      </p>
    );
  });
}

// Renders inline markdown: **bold**, *italic*, `code`, [text](url)
function inlineFormat(text) {
  if (!text) return null;
  // Split on bold, italic, code, AND markdown links
  const parts = text.split(/(\[([^\]]+)\]\(([^)]+)\)|\*\*[^*]+\*\*|\*[^*]+\*|`[^`]+`)/g);
  const result = [];
  let i = 0;
  while (i < parts.length) {
    const part = parts[i];
    if (!part) { i++; continue; }
    // Markdown link [label](url)
    if (part.startsWith('[') && /^\[([^\]]+)\]\(([^)]+)\)$/.test(part)) {
      const m = part.match(/^\[([^\]]+)\]\(([^)]+)\)$/);
      if (m) {
        const href = m[2].startsWith('/') ? m[2] : m[2];
        result.push(
          <a key={i} href={href}
            style={{ color: 'var(--primary)', fontWeight: 600, textDecoration: 'underline', textUnderlineOffset: '2px' }}
            onClick={(e) => { if (href.startsWith('/')) { e.preventDefault(); window.location.href = href; } }}
          >{m[1]}</a>
        );
        i += 3; // skip the 2 capture groups
        continue;
      }
    }
    if (part.startsWith('**') && part.endsWith('**'))
      result.push(<strong key={i} style={{ fontWeight: 700, color: 'inherit' }}>{part.slice(2, -2)}</strong>);
    else if (part.startsWith('*') && part.endsWith('*') && part.length > 2)
      result.push(<em key={i} style={{ fontStyle: 'italic' }}>{part.slice(1, -1)}</em>);
    else if (part.startsWith('`') && part.endsWith('`'))
      result.push(
        <code key={i} style={{
          background: 'rgba(0,75,135,0.1)', borderRadius: '4px', padding: '0.1em 0.4em',
          fontSize: '0.82em', fontFamily: "'JetBrains Mono', 'Courier New', monospace",
          fontWeight: 600, color: 'var(--primary)'
        }}>{part.slice(1, -1)}</code>
      );
    else
      result.push(part);
    i++;
  }
  return result;
}
// ─────────────────────────────────────────────────────────────────────────────
// Cross-navigation helpers
// ─────────────────────────────────────────────────────────────────────────────

/**
 * Given a product slug, return all protocols that include it.
 * Checks protocol.compounds[], protocol.compoundList[], and
 * protocol.products[] arrays (covers all known schema shapes).
 */
function findProtocolsForProduct(productSlug, protocols = []) {
  if (!productSlug) return [];
  const slug = productSlug.toLowerCase();
  return protocols.filter((p) => {
    const lists = [
      p.compounds,
      p.compoundList,
      p.products,
      p.items,
      p.primary_compounds,
    ].filter(Boolean);
    return lists.some((list) =>
      list.some((entry) => {
        const s =
          (typeof entry === 'string' ? entry : entry?.slug || entry?.id || entry?.name || '')
            .toLowerCase()
            .replace(/\s+/g, '-');
        return s === slug || s.includes(slug) || slug.includes(s);
      })
    );
  });
}

/**
 * Given a protocol object, return all products referenced by it.
 * Returns array of { slug, name } objects for navigation.
 */
function findProductsForProtocol(protocol, products = []) {
  if (!protocol) return [];
  const refs = [
    ...(protocol.compounds || []),
    ...(protocol.compoundList || []),
    ...(protocol.products || []),
    ...(protocol.items || []),
    ...(protocol.primary_compounds || []),
  ];
  if (!refs.length) return [];

  return refs
    .map((ref) => {
      const raw = typeof ref === 'string' ? ref : (ref?.slug || ref?.id || ref?.name || '');
      const refName = typeof ref === 'string' ? ref : (ref?.name || ref?.slug || ref?.id || '');

      // Normalise: blueprint uses underscores (bpc_157) → hyphens (bpc-157) for resolveProductId
      const normalised = raw.toLowerCase().replace(/[_\s]+/g, '-');

      // 1. Try exact compound index resolution → Firestore product ID
      const resolvedId = resolveProductId(normalised) || resolveProductId(raw.toLowerCase());
      if (resolvedId) {
        const match = products.find(p => (p.slug || p.id) === resolvedId);
        if (match) return { slug: match.slug || match.id, name: match.name };
      }

      // 2. Fuzzy fallback against products catalogue
      const match = products.find((p) => {
        const ps = (p.slug || p.id || '').toLowerCase();
        const pn = (p.name || '').toLowerCase().replace(/[_\s]+/g, '-');
        return ps === normalised || pn === normalised || ps.includes(normalised) || normalised.includes(ps);
      });

      if (match) return { slug: match.slug || match.id, name: match.name };
      if (refName) return { slug: normalised, name: refName };
      return null;
    })
    .filter(Boolean);
}


// ─────────────────────────────────────────────────────────────────────────────

// ─── ProtocolsForPeptideCard ─────────────────────────────────────────────────
// Collapsible premium card shown after a compound (TYPE 1) AI reply.
// Lists every protocol that includes the queried peptide.
function ProtocolsForPeptideCard({ protocols = [], count, navigate, setIsOpen }) {
  const [expanded, setExpanded] = React.useState(false);

  if (!count) return null;

  return (
    <div style={{ marginTop: '1.25rem' }}>
      {/* ── Header card (always visible) ── */}
      <div
        onClick={() => setExpanded(v => !v)}
        style={{
          display: 'flex',
          alignItems: 'center',
          gap: '0.75rem',
          padding: '0.9rem 1rem',
          borderRadius: expanded ? '14px 14px 0 0' : '14px',
          background: 'linear-gradient(135deg, #0f4c82 0%, #1a6fc4 100%)',
          cursor: 'pointer',
          transition: 'border-radius 0.25s',
          userSelect: 'none',
        }}
      >
        {/* Icon */}
        <div style={{
          width: '36px', height: '36px', borderRadius: '10px',
          background: 'rgba(255,255,255,0.15)', display: 'flex',
          alignItems: 'center', justifyContent: 'center', flexShrink: 0,
        }}>
          <ClipboardList size={18} color="white" />
        </div>

        {/* Text */}
        <div style={{ flex: 1, minWidth: 0 }}>
          <div style={{ fontSize: '0.82rem', fontWeight: 700, color: 'white', lineHeight: 1.2 }}>
            Used in {count} Protocol{count !== 1 ? 's' : ''}
          </div>
          <div style={{ fontSize: '0.67rem', color: 'rgba(255,255,255,0.72)', marginTop: '2px' }}>
            {expanded ? 'Tap to collapse' : 'Tap to see which protocols include this peptide'}
          </div>
        </div>

        {/* Chevron */}
        <div style={{
          transform: expanded ? 'rotate(90deg)' : 'rotate(0deg)',
          transition: 'transform 0.25s',
          flexShrink: 0,
        }}>
          <ChevronRight size={16} color="rgba(255,255,255,0.8)" />
        </div>
      </div>

      {/* ── Expanded list ── */}
      {expanded && (
        <div style={{
          borderRadius: '0 0 14px 14px',
          border: '1px solid #c7dff5',
          borderTop: 'none',
          background: '#f7faff',
          padding: '0.6rem',
          display: 'flex',
          flexDirection: 'column',
          gap: '0.5rem',
        }}>
          {protocols.map((protocol, idx) => {
            const slug = protocol.slug || protocol.id;
            const title = protocol.title || protocol.name || slug;
            const subtitle = protocol.goal || protocol.description || 'Research Protocol';
            return (
              <div
                key={idx}
                onClick={() => { navigate(`/protocol/${slug}`); setIsOpen(false); }}
                style={{
                  display: 'flex', alignItems: 'center', gap: '0.65rem',
                  padding: '0.65rem 0.75rem', borderRadius: '10px',
                  background: 'white', border: '1px solid #ddeeff',
                  cursor: 'pointer', transition: 'all 0.18s',
                }}
                onMouseOver={e => { e.currentTarget.style.borderColor = 'var(--primary)'; e.currentTarget.style.boxShadow = '0 2px 8px rgba(0,75,135,0.1)'; }}
                onMouseOut={e => { e.currentTarget.style.borderColor = '#ddeeff'; e.currentTarget.style.boxShadow = 'none'; }}
              >
                <div style={{
                  width: '32px', height: '32px', borderRadius: '8px',
                  background: 'linear-gradient(135deg,#e8f4fd,#d0e9f8)',
                  display: 'flex', alignItems: 'center', justifyContent: 'center', flexShrink: 0,
                }}>
                  <ClipboardList size={14} color="var(--primary)" />
                </div>
                <div style={{ flex: 1, minWidth: 0 }}>
                  <div style={{ fontSize: '0.79rem', fontWeight: 700, color: 'var(--text-main)', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>{title}</div>
                  <div style={{ fontSize: '0.63rem', color: 'var(--text-muted)', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>{subtitle}</div>
                </div>
                <div style={{ fontSize: '0.6rem', fontWeight: 700, color: 'var(--primary)', display: 'flex', alignItems: 'center', gap: '2px', flexShrink: 0 }}>
                  View <ChevronRight size={10} />
                </div>
              </div>
            );
          })}
        </div>
      )}
    </div>
  );
}

// ─────────────────────────────────────────────────────────────────────────────
// InstantResultsTabs — tabbed display of pre-ranked compounds & protocols
// ─────────────────────────────────────────────────────────────────────────────
function InstantResultsTabs({ preRankedProducts = [], preRankedProtocols = [], navigate, setIsOpen }) {
  const [activeTab, setActiveTab] = useState('compounds');

  // Deduplicate helpers
  const getBaseSlug = (slug) =>
    (slug || '').replace(/[\-]*(\d+(\.\d+)?[\-]?(mg|mcg|iu|ml|g|kg)[\-\w]*)$/i, '').replace(/\-+$/, '') || slug;
  const getBaseName = (name) =>
    (name || '').replace(/[\-\s]*(\d+(\.\d+)?\s*(mg|mcg|iu|ml|g|kg)[\-\w]*)$/i, '').trim() || name;

  const seenNames = new Set();
  const uniqueProducts = preRankedProducts.filter(product => {
    const baseName = getBaseName(product.displayName || product.name || '').toLowerCase();
    if (seenNames.has(baseName)) return false;
    seenNames.add(baseName);
    return true;
  });
  const uniqueProtos = preRankedProtocols.filter(
    (p, i, arr) => arr.findIndex(x => (x.protocol_slug || x.slug || x.id) === (p.protocol_slug || p.slug || p.id)) === i
  );

  const hasCompounds  = uniqueProducts.length > 0;
  const hasProtocols  = uniqueProtos.length > 0;
  const showTabs      = hasCompounds && hasProtocols;

  // If only one type, show directly without tabs
  const effectiveTab  = showTabs ? activeTab : (hasCompounds ? 'compounds' : 'protocols');

  const TAB_STYLE_BASE = {
    display: 'flex', alignItems: 'center', gap: '0.35rem',
    padding: '0.38rem 0.8rem',
    borderRadius: '20px',
    fontSize: '0.62rem', fontWeight: 700, letterSpacing: '0.06em',
    textTransform: 'uppercase', cursor: 'pointer',
    border: '1px solid transparent',
    transition: 'all 0.18s',
    userSelect: 'none',
  };

  return (
    <div style={{ marginBottom: '0.5rem' }}>
      {/* ── Visual divider */}
      <div style={{ display: 'flex', alignItems: 'center', gap: '0.5rem', margin: '0.25rem 0 0.7rem 0' }}>
        <div style={{ flex: 1, height: '1px', background: 'linear-gradient(90deg, #dde8f5 0%, transparent 100%)' }} />
        <span style={{
          fontSize: '0.6rem', fontWeight: 800, letterSpacing: '0.07em',
          color: 'var(--primary)', textTransform: 'uppercase',
          padding: '0.2rem 0.65rem',
          background: 'linear-gradient(135deg, rgba(0,75,135,0.07) 0%, rgba(0,75,135,0.03) 100%)',
          borderRadius: '20px', border: '1px solid rgba(0,75,135,0.15)', whiteSpace: 'nowrap'
        }}>⚡ Instant Results</span>
        <div style={{ flex: 1, height: '1px', background: 'linear-gradient(90deg, transparent 0%, #dde8f5 100%)' }} />
      </div>

      {/* ── Tab bar (only when both types present) */}
      {showTabs && (
        <div style={{ 
          display: 'flex', 
          gap: '0.4rem', 
          marginBottom: '0.7rem',
          position: 'sticky',
          top: '-1px',
          zIndex: 10,
          background: 'rgba(255, 255, 255, 0.95)',
          backdropFilter: 'blur(8px)',
          padding: '0.5rem 0',
          margin: '-0.5rem 0 0.7rem 0'
        }}>
          <button
            onClick={() => setActiveTab('compounds')}
            style={{
              ...TAB_STYLE_BASE,
              background: effectiveTab === 'compounds'
                ? 'linear-gradient(135deg, rgba(0,75,135,0.12) 0%, rgba(0,75,135,0.07) 100%)'
                : 'transparent',
              borderColor: effectiveTab === 'compounds' ? 'rgba(0,75,135,0.25)' : '#e2e8f0',
              color: effectiveTab === 'compounds' ? 'var(--primary)' : 'var(--text-muted)',
            }}
          >
            <span style={{ fontSize: '0.75rem' }}>🔬</span>
            Compounds
            <span style={{
              display: 'inline-flex', alignItems: 'center', justifyContent: 'center',
              minWidth: '16px', height: '16px', borderRadius: '50%', padding: '0 3px',
              background: effectiveTab === 'compounds' ? 'var(--primary)' : '#e2e8f0',
              color: effectiveTab === 'compounds' ? 'white' : 'var(--text-muted)',
              fontSize: '0.55rem', fontWeight: 800
            }}>{uniqueProducts.length}</span>
          </button>
          <button
            onClick={() => setActiveTab('protocols')}
            style={{
              ...TAB_STYLE_BASE,
              background: effectiveTab === 'protocols'
                ? 'linear-gradient(135deg, rgba(3,105,161,0.12) 0%, rgba(3,105,161,0.07) 100%)'
                : 'transparent',
              borderColor: effectiveTab === 'protocols' ? 'rgba(3,105,161,0.25)' : '#e2e8f0',
              color: effectiveTab === 'protocols' ? '#0369a1' : 'var(--text-muted)',
            }}
          >
            <span style={{ fontSize: '0.75rem' }}>📋</span>
            Protocols
            <span style={{
              display: 'inline-flex', alignItems: 'center', justifyContent: 'center',
              minWidth: '16px', height: '16px', borderRadius: '50%', padding: '0 3px',
              background: effectiveTab === 'protocols' ? '#0369a1' : '#e2e8f0',
              color: effectiveTab === 'protocols' ? 'white' : 'var(--text-muted)',
              fontSize: '0.55rem', fontWeight: 800
            }}>{uniqueProtos.length}</span>
          </button>
        </div>
      )}

      {/* ── Compounds panel */}
      {effectiveTab === 'compounds' && hasCompounds && (
        <div style={{ display: 'flex', flexDirection: 'column', gap: '0.5rem' }}>
          {!showTabs && (
            <div style={{ display: 'flex', alignItems: 'center', gap: '0.5rem', marginBottom: '0.25rem' }}>
              <span style={{ fontSize: '0.78rem' }}>🔬</span>
              <span style={{ fontSize: '0.6rem', fontWeight: 800, letterSpacing: '0.07em', color: 'var(--primary)', textTransform: 'uppercase' }}>
                Related Compounds
              </span>
              <span style={{ marginLeft: 'auto', fontSize: '0.58rem', color: 'var(--text-muted)', fontWeight: 500 }}>
                {uniqueProducts.length} found
              </span>
            </div>
          )}
          {uniqueProducts.map((product, idx) => (
            <div
              key={`tab-compound-${idx}`}
              onClick={() => { navigate(`/product/${getBaseSlug(product.slug || product.id)}`); setIsOpen(false); }}
              style={{
                display: 'flex', alignItems: 'center', gap: '0.75rem',
                padding: '0.75rem',
                borderRadius: '14px',
                background: 'linear-gradient(135deg, #f8fafc 0%, #f0f4ff 100%)',
                border: '1px solid #e2e8f0',
                cursor: 'pointer', transition: 'all 0.2s'
              }}
              onMouseOver={(e) => {
                e.currentTarget.style.borderColor = 'var(--primary)';
                e.currentTarget.style.background = 'linear-gradient(135deg, #f0f4ff 0%, #e8edff 100%)';
                e.currentTarget.style.borderLeftWidth = '3px';
                const vl = e.currentTarget.querySelector('.view-link-c');
                if (vl) vl.style.opacity = '1';
              }}
              onMouseOut={(e) => {
                e.currentTarget.style.borderColor = '#e2e8f0';
                e.currentTarget.style.background = 'linear-gradient(135deg, #f8fafc 0%, #f0f4ff 100%)';
                e.currentTarget.style.borderLeftWidth = '1px';
                const vl = e.currentTarget.querySelector('.view-link-c');
                if (vl) vl.style.opacity = '0';
              }}
            >
              <div style={{
                width: '36px', height: '36px', borderRadius: '8px',
                background: 'white', display: 'flex', alignItems: 'center', justifyContent: 'center',
                border: '1px solid #f1f5f9', flexShrink: 0
              }}>
                <FlaskConical size={16} color="var(--primary)" />
              </div>
              <div style={{ flex: 1, minWidth: 0 }}>
                <div style={{ fontSize: '0.8rem', fontWeight: 700, color: 'var(--text-main)', marginBottom: '0.1rem' }}>
                  {getBaseName(product.displayName || product.name)}
                </div>
                <div style={{ fontSize: '0.65rem', color: 'var(--text-muted)', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>
                  {product.shortDescription || product.category || 'Research Peptide'}
                </div>
              </div>
              <span className="view-link-c" style={{
                fontSize: '0.62rem', fontWeight: 700,
                color: 'var(--primary)', opacity: 0,
                transition: 'opacity 0.18s', flexShrink: 0, whiteSpace: 'nowrap'
              }}>View →</span>
            </div>
          ))}
        </div>
      )}

      {/* ── Protocols panel */}
      {effectiveTab === 'protocols' && hasProtocols && (
        <div style={{ display: 'flex', flexDirection: 'column', gap: '0.45rem' }}>
          {!showTabs && (
            <div style={{ display: 'flex', alignItems: 'center', gap: '0.5rem', marginBottom: '0.25rem' }}>
              <span style={{ fontSize: '0.78rem' }}>📋</span>
              <span style={{ fontSize: '0.6rem', fontWeight: 800, letterSpacing: '0.07em', color: '#0369a1', textTransform: 'uppercase' }}>
                Related Protocols
              </span>
              <span style={{ marginLeft: 'auto', fontSize: '0.58rem', color: 'var(--text-muted)', fontWeight: 500 }}>
                {uniqueProtos.length} found
              </span>
            </div>
          )}
          {uniqueProtos.slice(0, 5).map((proto, pi) => {
            const compoundCount = proto.compounds?.length || proto.peptide_count || proto.compoundCount || null;
            const duration = proto.duration || proto.weeks ? `${proto.duration || proto.weeks} wks` : null;
            const slug = proto.protocol_slug || proto.slug || proto.id;
            return (
              <div
                key={`tab-proto-${pi}`}
                onClick={() => { navigate(`/protocols/${slug}`); setIsOpen(false); }}
                style={{
                  display: 'flex', alignItems: 'center', gap: '0.65rem',
                  padding: '0.65rem 0.8rem',
                  borderRadius: '12px',
                  background: 'linear-gradient(135deg, #f0f7ff 0%, #f8fafc 100%)',
                  border: '1px solid #dbeafe',
                  cursor: 'pointer', transition: 'all 0.2s'
                }}
                onMouseOver={(e) => {
                  e.currentTarget.style.borderColor = '#0369a1';
                  e.currentTarget.style.background = 'linear-gradient(135deg, #e0f0ff 0%, #f0f7ff 100%)';
                  const vl = e.currentTarget.querySelector('.view-link-p');
                  if (vl) vl.style.opacity = '1';
                }}
                onMouseOut={(e) => {
                  e.currentTarget.style.borderColor = '#dbeafe';
                  e.currentTarget.style.background = 'linear-gradient(135deg, #f0f7ff 0%, #f8fafc 100%)';
                  const vl = e.currentTarget.querySelector('.view-link-p');
                  if (vl) vl.style.opacity = '0';
                }}
              >
                <div style={{
                  width: '32px', height: '32px', borderRadius: '8px',
                  background: 'linear-gradient(135deg, #0369a1 0%, #0ea5e9 100%)',
                  display: 'flex', alignItems: 'center', justifyContent: 'center', flexShrink: 0
                }}>
                  <span style={{ fontSize: '0.85rem' }}>📋</span>
                </div>
                <div style={{ flex: 1, minWidth: 0 }}>
                  <div style={{ fontSize: '0.75rem', fontWeight: 700, color: 'var(--text-main)', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap', marginBottom: '0.15rem' }}>
                    {proto.name || proto.title}
                  </div>
                  <div style={{ display: 'flex', alignItems: 'center', gap: '0.35rem', flexWrap: 'wrap' }}>
                    {proto.category && (
                      <span style={{
                        fontSize: '0.58rem', fontWeight: 600, color: '#0369a1',
                        background: 'rgba(3,105,161,0.08)', padding: '0.05rem 0.35rem', borderRadius: '8px'
                      }}>{proto.category.replace(/_/g, ' ')}</span>
                    )}
                    {compoundCount && (
                      <span style={{ fontSize: '0.58rem', color: 'var(--text-muted)' }}>• {compoundCount} compounds</span>
                    )}
                    {duration && (
                      <span style={{ fontSize: '0.58rem', color: 'var(--text-muted)' }}>• {duration}</span>
                    )}
                  </div>
                </div>
                <span className="view-link-p" style={{
                  fontSize: '0.62rem', fontWeight: 700,
                  color: '#0369a1', opacity: 0,
                  transition: 'opacity 0.18s', flexShrink: 0, whiteSpace: 'nowrap'
                }}>View →</span>
              </div>
            );
          })}
        </div>
      )}
    </div>
  );
}

// ─────────────────────────────────────────────────────────────────────────────

export default function ClinicalAssistant({ isOpen, setIsOpen }) {
  const navigate = useNavigate();
  const location = useLocation();
  const { user, userProfile } = useAuth();
  const [products, setProducts] = useState([]);
  const [protocols, setProtocols] = useState([]);
  const [isMobile, setIsMobile] = useState(window.innerWidth <= 768);

  useEffect(() => {
    const handleResize = () => setIsMobile(window.innerWidth <= 768);
    window.addEventListener('resize', handleResize);
    return () => window.removeEventListener('resize', handleResize);
  }, []);

  // ─── Product page detection — hides FAB on mobile when inline CTA exists ───
  const isProductPage = /^\/product\//.test(location.pathname);

  // ─── ClinicalAI mutable config from Firestore ──────────────────────────────
  // Falls back gracefully to null if Firestore is unavailable; the static
  // buildClinicalAITrainingBlock() from clinicalAIRules.js always runs as baseline.
  const { clinicalConfig } = useClinicalAIConfig();

  // ─── WhatsApp Support Escalation ──────────────────────────────────────────
  const [showSupportCard, setShowSupportCard] = useState(false);
  const [supportDismissed, setSupportDismissed] = useState(() => {
    try { return !!localStorage.getItem('hide_whatsapp_support'); } catch { return false; }
  });
  const [supportContext, setSupportContext] = useState('');
  const supportShownThisSession = useRef(false);
  // Phase 1a — track peptide/protocol names explored this session for WA prefill
  const exploredCompoundsRef = useRef([]);
  // Phase 3 — guided discovery: holds the current goal string while the user
  // chooses between "show me peptides" or "show me protocols" for that goal.
  // Cleared once the user's choice is detected in the next message.
  const pendingGoalContextRef = useRef(null);

  // ─── Session Activity Tracker ──────────────────────────────────────────────
  const activityRef = useRef({
    messagesSent: 0,
    negFeedbackCount: 0,
    comparisonCount: 0,
    sessionStart: Date.now(),
    pageViews: 0,
  });

  // Helper: fire analytics event (no-op if dataLayer not present)
  const trackSupportEvent = useCallback((eventName, triggerType) => {
    try {
      if (typeof window !== 'undefined' && window.dataLayer) {
        window.dataLayer.push({
          event: eventName,
          source_page: window.location.pathname,
          trigger_type: triggerType,
        });
      }
    } catch {}
  }, []);

  // Helper: try to show escalation card (respects dismiss + once-per-session rule)
  const maybeShowSupport = useCallback((triggerType, contextHint = '') => {
    if (supportDismissed || supportShownThisSession.current) return;
    supportShownThisSession.current = true;
    setSupportContext(contextHint);
    setShowSupportCard(true);
    trackSupportEvent('support_prompt_shown', triggerType);
  }, [supportDismissed, trackSupportEvent]);

  // Dismiss handler
  const dismissSupportCard = useCallback(() => {
    setShowSupportCard(false);
    setSupportDismissed(true);
    trackSupportEvent('support_prompt_dismissed', 'manual');
    try { localStorage.setItem('hide_whatsapp_support', 'true'); } catch {}
  }, [trackSupportEvent]);

  // ─── User context (name, orders, returning flag) ───────────────────────────
  const [userCtx, setUserCtx] = useState(null);
  const [recentOrders, setRecentOrders] = useState([]);

  // ─── Query cache (in-memory, per session) ────────────────────────────────
  const queryCacheRef = useRef(new Map());

  // Restore message history: prefer localStorage (persistent), fall back to sessionStorage
  const [messages, setMessages] = useState(() => {
    try {
      const saved = localStorage.getItem('clinical_ai_messages_v2') ||
                    sessionStorage.getItem('clinical_ai_messages');
      if (saved) {
        const parsed = JSON.parse(saved);
        // Only restore if reasonably recent (< 7 days)
        const lastTs = parsed[parsed.length - 1]?.timestamp;
        if (lastTs && Date.now() - new Date(lastTs).getTime() < 7 * 24 * 60 * 60 * 1000) {
          return parsed.map(m => ({ ...m, timestamp: new Date(m.timestamp) }));
        }
      }
    } catch {}
    return [getInitialMsg(window.location.pathname, [], null, getRecentViews())];
  });

  const [input, setInput] = useState('');
  const [isLoading, setIsLoading] = useState(false);
  const [isTyping, setIsTyping] = useState(false);
  const [feedbackSent, setFeedbackSent] = useState({});

  // Phase 8 — Session Intent Memory (session-only, no persistence, no medical profiling)
  const [sessionIntents, setSessionIntents] = useState([]);

  // Phase 4 — Compare chips: known compound similarity relationships
  const SIMILAR_MAP = {
    'BPC-157':       ['TB-500', 'GHK-Cu'],
    'TB-500':        ['BPC-157', 'GHK-Cu'],
    'Semaglutide':   ['Tirzepatide', 'Retatrutide'],
    'Tirzepatide':   ['Semaglutide', 'Retatrutide'],
    'Retatrutide':   ['Tirzepatide', 'Semaglutide'],
    'Epithalon':     ['MOTS-c', 'NAD+', 'GHK-Cu'],
    'GHK-Cu':        ['Epithalon', 'BPC-157'],
    'Semax':         ['Selank', 'Dihexa'],
    'Selank':        ['Semax', 'Dihexa'],
    'Ipamorelin':    ['CJC-1295', 'GHRP-6'],
    'CJC-1295':      ['Ipamorelin', 'GHRP-6'],
    'GHRP-6':        ['Ipamorelin', 'CJC-1295'],
    'PT-141':        ['Melanotan II'],
    'AOD 9604':      ['Semaglutide', 'Fragment 176-191'],
    'Sermorelin':    ['Ipamorelin', 'CJC-1295'],
    'NAD+':          ['MOTS-c', 'Epithalon'],
    'MOTS-c':        ['NAD+', 'Epithalon'],
    'LL-37':         ['BPC-157', 'Thymosin Alpha-1'],
    'Thymosin Alpha-1': ['LL-37', 'Thymosin Beta-4'],
    'Thymosin Beta-4':  ['BPC-157', 'Thymosin Alpha-1'],
  };

  // Intent inference: maps user query keywords → research interest themes
  const SESSION_INTENT_MAP = [
    { theme: 'recovery & repair',    keywords: ['recovery', 'repair', 'healing', 'injury', 'tendon', 'joint', 'bpc', 'tb-500', 'tissue'] },
    { theme: 'sleep & circadian',    keywords: ['sleep', 'insomnia', 'circadian', 'dsip', 'melatonin', 'rest', 'wake', 'rem'] },
    { theme: 'cognitive & nootropic',keywords: ['cognitive', 'focus', 'memory', 'brain', 'nootropic', 'semax', 'selank', 'dihexa', 'mental'] },
    { theme: 'longevity & anti-aging',keywords: ['longevity', 'aging', 'anti-aging', 'antiaging', 'lifespan', 'epithalon', 'mots-c', 'nad', 'humanin', 'senescence'] },
    { theme: 'metabolic & weight',   keywords: ['weight', 'fat', 'metabolic', 'metabolism', 'glp-1', 'semaglutide', 'tirzepatide', 'aod', 'obesity', 'insulin'] },
    { theme: 'growth hormone & muscle', keywords: ['growth hormone', 'gh', 'ipamorelin', 'cjc', 'ghrp', 'muscle', 'lean mass', 'sermorelin', 'igf'] },
    { theme: 'sexual health',        keywords: ['libido', 'sexual', 'pt-141', 'melanotan', 'erectile', 'desire'] },
    { theme: 'immune & thymic',      keywords: ['immune', 'thymosin', 'thymic', 'immunity', 'infection', 'autoimmune', 'ta-1'] },
    // ⚠️ hair loss MUST come before 'skin & collagen' so 'hair' keywords resolve here first
    { theme: 'hair loss & growth',   keywords: ['hair loss', 'hair-loss', 'hair growth', 'hair-growth', 'alopecia', 'hair follicle', 'thinning hair', 'hairloss', 'baldness', 'hair regrowth'] },
    { theme: 'skin & collagen',      keywords: ['skin', 'collagen', 'ghk', 'wrinkle', 'complexion', 'wound', 'palmitoyl'] },
  ];

  const inferIntentFromMessage = (text) => {
    const lower = text.toLowerCase();
    const matched = SESSION_INTENT_MAP
      .filter(({ keywords }) => keywords.some(kw => lower.includes(kw)))
      .map(({ theme }) => theme);
    if (matched.length) {
      setSessionIntents(prev => {
        const updated = [...prev, ...matched];
        // Keep last 20 signals, no persistent storage
        return updated.slice(-20);
      });
    }
  };

  // ─── Voice Input (Web Speech API) ────────────────────────────────────────────
  const [isListening, setIsListening] = useState(false);
  const recognitionRef = useRef(null);
  const voiceTimeoutRef = useRef(null);
  const voiceSupported = typeof window !== 'undefined' &&
    ('SpeechRecognition' in window || 'webkitSpeechRecognition' in window);

  const startListening = () => {
    if (!voiceSupported || isListening) return;
    const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    const rec = new SR();
    rec.lang = navigator.language || 'en-US'; // Phase 3 — use browser locale for STT
    rec.continuous = false;
    rec.interimResults = true;
    rec.onstart = () => setIsListening(true);
    rec.onresult = (e) => {
      const transcript = Array.from(e.results)
        .map(r => r[0].transcript)
        .join('');
      setInput(transcript);
    };
    rec.onerror = () => stopListening();
    // Phase 3 — Voice auto-submit: when recognition ends, submit if transcript ≥ 3 chars
    rec.onend = () => {
      stopListening();
      setInput(prev => {
        if (prev.trim().length >= 3) {
          setTimeout(() => handleSend(), 50);
        }
        return prev;
      });
    };
    recognitionRef.current = rec;
    rec.start();
    // Auto-stop after 7 s
    voiceTimeoutRef.current = setTimeout(() => stopListening(), 7000);
  };

  const stopListening = () => {
    if (recognitionRef.current) {
      try { recognitionRef.current.stop(); } catch {}
      recognitionRef.current = null;
    }
    clearTimeout(voiceTimeoutRef.current);
    setIsListening(false);
  };

  // Cleanup on unmount
  useEffect(() => () => stopListening(), []);

  // ─── Compound Quick-Match ──────────────────────────────────────────────────
  // Scans input tokens against product names/displayNames/aliases in real-time.
  const quickMatch = useMemo(() => {
    if (!input.trim() || input.length < 3 || products.length === 0) return null;
    const tokens = input.toLowerCase().split(/[\s,;-]+/).filter(t => t.length >= 3);
    if (tokens.length === 0) return null;
    for (const product of products) {
      const names = [
        product.name,
        product.displayName,
        ...(product.aliases || []),
      ].filter(Boolean).map(n => n.toLowerCase());
      for (const token of tokens) {
        if (names.some(n => n.includes(token) || token.includes(n.split(' ')[0]))) {
          return product;
        }
      }
    }
    return null;
  }, [input, products]);

  const scrollRef = useRef(null);
  const typingIntervalRef = useRef(null);
  const [userScrolled, setUserScrolled] = useState(false);
  const [showScrollBtn, setShowScrollBtn] = useState(false);
  const [copiedMsgIdx, setCopiedMsgIdx] = useState(null);

  const [suggestions, setSuggestions] = useState([]);
  const [hasNewActivity, setHasNewActivity] = useState(false);
  const [sessionId] = useState(() => {
    const existing = sessionStorage.getItem('clinical_ai_session');
    if (existing) return existing;
    const id = `sess_${Math.random().toString(36).substr(2, 9)}`;
    sessionStorage.setItem('clinical_ai_session', id);
    return id;
  });

  // Fetch products and protocols for context & card rendering
  useEffect(() => {
    getActiveProducts().then(setProducts).catch(console.error);
    getAllProtocols().then(setProtocols).catch(console.error);
  }, []);

  // Build a memoised protocol search index whenever protocols load
  const protocolIndex = useMemo(() => buildProtocolIndex(protocols), [protocols]);
  // Memoised catalog index consumed by classifyQuery for compound-name recognition.
  const catalogIndex = useMemo(() => buildCatalogIndex(products), [products]);

  // ─── Build user context whenever auth state changes ───────────────────────
  useEffect(() => {
    if (!user) {
      setUserCtx(null);
      setRecentOrders([]);
      return;
    }

    const firstName = userProfile?.firstName || user.displayName?.split(' ')[0] || '';
    const lastName  = userProfile?.lastName  || '';
    const email     = user.email || '';
    const role      = userProfile?.role || 'guest';
    const isPro     = userProfile?.approved === true || userProfile?.isVerified === true || userProfile?.role === 'admin';

    // Has the user opened the assistant before?
    const sessionKey = `mp_ai_visited_${user.uid}`;
    const isReturning = !!sessionStorage.getItem(sessionKey);
    sessionStorage.setItem(sessionKey, '1');

    // Fetch up to 3 recent orders from Firestore
    const fetchOrders = async () => {
      try {
        const q = query(
          collection(db, 'orders'),
          where('userId', '==', user.uid),
          orderBy('createdAt', 'desc'),
          limit(3)
        );
        const snap = await getDocs(q);
        const orders = snap.docs.map(d => ({ id: d.id, ...d.data() }));
        setRecentOrders(orders);
        setUserCtx({
          isLoggedIn: true,
          firstName,
          lastName,
          email,
          role,
          isProfessional: isPro,
          isReturning,
          recentOrders: orders,
        });
      } catch {
        // Orders fetch failed — still build ctx without orders
        setUserCtx({
          isLoggedIn: true,
          firstName,
          lastName,
          email,
          role,
          isProfessional: isPro,
          isReturning,
          recentOrders: [],
        });
      }
    };

    fetchOrders();
  }, [user, userProfile]);

  // Persist message history to both localStorage (long-term) and sessionStorage
  useEffect(() => {
    try {
      const serialised = JSON.stringify(messages);
      sessionStorage.setItem('clinical_ai_messages', serialised);
      // Keep at most the last 40 messages in localStorage to avoid quota issues
      const trimmed = messages.slice(-40);
      localStorage.setItem('clinical_ai_messages_v2', JSON.stringify(trimmed));
    } catch {}
  }, [messages]);

  // Update greeting when products or user context loads
  // (only if still showing the very first message)
  useEffect(() => {
    if (products.length === 0) return;
    setMessages(prev => {
      if (prev.length === 1) {
        const first = prev[0];
        // Replace if it's still the bare default or an old context-less greeting
        const isDefaultish = first.content === DEFAULT_GREETING ||
          !first.content.includes('**');
        if (isDefaultish) {
          const contextual = getInitialMsg(location.pathname, products, userCtx, getRecentViews());
          return [contextual];
        }
      }
      return prev;
    });
  }, [products, location.pathname, userCtx]);

  // Assistant opens only on user interaction — no auto-expand
  // (hasNewActivity badge still pulses to attract attention without forcing open)

  useEffect(() => {
    const handleHash = () => {
      if (window.location.hash === '#clinical-ai') {
        setIsOpen(true);
        // ── Product Intelligence Mode ──────────────────────────────────────
        // When triggered from a product detail page, inject a fresh
        // product-specific greeting so the assistant leads with context
        // rather than a generic opener or stale history.
        const productMatch = window.location.pathname.match(/^\/product\/(.+)/);
        if (productMatch && products.length > 0) {
          const contextualMsg = getInitialMsg(window.location.pathname, products, userCtx, getRecentViews());
          setMessages(prev => {
            // Only replace if there is exactly one message (the default greeting)
            // or if the first message doesn't already reference this product.
            const productName = contextualMsg.content.match(/\*\*(.+?)\*\*/)?.[1] || '';
            const alreadyContextual = prev.length === 1 && productName &&
              prev[0].content.includes(productName);
            if (alreadyContextual) return prev;
            // Keep conversation history but prepend/replace the greeting
            if (prev.length <= 1) return [contextualMsg];
            // If mid-conversation, prepend a product context reminder
            return prev;
          });
        }
        // Clear hash so it can be re-triggered
        window.history.replaceState(null, null, ' ');
      }
    };
    handleHash();
    window.addEventListener('hashchange', handleHash);
    return () => window.removeEventListener('hashchange', handleHash);
  }, [products, userCtx]);

  // ─── Context Bridge: external sections can open the AI with a message ────────
  // Usage from any component:
  //   window.dispatchEvent(new CustomEvent('open-clinical-ai', {
  //     detail: { message: 'Tell me about BPC-157 for recovery' }
  //   }));
  const pendingContextRef = useRef(null);
  useEffect(() => {
    const handleContextBridge = (e) => {
      // Accept detail.message, detail.query, OR just detail.context (SearchModal footer CTA)
      const msg = e?.detail?.message || e?.detail?.query;
      const ctx = e?.detail?.context;

      // Build a contextual opener when no explicit message is given.
      // IMPORTANT: the message must read as a *goal intent query* so the AI's
      // intent classifier fires GOAL_COMPREHENSIVE_MODE and returns peptides +
      // protocols + supplements. A vague "I was searching for X" message
      // bypasses classification and returns an empty/generic answer.
      const resolvedMsg = msg || (() => {
        if (!ctx) return 'Hi! How can I help you today?';
        if (ctx.currentQuery) {
          // Frame the query as an explicit goal search — triggers comprehensive mode
          return `I'm looking for peptides, supplements and protocols for "${ctx.currentQuery}". What are the best options?`;
        }
        const tabMap = { Peptides: 'peptides', Supplements: 'supplements', Protocols: 'protocols' };
        const tabLabel = tabMap[ctx.activeTab] || 'products';
        return `I was browsing the ${tabLabel} catalog and could use some guidance. Can you help me find the right option for my goal?`;
      })();

      setIsOpen(true);
      // Store pending message; handleSend will pick it up after the modal opens
      pendingContextRef.current = resolvedMsg;
    };
    window.addEventListener('open-clinical-ai', handleContextBridge);
    return () => window.removeEventListener('open-clinical-ai', handleContextBridge);
  }, []);

  // Fire the pending context message once the modal is open
  useEffect(() => {
    if (isOpen && pendingContextRef.current) {
      const msg = pendingContextRef.current;
      pendingContextRef.current = null;
      // Small delay so the modal animation completes before sending
      setTimeout(() => {
        handleSend(msg);
      }, 320);
    }
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [isOpen]);

  // ─── Phase 5: Track ai_session_start on first open ───────────────────────
  const aiSessionTrackedRef = useRef(false);
  useEffect(() => {
    if (isOpen && !aiSessionTrackedRef.current) {
      aiSessionTrackedRef.current = true;
      trackAISessionStart(sessionId, location.pathname);
    }
  }, [isOpen, sessionId, location.pathname]);

  // High-intent page-view escalation trigger
  useEffect(() => {
    const isHighIntent =
      location.pathname.startsWith('/product/') ||
      location.pathname.startsWith('/protocol/') ||
      location.pathname.startsWith('/checkout') ||
      location.pathname.startsWith('/cart');
    if (isHighIntent) {
      activityRef.current.pageViews += 1;
      // After viewing 2 high-intent pages, offer support (delayed to avoid jarring)
      if (activityRef.current.pageViews >= 2 && !supportShownThisSession.current) {
        const pageLabel = location.pathname.split('/').filter(Boolean).join(' › ');
        setTimeout(() => maybeShowSupport('high_intent', pageLabel), 6000);
      }
    }
  }, [location.pathname, maybeShowSupport]);

  // Ref pointing to the most-recent assistant message bubble
  const lastAssistantMsgRef = useRef(null);
  // Track previous message count to detect when a new message is appended
  const prevMsgCountRef = useRef(0);

  // Scroll to the TOP of the new assistant message when it first appears.
  // While streaming, do NOT auto-scroll so the user can read without the
  // content jumping away from them.
  useEffect(() => {
    const currentCount = messages.length;
    const lastMsg = messages[currentCount - 1];
    const isNewAssistantMsg = currentCount > prevMsgCountRef.current && lastMsg?.role === 'assistant';

    if (isNewAssistantMsg && lastAssistantMsgRef.current && scrollRef.current) {
      // Small rAF delay so the DOM has rendered the bubble before we measure
      requestAnimationFrame(() => {
        const container = scrollRef.current;
        const bubble = lastAssistantMsgRef.current;
        if (!container || !bubble) return;
        const bubbleTop = bubble.offsetTop;
        container.scrollTo({ top: bubbleTop - 12, behavior: 'smooth' });
      });
    }

    prevMsgCountRef.current = currentCount;
  }, [messages]);

  const handleScrollMessages = () => {
    if (!scrollRef.current) return;
    const { scrollTop, scrollHeight, clientHeight } = scrollRef.current;
    const nearBottom = scrollHeight - scrollTop - clientHeight < 80;
    setUserScrolled(!nearBottom);
    setShowScrollBtn(!nearBottom);
  };

  const scrollToBottom = () => {
    if (scrollRef.current) {
      scrollRef.current.scrollTo({ top: scrollRef.current.scrollHeight, behavior: 'smooth' });
    }
    setUserScrolled(false);
    setShowScrollBtn(false);
  };

  // Copy assistant message to clipboard
  const copyMessage = (text, idx) => {
    const plain = text
      .replace(/\*\*(.+?)\*\*/g, '$1')
      .replace(/\*(.+?)\*/g, '$1')
      .replace(/\[PRODUCT:(.*?)\]/g, '$1')
      .replace(/\[PROTOCOL:(.*?)\]/g, '$1')
      .replace(/\[RECON_TOOL:.*?\]/g, '')
      .replace(/\[QUESTION:.*?\]/g, '')
      .replace(/\[FAMILY:.*?\]/g, '')
      .replace(/\[ROLE:.*?\]/g, '')
      .replace(/\[MATURITY:.*?\]/g, '')
      .replace(/\[COMPARE_SUMMARY:.*?\]/g, '')
      .replace(/\[RESEARCH_INTEREST:.*?\]/g, '')
      .replace(/\[STACK:.*?\]/g, '')
      .trim();
    navigator.clipboard.writeText(plain).then(() => {
      setCopiedMsgIdx(idx);
      setTimeout(() => setCopiedMsgIdx(null), 2000);
    });
  };

  // Clear conversation and start fresh
  const clearSession = () => {
    sessionStorage.removeItem('clinical_ai_messages');
    sessionStorage.removeItem('clinical_ai_session');
    try { localStorage.removeItem('clinical_ai_messages_v2'); } catch {}
    queryCacheRef.current.clear();
    setMessages([getInitialMsg(location.pathname, products, userCtx, getRecentViews())]);
    setSuggestions([]);
    setUserScrolled(false);
    setShowScrollBtn(false);
    activityRef.current = { messagesSent: 0, negFeedbackCount: 0, comparisonCount: 0, sessionStart: Date.now(), pageViews: 0 };
    supportShownThisSession.current = false;
    setShowSupportCard(false);
  };

  // ─── WhatsApp Support Card Component ──────────────────────────────────────
  const WHATSAPP_NUMBER = '971564179256';
  const buildWhatsAppUrl = () => {
    // Phase 1a: contextual prefilled message using explored compounds
    const explored = exploredCompoundsRef.current;
    let base;
    if (explored.length >= 2) {
      const list = explored.slice(0, 3).join(' and ');
      base = `Hello, I was reviewing ${list} on Med-Peptides and would like help understanding the differences and possible protocol options.`;
    } else if (explored.length === 1) {
      base = `Hello, I was reviewing ${explored[0]} on Med-Peptides and would like more information about protocols and research applications.`;
    } else if (supportContext) {
      base = `Hello, I was reviewing ${supportContext} on Med-Peptides and would like expert guidance on protocols and peptides.`;
    } else {
      base = 'Hello, I was exploring peptides and protocols on Med-Peptides and would like help finding the most relevant options for my research goals.';
    }
    return `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(base)}`;
  };

  const SupportEscalationCard = () => (
    <AnimatePresence>
      {showSupportCard && (
        <motion.div
          key="support-card"
          className="ca-support-mobile"
          initial={{ opacity: 0, y: 20, scale: 0.96 }}
          animate={{ opacity: 1, y: 0, scale: 1 }}
          exit={{ opacity: 0, y: 16, scale: 0.95 }}
          transition={{ duration: 0.3, ease: [0.34, 1.56, 0.64, 1] }}
          style={{
            position: 'fixed',
            bottom: isOpen ? '560px' : '6.5rem',
            left: '2rem',
            zIndex: 9998,
            width: '280px',
            background: 'linear-gradient(135deg, #ffffff 0%, #f0f7ff 100%)',
            borderRadius: '20px',
            border: '1px solid rgba(0, 120, 215, 0.18)',
            boxShadow: '0 8px 32px rgba(0,75,135,0.18), 0 2px 8px rgba(0,0,0,0.06)',
            padding: '1.25rem',
            fontFamily: "'Inter', sans-serif",
          }}
        >
          {/* Header */}
          <div style={{ display: 'flex', alignItems: 'flex-start', justifyContent: 'space-between', marginBottom: '0.75rem' }}>
            <div style={{ display: 'flex', alignItems: 'center', gap: '0.5rem' }}>
              {/* WhatsApp icon */}
              <div style={{
                width: '32px', height: '32px', borderRadius: '50%',
                background: 'linear-gradient(135deg, #25D366, #128C7E)',
                display: 'flex', alignItems: 'center', justifyContent: 'center',
                flexShrink: 0,
              }}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="white">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                  <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.553 4.116 1.522 5.847L.057 23.882l6.206-1.438C7.878 23.44 9.894 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.937 0-3.741-.524-5.288-1.437l-.379-.225-3.683.853.872-3.583-.247-.39C2.524 15.73 2 13.926 2 12 2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
                </svg>
              </div>
              <span style={{ fontSize: '0.8rem', fontWeight: 800, color: '#0f172a', lineHeight: 1.2 }}>
                Need Help Navigating Protocols or Comparing Peptides?
              </span>
            </div>
            <button
              onClick={dismissSupportCard}
              style={{ background: 'none', border: 'none', cursor: 'pointer', padding: '2px', color: '#94a3b8', lineHeight: 1 }}
              aria-label="Dismiss"
            >
              <X size={14} />
            </button>
          </div>

          {/* Body */}
          <p style={{ fontSize: '0.72rem', color: '#475569', lineHeight: 1.5, margin: '0 0 1rem' }}>
            Our team can continue this discussion directly on WhatsApp and help you explore the most relevant peptides and protocols for your research goals.
          </p>

          {/* CTA */}
          <a
            href={buildWhatsAppUrl()}
            target="_blank"
            rel="noopener noreferrer"
            onClick={() => {
              trackSupportEvent('support_prompt_clicked', 'whatsapp_cta');
              // Phase 5 — track ai_to_whatsapp
              trackAIToWhatsApp(sessionId, supportContext || 'manual', activityRef.current.messagesSent);
            }}
            style={{
              display: 'flex',
              alignItems: 'center',
              justifyContent: 'center',
              gap: '0.5rem',
              width: '100%',
              padding: '0.7rem',
              borderRadius: '12px',
              background: 'linear-gradient(135deg, #25D366, #128C7E)',
              color: 'white',
              fontWeight: 700,
              fontSize: '0.78rem',
              textDecoration: 'none',
              boxShadow: '0 4px 14px rgba(37,211,102,0.35)',
              transition: 'opacity 0.2s',
            }}
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="white">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.553 4.116 1.522 5.847L.057 23.882l6.206-1.438C7.878 23.44 9.894 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.937 0-3.741-.524-5.288-1.437l-.379-.225-3.683.853.872-3.583-.247-.39C2.524 15.73 2 13.926 2 12 2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
            </svg>
            Continue on WhatsApp
          </a>

          <p style={{ fontSize: '0.62rem', color: '#94a3b8', textAlign: 'center', margin: '0.6rem 0 0', fontWeight: 500 }}>
            Research concierge · Available on WhatsApp
          </p>
        </motion.div>
      )}
    </AnimatePresence>
  );

  // ─── Export session ────────────────────────────────────────────────────
  const exportSession = () => {
    if (messages.length <= 1) return;
    const lines = [
      'Med-Peptides Clinical AI — Session Export',
      `Date: ${new Date().toLocaleString()}`,
      '='.repeat(60),
      '',
      ...messages
        .filter(m => typeof m.content === 'string')
        .map(m => {
          const role = m.role === 'assistant' ? 'AI' : 'You';
          const time = m.timestamp ? new Date(m.timestamp).toLocaleTimeString() : '';
          // Strip markdown bold/italic for plain text
          const text = m.content.replace(/\*\*(.+?)\*\*/g, '$1').replace(/\*(.+?)\*/g, '$1');
          return `[${time}] ${role}:\n${text}\n`;
        }),
      '='.repeat(60),
      'For research purposes only. Not clinical advice.'
    ];
    const blob = new Blob([lines.join('\n')], { type: 'text/plain;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `med-peptides-session-${Date.now()}.txt`;
    a.click();
    URL.revokeObjectURL(url);
  };

  // Clean up typewriter on unmount
  useEffect(() => {
    return () => {
      if (typingIntervalRef.current) clearInterval(typingIntervalRef.current);
    };
  }, []);

  const handleSend = async (suggestion) => {
    let messageText = input;
    
    // Check if suggestion is actually a suggestion object (not a React event)
    if (suggestion && typeof suggestion === 'object' && !suggestion.nativeEvent) {
      if (suggestion.action === 'NAVIGATE') {
        navigate(suggestion.payload);
        setIsOpen(false);
        return;
      }
      if (suggestion.action === 'URL') {
        window.open(suggestion.payload, '_blank', 'noopener,noreferrer');
        return;
      }
      if (suggestion.action === 'MESSAGE') {
        messageText = suggestion.payload;
      } else {
        messageText = suggestion.label || suggestion.payload || '';
      }
    } else if (typeof suggestion === 'string') {
      messageText = suggestion;
    }

    if (!messageText.trim() || isLoading || isTyping) return;

    const userMsg = { role: 'user', content: messageText, timestamp: new Date() };
    setMessages(prev => [...prev, userMsg]);
    setInput('');
    setSuggestions([]);
    setIsLoading(true);
    setHasNewActivity(false);

    // Phase 8 — infer session intent from this message (session-only)
    inferIntentFromMessage(messageText);

    // Track activity
    activityRef.current.messagesSent += 1;
    // Long-engagement trigger: ≥5 messages in session
    if (activityRef.current.messagesSent === 5 && !supportShownThisSession.current) {
      setTimeout(() => maybeShowSupport('long_engagement'), 4000);
    }

    // Phase 5 — track ai_question with inferred intent
    const isComparisonQuery5 = /\bvs\b|\bversus\b|\bcompare\b|\bdifference between\b/i.test(messageText);
    const inferredIntent = sessionIntents.length > 0 ? sessionIntents[sessionIntents.length - 1] : 'unknown';
    trackAIQuestion(sessionId, activityRef.current.messagesSent - 1, inferredIntent, isComparisonQuery5);

    // Phase 1b — comparison query trigger
    const isComparisonQuery = /\bvs\b|\bversus\b|\bcompare\b|\bdifference between\b/i.test(messageText);
    if (isComparisonQuery) {
      activityRef.current.comparisonCount += 1;
      // After 2 comparisons, offer concierge guidance
      if (activityRef.current.comparisonCount >= 2 && !supportShownThisSession.current) {
        setTimeout(() => maybeShowSupport('advanced_comparison', messageText.slice(0, 60)), 3500);
      }
    }

    // ── Query cache check ──────────────────────────────────────────────────────
    // Normalise the key: lowercase, collapse whitespace
    const cacheKey = messageText.trim().toLowerCase().replace(/\s+/g, ' ');
    const cached = queryCacheRef.current.get(cacheKey);
    if (cached) {
      // Replay cached reply via typewriter (skip the API call)
      setIsLoading(false);
      setIsTyping(true);
      setMessages(prev => [...prev, { role: 'assistant', content: '', fullContent: cached.reply, timestamp: new Date() }]);
      let ci = 0;
      if (typingIntervalRef.current) clearInterval(typingIntervalRef.current);
      typingIntervalRef.current = setInterval(() => {
        ci++;
        setMessages(prev => {
          const updated = [...prev];
          const last = updated[updated.length - 1];
          if (last && last.role === 'assistant' && last.fullContent) {
            updated[updated.length - 1] = { ...last, content: last.fullContent.slice(0, ci) };
          }
          return updated;
        });
        if (ci >= cached.reply.length) {
          clearInterval(typingIntervalRef.current);
          typingIntervalRef.current = null;
          setIsTyping(false);
          setSuggestions(cached.suggestions || []);
          setHasNewActivity(true);
        }
      }, 14);
      return;
    }

    // ── Pre-search synonym expansion ──────────────────────────────────────────
    // Broad intent queries like "anti-aging" rarely match product names directly.
    // We expand them via a synonym map before running the search engine so that
    // longevity compounds (Epithalon, NAD+, MOTS-c, GHK-Cu, etc.) score positively.
    const PRE_SEARCH_SYNONYMS = {
      'anti aging':       'longevity epithalon nad ghk-cu mots-c humanin cellular regeneration',
      'anti-aging':       'longevity epithalon nad ghk-cu mots-c humanin cellular regeneration',
      'antiaging':        'longevity epithalon nad ghk-cu mots-c humanin cellular regeneration',
      'longevity':        'epithalon nad mots-c humanin telomere aging lifespan',
      'fat loss':         'weight loss semaglutide aod metabolic',
      'fat-loss':         'weight loss semaglutide aod metabolic',
      'weight loss':      'semaglutide aod tirzepatide metabolic',
      'weight-loss':      'semaglutide aod tirzepatide metabolic',
      'brain fog':        'cognitive focus semax selank dihexa',
      'brain-fog':        'cognitive focus semax selank dihexa',
      'gut health':       'bpc-157 leaky gut gastro intestinal',
      'gut-health':       'bpc-157 leaky gut gastro intestinal',
      'energy':           'nad mots-c mitochondrial',
      'sleep':            'dsip cjc sleep circadian',
      'muscle':           'ipamorelin cjc ghrp sermorelin growth hormone',
      'muscle growth':    'ipamorelin cjc ghrp sermorelin growth hormone',
      'muscle-growth':    'ipamorelin cjc ghrp sermorelin growth hormone',
      'injury':           'bpc-157 tb-500 tissue repair healing',
      'recovery':         'bpc-157 tb-500 tissue repair healing',
      'immune':           'thymosin ta-1 ll-37 immunity',
      'immunity':         'thymosin ta-1 ll-37 immunity',
      'skin':             'ghk-cu collagen palmitoyl',
      'skin health':      'ghk-cu collagen palmitoyl',
      'skin-health':      'ghk-cu collagen palmitoyl',
      'hair loss':        'ghk-cu hair follicle alopecia keratinocyte stem cell growth factor',
      'hair-loss':        'ghk-cu hair follicle alopecia keratinocyte stem cell growth factor',
      'hair growth':      'ghk-cu hair follicle alopecia keratinocyte stem cell regrowth',
      'hair-growth':      'ghk-cu hair follicle alopecia keratinocyte stem cell regrowth',
      'testosterone':     'testosterone hormonal libido',
      'sexual health':    'pt-141 melanotan libido sexual',
      'sexual-health':    'pt-141 melanotan libido sexual',
      'cognitive':        'semax selank dihexa cognitive nootropic brain',
      'inflammation':     'bpc-157 tb-500 ll-37 anti-inflammatory',
      'stress':           'selank semax cortisol adaptogen',
      'mood':             'selank semax serotonin wellbeing',
      'joint health':     'bpc-157 tb-500 collagen joint repair',
      'joint-health':     'bpc-157 tb-500 collagen joint repair',
    };

    // ── Known goal/intent terms that must NEVER be classified as compound names ──
    // These are health goal keywords that the standalone compound pattern might
    // incorrectly capture. Always treat them as goal queries, not peptide names.
    const KNOWN_GOAL_TERMS = new Set([
      'anti-aging', 'antiaging', 'anti aging',
      'hair-loss', 'hair loss', 'hair-growth', 'hair growth',
      'fat-loss', 'fat loss', 'weight-loss', 'weight loss',
      'brain-fog', 'brain fog',
      'gut-health', 'gut health',
      'skin-health', 'skin health',
      'sexual-health', 'sexual health',
      'joint-health', 'joint health',
      'muscle-growth', 'muscle growth',
      'longevity', 'energy', 'sleep', 'muscle', 'recovery',
      'immunity', 'inflammation', 'cognitive', 'stress', 'mood',
      'testosterone', 'libido', 'injury', 'aging', 'performance',
    ]);
    const expandQueryForSearch = (q) => {
      const lower = q.toLowerCase().trim();
      return PRE_SEARCH_SYNONYMS[lower] || lower;
    };
    const expandedSearchQuery = expandQueryForSearch(messageText);
    const didExpandQuery = expandedSearchQuery !== messageText.toLowerCase().trim();

    // ── Pre-search: run hybrid search engine BEFORE the API call ────────────
    // This mirrors the search modal logic, giving the LLM pre-ranked context.
    // Use expanded query when available to maximise recall for broad intent terms.
    const topProducts = searchProducts(
      didExpandQuery ? expandedSearchQuery : messageText,
      products,
      protocolIndex
    ).slice(0, 5);
    const topProtocols = searchProtocols(
      didExpandQuery ? expandedSearchQuery : messageText,
      protocolIndex
    ).slice(0, 4);

    // Detect whether the raw query maps to a known goal/intent theme even when
    // the search engine returns 0 results (e.g. products not yet tagged correctly).
    // We use the same SESSION_INTENT_MAP heuristic that drives session memory.
    const rawQueryLower = messageText.toLowerCase();
    const matchedGoalTheme = SESSION_INTENT_MAP.find(({ keywords }) =>
      keywords.some(kw => rawQueryLower.includes(kw))
    );

    // Format ranked compounds block — Phase 6: include description snippet for LLM grounding
    // ── Phase 9: Enrich ranked compounds with canonical context fields ────────
    // Each entry now exposes productType, top goals, and key mechanisms so
    // the AI can reason about *why* each compound matches the user's goal,
    // not just what it is called.
    const rankedCompoundsBlock = topProducts.length > 0
      ? `\n\nPRE-RANKED COMPOUNDS (top ${topProducts.length} by relevance — [Rules 9.0]):\n${topProducts.map((p, i) => {
          const pType    = p.productType || 'peptide';
          const pName    = p.displayName || p.name;
          const pSlug    = p.slug || p.id;
          // Canonical goals (top 2)
          const pGoals   = Array.isArray(p.goals)   && p.goals.length   > 0
            ? p.goals.slice(0, 2).join(', ')
            : (p.detectedThemes?.slice(0, 2).join(', ') || '');
          // Canonical mechanisms (top 2)
          const pMechs   = Array.isArray(p.mechanisms) && p.mechanisms.length > 0
            ? p.mechanisms.slice(0, 2).join(', ')
            : '';
          // Safety note — short flag if present
          const pSafety  = p.safetyNote ? ` ⚠️ ${p.safetyNote.substring(0, 60)}` : '';
          // Fallback description if no canonical fields
          const pDesc    = (!pGoals && !pMechs)
            ? (p.shortDescription || p.description || '').substring(0, 80)
            : '';

          return `${i + 1}. [${pType.toUpperCase()}] ${pName} [slug:${pSlug}]`
            + (pGoals   ? ` | Goals: ${pGoals}`      : '')
            + (pMechs   ? ` | Mechanisms: ${pMechs}` : '')
            + (pDesc    ? ` — ${pDesc}`               : '')
            + pSafety;
        }).join('\n')}`
      : '';

    // ── Format ranked protocols block — keep concise but add goal & slug ─────
    const rankedProtocolsBlock = topProtocols.length > 0
      ? `\n\nPRE-RANKED PROTOCOLS (top ${topProtocols.length} by relevance):\n${topProtocols.map((pr, i) => {
          const prGoal  = (pr.goal || pr.description || '').substring(0, 80);
          const prComps = Array.isArray(pr.compounds) && pr.compounds.length > 0
            ? ` | Compounds: ${pr.compounds.slice(0, 3).join(', ')}`
            : '';
          return `${i + 1}. ${pr.name || pr.title} [slug:${pr.protocol_slug || pr.slug}]`
            + (pr.category ? ` (${pr.category})` : '')
            + (prGoal      ? ` — ${prGoal}`       : '')
            + prComps;
        }).join('\n')}`
      : '';

    // Phase 5 — Session intent memory: build deduplicated list of all intents explored this session
    const sessionIntentContext = (() => {
      if (!sessionIntents.length) return '';
      const unique = [...new Set(sessionIntents)].slice(-8); // last 8 unique themes
      return `\n\n## Session Research Memory\nThis researcher has explored the following topics in this session: ${unique.join(', ')}.\nPrioritize compounds, protocols, and comparisons aligned with these themes in your answer. Do NOT repeat this list back to the user.`;
    })();

    // Flag: the hybrid search engine returned usable results for this query.
    // Used to activate GOAL_SEARCH_MODE which forces the LLM to present those results.
    const hasPreRankedResults = topProducts.length > 0 || topProtocols.length > 0;
    // hasKnownIntent: true even when search returns 0 results — used to still
    // activate a structured knowledge-driven response for broad intent queries.
    const hasKnownIntent = !!matchedGoalTheme;

    // ── Hybrid Immediate Render ───────────────────────────────────────────────
    // For goal/intent queries with pre-ranked results, push the assistant
    // placeholder message NOW (before the API call) so product/protocol cards
    // appear instantly. Compound-education queries ("tell me about X",
    // "what is X") are excluded — they rely on the LLM for their answer format.
    const _compoundEducationPattern = /(?:tell\s+me\s+about|what\s+(?:is|are|does|do)|explain|describe|info\s+(?:on|about)|about|how\s+does|how\s+do|cuéntame|qué\s+es|habla(?:me)?\s+(?:de|sobre)|información\s+(?:sobre|de)|dime\s+(?:sobre|acerca\s+de))/i;
    const isGoalQueryWithResults = hasPreRankedResults
      && !isQuestion(messageText)
      && !_compoundEducationPattern.test(messageText);
    if (isGoalQueryWithResults) {
      setMessages(prev => [...prev, {
        role: 'assistant',
        content: '',
        fullContent: null,
        preRankedProducts: topProducts,
        preRankedProtocols: topProtocols,
        preRankedQuery: messageText,
        timestamp: new Date(),
        _isPreRankedPlaceholder: true
      }]);
    }

    const isQueryAQuestion = isQuestion(messageText);

    // ── Phase 1 (Guided Engine) — classifyIntent ──────────────────────────────
    // Delegates to the canonical classifyQuery() utility (single source of truth).
    // catalogIndex is a memoised Map built from the products catalog above.
    //
    // classifyQuery() returns an OBJECT: { query_type, confidence, detected_entities, reason }.
    // We destructure it and map query_type → short intent name for use in the switch
    // statement and comparisons below (which all use short names like 'comparison', 'goal').
    const classifyResult   = classifyQuery(messageText, { catalogIndex });
    const detectedIntent   = QUERY_TYPE_TO_INTENT[classifyResult.query_type] || 'goal';
    const classifyEntities = classifyResult.detected_entities || [];  // Phase 2 catalog hits

    // ── Phase 3 (Guided Engine) — Beginner signal detection ───────────────────
    // Detects low-experience phrases so the AI can simplify its response.
    // When isBeginnerMode is true, BEGINNER_MODE directive is injected into the prompt.
    const isBeginnerMode = (() => {
      const lower = messageText.toLowerCase();
      const BEGINNER_SIGNALS = [
        'where do i start', 'where to start', 'getting started',
        "i'm new", 'im new', 'i am new', 'newbie', 'beginner',
        'never used', "don't know where", 'dont know where',
        "don't know what", 'dont know what',
        'first time', 'just starting', 'just started',
        'help me choose', 'help me pick', 'recommend for me',
        'what should i take', 'what should i try',
        'no experience', 'no idea', 'confused', 'overwhelmed',
        'explain it simply', 'in simple terms', 'laymans', "layman's"
      ];
      return BEGINNER_SIGNALS.some(signal => lower.includes(signal));
    })();

    // ── Phase 4 (Guided Engine) — Progressive layer detection ─────────────────
    // Returns 1–4 to indicate how deep the response should go.
    // Layer 1 = intro/overview, Layer 4 = advanced/mechanistic detail.
    const responseLayer = (() => {
      // Layer 4: advanced vocabulary → always go deep
      if (/\b(mechanism\s+of\s+action|receptor\s+(agonist|antagonist|binding)|half[- ]life|pharmacokinetics|pharmacodynamics|downstream\s+signaling|stack\s+synergy|bioavailability|peptide\s+bond|amino\s+acid\s+sequence|GHS-R|GLP-1R|IGF-1)\b/i.test(messageText)) {
        return 4;
      }
      // Layer 1: first message in session OR beginner signal
      const nonSystemMessages = messages.filter(m => m.role !== 'system');
      const isFirstMessage = nonSystemMessages.length <= 1;
      if (isFirstMessage || isBeginnerMode) return 1;

      // Layer 3: comparison query OR ≥4 user messages
      const userMessageCount = nonSystemMessages.filter(m => m.role === 'user').length;
      if (detectedIntent === 'comparison' || userMessageCount >= 4) return 3;

      // Layer 2: 2–3 messages in session
      if (userMessageCount >= 2) return 2;

      return 1;
    })();

    // ── Rules 7.0 — Compound query detection ─────────────────────────────────
    // Detect if the user's message names a specific compound WITHOUT asking for a
    // protocol or stack. If so, pre-classify as compound_query and inject compound
    // data so the AI can follow the mandatory compound_query response format.
    const isExplicitProtocolRequest = /\b(protocol|stack|recommend|which protocol|what protocol|best protocol|for (weight loss|fat loss|muscle|recovery|longevity|anti.aging|sleep|cognitive))\b/i.test(messageText);

    // ── Stage 1: Pattern-based detection ──────────────────────────────────────
    // Catches: "tell me about X", "what is X", "explain X", "info on X",
    //          "about tirzepatide", "tirzepatide?", "tirzepatide information",
    //          "how does X work", "what does X do", "X peptide", etc.
    //
    // ⚠️ BUG FIX: The regex captures the phrase immediately after the opener,
    // which for "explain the mechanism of action of Tirzepatide" captures
    // "the mechanism of action" — not the compound name. We must validate the
    // extracted candidate against the catalog and fall through if it's not a
    // real compound.
    const msgLowerForGoalCheck = messageText.toLowerCase().trim();
    // If the entire message is a known goal term, skip compound detection entirely
    const isKnownGoalQuery = KNOWN_GOAL_TERMS.has(msgLowerForGoalCheck)
      || Array.from(KNOWN_GOAL_TERMS).some(goal => msgLowerForGoalCheck === goal);

    const compoundPatternMatchRaw = !isExplicitProtocolRequest && !isKnownGoalQuery && (() => {
      const m = messageText.match(
        /(?:tell\s+me\s+about|what\s+(?:is|are|does|do)|explain|describe|info\s+(?:on|about)|about|how\s+does|how\s+do|cuéntame\s+(?:sobre|acerca\s+de)|qué\s+es|habla(?:me)?\s+(?:de|sobre)|información\s+(?:sobre|de)|dime\s+(?:sobre|acerca\s+de))\s+([A-Za-z0-9][A-Za-z0-9\-]{2,}(?:\s+[A-Za-z0-9\-]+){0,3})/i
      );
      if (m) return m[1].trim();

      // Standalone compound name: message is JUST a compound name (possibly with punctuation)
      // e.g. "Tirzepatide", "tirzepatide?", "BPC-157"
      // ⚠️ Guard: do NOT capture known health goal terms (e.g. "hair-loss", "anti-aging")
      const standalone = messageText.match(/^\s*([A-Za-z][A-Za-z0-9\-]{3,}(?:\s+[A-Za-z0-9\-]+){0,2})\s*[?!.]?\s*$/i);
      if (standalone) {
        const candidate = standalone[1].trim();
        // Reject if candidate is a known goal term
        if (KNOWN_GOAL_TERMS.has(candidate.toLowerCase())) return null;
        return candidate;
      }

      return null;
    })();

    // ── Stage 2: Catalog name scan ────────────────────────────────────────────
    // ALWAYS scan the full message for known compound names — regardless of
    // whether Stage 1 fired. This catches cases like "explain the mechanism of
    // action of Tirzepatide" where Stage 1 captures a non-compound phrase.
    // ⚠️ Skip entirely if we already identified this as a known goal query.
    const catalogCompoundMatch = !isExplicitProtocolRequest && !isKnownGoalQuery && (() => {
      const msgLower = messageText.toLowerCase();
      // Sort products by name length descending so longer names match first
      const sorted = [...products].sort((a, b) =>
        ((b.displayName || b.name || '').length) - ((a.displayName || a.name || '').length)
      );
      for (const p of sorted) {
        const name = (p.displayName || p.name || '').toLowerCase().trim();
        if (name.length < 3) continue;
        if (msgLower.includes(name)) return p;
      }
      return null;
    })();

    // Prefer catalog match (guaranteed real compound) over raw pattern extraction.
    // If the catalog found a compound in the message, use its display name.
    // Otherwise fall back to the raw pattern match only if it looks like a real compound
    // name (i.e. NOT a common English phrase like "the mechanism of action").
    const COMMON_PHRASE_TOKENS = /^(the|a|an|this|that|its|their|your|my|our|of|in|on|at|by|for|with|about|mechanism|action|effect|dose|dosage|protocol|stack|treatment|therapy|use|study|research|information|info|data|benefits|side|effects|risk|profile|compound|peptide|hormone)$/i;
    const patternMatchIsRealCompound = compoundPatternMatchRaw && (() => {
      const tokens = compoundPatternMatchRaw.toLowerCase().replace(/[-_]/g, ' ').split(/\s+/);
      // If the first token is a common English word, this is NOT a compound name
      return !COMMON_PHRASE_TOKENS.test(tokens[0]);
    })();
    const compoundPatternMatch = patternMatchIsRealCompound ? compoundPatternMatchRaw : null;

    // ⚠️ Firebase is the single source of truth for compound data.
    // detectedCompound is set from catalog scan (guaranteed match) or null.
    // compoundPatternMatch provides the name hint to the backend when the compound
    // isn't in the local cache yet.
    const detectedCompound = !isExplicitProtocolRequest ? (catalogCompoundMatch || null) : null;

    // Classify as compound_query if:
    // (a) pattern match found ("tell me about X", standalone name) — even if not in DB
    // (b) catalog scan found the compound name inside the message
    // (c) top pre-search result name tokens appear in the message
    const isCompoundQuery = (() => {
      if (isExplicitProtocolRequest) return false;
      // Pattern-based or standalone: always trust these
      if (compoundPatternMatch) return true;
      // Catalog scan: compound name literally found in message
      if (catalogCompoundMatch) return true;
      if (!detectedCompound) return false;
      const compoundName = (detectedCompound.displayName || detectedCompound.name || '').toLowerCase();
      const msgLower = messageText.toLowerCase();
      const nameTokens = compoundName.replace(/[-_]/g, ' ').split(/\s+/).filter(t => t.length > 2);
      return nameTokens.length > 0 && nameTokens.some(token => msgLower.includes(token));
    })();

    // Build compound data block for injection into the system prompt
    const compoundDataBlock = isCompoundQuery ? (() => {
      // ── Phase 9: Read canonical fields + legacy fallbacks ─────────────────
      const c = detectedCompound;
      const name = c ? (c.displayName || c.name || compoundPatternMatch || 'Unknown') : (compoundPatternMatch || 'Unknown');
      const slug = c ? (c.slug || c.id || '') : '';

      // Product type drives the response template (peptide | supplement | stack | unknown)
      const productType = c?.productType || (
        c?.category?.toLowerCase().includes('supplement') ? 'supplement' :
        c?.category?.toLowerCase().includes('stack') ? 'stack' : 'peptide'
      );

      // Description — prefer canonical aiContent, then legacy fields
      const aiContent = c?.aiContent || {};
      const description = aiContent.summary
        || c?.description
        || c?.shortDescription
        || '';

      // Goals — canonical array, then aiContent.goals, then typeData.goals
      const goalsRaw = c?.goals
        || aiContent.goals
        || c?.typeData?.goals
        || [];
      const goals = Array.isArray(goalsRaw) ? goalsRaw : [];

      // Mechanisms
      const mechsRaw = c?.mechanisms
        || aiContent.mechanisms
        || c?.typeData?.mechanisms
        || [];
      const mechanisms = Array.isArray(mechsRaw) ? mechsRaw : [];

      // Semantic keywords / synonyms (alias expansion for the AI)
      const keywordsRaw = c?.semanticKeywords || c?.typeData?.semanticKeywords || [];
      const synonymsRaw = c?.synonyms || c?.aliases || c?.typeData?.synonyms || [];
      const keywords = [...new Set([
        ...(Array.isArray(keywordsRaw) ? keywordsRaw : []),
        ...(Array.isArray(synonymsRaw) ? synonymsRaw : []),
      ])];

      // Safety note (injected into the safety section)
      const safetyNote = c?.safetyNote || aiContent.safetyNote || c?.typeData?.safetyNote || '';

      // Legacy fields (still used if Phase 9 fields absent)
      const category = c?.category || c?.detectedThemes?.[0] || 'Research Compound';
      const forms = c?.forms || c?.vialSizes || c?.variants || [];
      const similarTo = c?.similarCompounds || c?.similar || [];
      const relatedProtocols = c?.protocols || c?.relatedProtocols || [];

      // ── Choose prompt template by productType ─────────────────────────────
      const formatDirective = productType === 'supplement'
        ? `⚠️ SUPPLEMENT FORMAT — YOU MUST FOLLOW THIS EXACTLY:
1. Start with: "## ${name}"
2. What It Is — 2-sentence overview (nutrient/compound class, origin)
3. Primary Research Areas — 3-4 bullet points${goals.length > 0 ? ` (focus on: ${goals.slice(0,3).join(', ')})` : ''}
4. How It's Used — oral/topical/injectable, typical dosing range
5. Synergistic Peptides — 2-3 peptides that pair well
6. Safety Profile — known contraindications, interactions${safetyNote ? `\n   IMPORTANT SAFETY NOTE: ${safetyNote}` : ''}
7. DO NOT lead with a protocol recommendation.`
        : productType === 'stack'
        ? `⚠️ STACK FORMAT — YOU MUST FOLLOW THIS EXACTLY:
1. Start with: "## ${name}"
2. Stack Overview — what compounds are included and the shared goal
3. Why This Stack Works — synergy mechanisms
4. Who Is It For — experience level, research context
5. Protocol Structure — phases, timing, cycle length
6. Individual Component Profiles — brief note on each compound with [PRODUCT:slug] tags
7. Safety Considerations${safetyNote ? `\n   IMPORTANT SAFETY NOTE: ${safetyNote}` : ''}
8. DO NOT skip the individual compound breakdown.`
        : `⚠️ PEPTIDE FORMAT — YOU MUST FOLLOW THIS EXACTLY:
1. Start with: "## ${name}"
2. What It Is — mechanism of action, peptide class, origin${mechanisms.length > 0 ? `\n   Key mechanisms: ${mechanisms.slice(0,3).join(', ')}` : ''}
3. Primary Research Areas — 3-4 bullet points${goals.length > 0 ? ` (emphasize: ${goals.slice(0,3).join(', ')})` : ''}
4. Available Forms${slug ? ` (include [PRODUCT:${slug}] tag)` : ''}
5. Similar Peptides — 2-3 related compounds with a one-line distinction
6. Safety Profile${safetyNote ? `\n   IMPORTANT SAFETY NOTE: ${safetyNote}` : ''}
7. DO NOT start with GOAL, PROTOCOL, STACK, or RECOMMENDED PROTOCOL sections.
8. DO NOT lead with a protocol recommendation. Compound education FIRST.`;

      return `

===== COMPOUND DATA — INJECTED BY FRONTEND [Rules 9.0] =====
QUERY TYPE: compound_query
PRODUCT TYPE: ${productType.toUpperCase()}
USER ASKED ABOUT: "${name}"

${formatDirective}

--- PRODUCT DATA ---
NAME: ${name}${slug ? `\nSLUG: ${slug}` : ''}
TYPE: ${productType}
CATEGORY: ${category}${description ? `\nSUMMARY: ${description}` : ''}${goals.length > 0 ? `\nRESEARCH GOALS: ${goals.join(', ')}` : ''}${mechanisms.length > 0 ? `\nMECHANISMS: ${mechanisms.join(', ')}` : ''}${keywords.length > 0 ? `\nKEYWORDS / ALIASES: ${keywords.join(', ')}` : ''}${Array.isArray(forms) && forms.length > 0 ? `\nAVAILABLE FORMS: ${forms.join(', ')}` : ''}${Array.isArray(similarTo) && similarTo.length > 0 ? `\nSIMILAR COMPOUNDS: ${similarTo.join(', ')}` : ''}${Array.isArray(relatedProtocols) && relatedProtocols.length > 0 ? `\nRELATED PROTOCOLS (mention AFTER compound info): ${relatedProtocols.join(', ')}` : ''}${safetyNote ? `\nSAFETY NOTE: ${safetyNote}` : ''}
===== END COMPOUND DATA =====`;
    })() : '';

    // Phase 1 — use the canonical query_type from classifyResult directly.
    // Falls back to local heuristics only when classifyResult is inconclusive.
    const detectedQueryType = classifyResult.query_type
      || INTENT_TO_QUERY_TYPE[detectedIntent]
      || (isCompoundQuery ? 'compound_query' : isComparisonQuery ? 'comparison_query' : isQueryAQuestion ? 'education_query' : 'goal_query');

    // Build user context block for the AI system prompt
    // Phase 8 — derive dominant session intent (most frequent theme)
    const intentTheme = (() => {
      if (!sessionIntents.length) return null;
      const freq = {};
      sessionIntents.forEach(t => { freq[t] = (freq[t] || 0) + 1; });
      return Object.entries(freq).sort((a, b) => b[1] - a[1])[0]?.[0] || null;
    })();

    const userContextBlock = userCtx ? `
- **Logged in:** Yes
- **Name:** ${userCtx.firstName}${userCtx.lastName ? ' ' + userCtx.lastName : ''}
- **Email:** ${userCtx.email}
- **Account type:** ${userCtx.role}
- **Professional / verified:** ${userCtx.isProfessional ? 'Yes' : 'No'}
- **Returning user:** ${userCtx.isReturning ? 'Yes' : 'No (first session)'}
${userCtx.recentOrders.length > 0
  ? `- **Recent orders (up to 3):**\n${userCtx.recentOrders.map((o, i) =>
      `  ${i + 1}. Order #${o.orderNumber || o.id} — Status: ${o.status || 'Processing'} — Date: ${o.createdAt?.toDate ? o.createdAt.toDate().toLocaleDateString() : (o.createdAt || 'N/A')}${o.items?.length ? ` — Items: ${o.items.map(it => it.name || it.productName || it.slug).filter(Boolean).join(', ')}` : ''}`
    ).join('\n')}`
  : `- **Recent orders:** None found`}

If the user asks about their order, delivery, or purchase history, answer using the above data. Do NOT fabricate order details. If the order they reference is not in the list, say you can only see their most recent orders and suggest they contact support.${intentTheme ? `
- **Session research theme (inferred):** ${intentTheme}. Subtly adapt comparisons, protocol suggestions, and related compound recommendations toward this theme without explicitly stating it.` : ''}`
        : `- **Logged in:** No (guest / anonymous session). The user is browsing without an account. Do not reference any order history. If they ask about orders, suggest they log in.${intentTheme ? `
- **Session research theme (inferred):** ${intentTheme}. Subtly adapt comparisons, protocol suggestions, and related compound recommendations toward this theme.` : ''}`;

    // When it's a peptide query, prepend a hard directive to the message itself.
    // This guarantees the model sees the format constraint in the user turn,
    // bypassing any backend system prompt ordering that might ignore context.instructions.
    //
    // GOAL_COMPREHENSIVE_MODE: When a goal/intent query is detected (e.g. "anti-aging",
    // "weight loss"), immediately return a unified response covering:
    //   1. Recommended peptides (with [PRODUCT:slug] tags)
    //   2. Recommended protocols (with [PROTOCOL:slug] tags)
    //   3. Complementary supplements
    // No fork, no choice required — give the full picture immediately.

    // Derive the original user intent label for injection into the prompt.
    // Priority: matched goal theme > known goal term > raw message.
    // This prevents the AI from re-labelling the user's goal based on compound tags.
    const originalIntentLabel = matchedGoalTheme?.theme
      || (isKnownGoalQuery ? messageText : null)
      || messageText;

    // ── Phase 2 (Guided Engine) — intent-driven prompt selection ─────────────
    // Each detectedIntent maps to a focused prompt template.
    // The legacy mode strings (PEPTIDE_EDUCATION_MODE, GOAL_COMPREHENSIVE_MODE, etc.)
    // are preserved so the system prompt understands them; new templates added for
    // safety, comparison, protocol, availability, supplement, and education intents.
    let effectiveMessage;
    switch (detectedIntent) {
      case 'peptide': {
        const compoundName = detectedCompound
          ? (detectedCompound.displayName || detectedCompound.name)
          : (compoundPatternMatch || messageText);
        effectiveMessage = `[PEPTIDE_EDUCATION_MODE] The user is asking about a specific peptide: "${compoundName}". You MUST respond with educational peptide information ONLY. DO NOT start with GOAL, PROTOCOL, STACK, or RECOMMENDED PROTOCOL. Structure:

## ${compoundName}
**What It Is** — A concise 2-sentence overview of this peptide.

**Primary Research Areas** — List 3-4 peer-reviewed research application areas.

**Available Forms** — Briefly note the common administration route(s).

**Similar Peptides** — Name 2-3 related peptides with a one-line distinction.

Then offer exactly 3 short follow-up options: "More detail", "Similar peptides", "Protocols using this peptide".

Original user message: "${messageText}"`;
        break;
      }

      case 'comparison': {
        effectiveMessage = `[COMPARISON_MODE] The user wants to compare peptides or compounds. User message: "${messageText}".

Structure your response as a clear side-by-side analysis:

## Head-to-Head Comparison
Use a table or clearly labelled parallel sections.

**For each compound:**
- Primary mechanism of action
- Key research applications
- Typical research protocols (dosing range)
- Strengths vs limitations

## Which to Choose?
Give a clear recommendation based on the user's stated context/goal.

Tag each compound with [PRODUCT:slug] if it exists in the catalog. Do NOT pick sides without explaining the reasoning.`;
        break;
      }

      case 'protocol': {
        effectiveMessage = `[PROTOCOL_MODE] The user is asking for a research protocol or stack recommendation. User message: "${messageText}".

Structure your response as:

## 🎯 Goal
Restate the user's specific research objective in one sentence.

## 📋 Recommended Protocol
${topProtocols.length > 0 ? `List each protocol with [PROTOCOL:slug] tag.` : `List a well-structured protocol based on your training data.`}

## 💊 Compounds in This Protocol
For each compound: name with [PRODUCT:slug] tag, role in the protocol, dosing range, and frequency.

## ⚠️ Important Notes
Any key considerations: cycling, interactions, monitoring.

## ➡️ Next Steps
Suggest 2 follow-up questions the user might want to explore.

Do NOT list compounds without protocol context. Always frame recommendations around the stated goal: "${originalIntentLabel || messageText}".`;
        break;
      }

      case 'safety': {
        effectiveMessage = `[SAFETY_MODE] The user has asked a safety-related question. User message: "${messageText}".

Structure your response as:

## ⚠️ Safety Overview
Address the specific safety concern directly and clearly.

## Known Considerations
List any documented side effects, contraindications, or interactions relevant to the query.

## Recommended Precautions
Practical research-safety guidance. Do NOT provide medical advice.

## 🔬 Research Context
Brief note on the current evidence level for this compound/topic.

Keep language clear and accessible. Do NOT overwhelm with protocols. End with: "For personalized guidance, consult a qualified healthcare professional."`;
        break;
      }

      case 'supplement': {
        effectiveMessage = `[SUPPLEMENT_MODE] The user is asking about a non-peptide supplement. User message: "${messageText}".

Structure your response as:

## 🌿 Supplement Overview
What it is and its primary evidence-based uses.

## How It Complements Peptide Research
Briefly explain how this supplement may synergize with peptide protocols (if applicable).

## 💊 Relevant Peptides
List 2-3 peptides that are commonly researched alongside this supplement, each with [PRODUCT:slug] tag.

## ➡️ Suggested Next Steps
2 follow-up questions to guide the conversation forward.`;
        break;
      }

      case 'availability': {
        effectiveMessage = `[AVAILABILITY_MODE] The user is asking about product availability, pricing, or sourcing. User message: "${messageText}".

${topProducts.length > 0
  ? `The following compounds were found in our catalog: ${topProducts.map(p => `${p.displayName || p.name} [PRODUCT:${p.slug || p.id}]`).join(', ')}.`
  : 'No exact catalog match was found.'
}

Structure your response:

## 🛒 Availability
State clearly whether the compound(s) mentioned are available in the catalog.

## 📦 Product Details
For each available compound, link it with [PRODUCT:slug] so the user can view the product page.

## 💡 Alternatives
If unavailable, suggest 1-2 similar compounds that ARE in the catalog.

Keep the response short and action-oriented. Do NOT launch into educational content unless the user asks.`;
        break;
      }

      case 'education': {
        effectiveMessage = `[EDUCATION_MODE] The user is asking a general educational question about peptides or related science. User message: "${messageText}".

Structure your response as:

## 🔬 Overview
A clear, jargon-light answer (2-3 sentences) addressing the core question.

## How This Applies to Research
Practical context for how this concept is relevant to peptide research.

## Related Compounds
If applicable, mention 1-3 peptides related to this concept with [PRODUCT:slug] tags.

## ➡️ Want to Go Deeper?
Offer 2 follow-up directions (e.g., "See specific protocols", "Compare related peptides").

Keep the tone educational and accessible — assume the user wants to learn, not just buy.`;
        break;
      }

      case 'goal':
      default: {
        // Goal intent: use pre-ranked results if available, otherwise knowledge-base mode
        if (hasPreRankedResults) {
          effectiveMessage = `[GOAL_COMPREHENSIVE_MODE] USER GOAL: "${originalIntentLabel}". The user asked: "${messageText}". The search engine identified ${topProducts.length} relevant peptide(s) and ${topProtocols.length} relevant protocol(s) listed in PRE-RANKED COMPOUNDS and PRE-RANKED PROTOCOLS above. CRITICAL: Frame ALL sections around the user's stated goal "${originalIntentLabel}" — do NOT re-label it as a different goal. Structure your response as follows:

## 💊 Peptides for ${originalIntentLabel}
List each peptide with [PRODUCT:slug] tag and a 1-2 sentence research summary specifically related to "${originalIntentLabel}".

## 📋 Recommended Protocols
List each protocol with [PROTOCOL:slug] tag and a 1-sentence description of its relevance to "${originalIntentLabel}".

## 🌿 Complementary Supplements
List 2-4 well-studied non-peptide supplements that specifically support "${originalIntentLabel}" (e.g. biotin, saw palmetto, zinc for hair loss).

## 🔬 Research Insights
A brief synthesis of the current evidence base for "${originalIntentLabel}" and what to consider.

Do NOT say you have no information. Do NOT rename or reframe the user's goal. Tag every peptide with [PRODUCT:slug] and every protocol with [PROTOCOL:slug]. Original user message: "${messageText}"`;
        } else if (hasKnownIntent) {
          effectiveMessage = `[GOAL_COMPREHENSIVE_KNOWLEDGE_MODE] USER GOAL: "${originalIntentLabel}". The user asked: "${messageText}". CRITICAL: Respond entirely in the context of "${originalIntentLabel}" — do NOT pivot to a different theme. Structure:

## 💊 Key Peptides for ${originalIntentLabel}
List the most studied peptides for "${originalIntentLabel}" with [PRODUCT:slug] tags where known.

## 📋 Recommended Research Protocols
List relevant protocols for "${originalIntentLabel}" with [PROTOCOL:slug] tags where known.

## 🌿 Complementary Supplements
List 2-4 well-studied non-peptide supplements specifically for "${originalIntentLabel}" with a brief explanation.

## 🔬 Research Insights
Brief synthesis of the evidence and key considerations for "${originalIntentLabel}".

Do NOT say you have no information. Do NOT reframe the goal as something else. Provide specific, actionable guidance for "${messageText}".`;
        } else {
          effectiveMessage = messageText;
        }
        break;
      }
    }

    // ── Phase 5 — Goal clarifying question ────────────────────────────────────
    // When the user expresses a health goal on their FIRST message (Layer 1),
    // instead of immediately dumping all compounds, ask ONE clarifying question
    // to narrow the research direction. Beginner mode overrides this if both fire.
    if (detectedIntent === 'goal' && responseLayer === 1 && !isBeginnerMode) {
      effectiveMessage = `[GOAL_CLARIFY_MODE] The user has expressed a health goal but this appears to be their first or early interaction. Do NOT immediately list all compounds and protocols.

Instead, structure your response as:
1. Acknowledge the goal warmly (1 sentence).
2. Ask ONE clarifying question to narrow the focus. Examples:
   - "Are you primarily looking for [Option A] or [Option B]?"
   - "Is this for general research, or do you have a specific context in mind?"
3. Preview 2 (not all) of the most relevant compounds to spark interest. Use [PRODUCT:slug] tags.
4. End with: "Let me know more and I'll tailor a full research overview for you."

User's stated goal: "${originalIntentLabel || messageText}"

${effectiveMessage}`;
    }

    // ── Phase 3 — Beginner mode override ──────────────────────────────────────
    // When beginner signals are detected, prepend a [BEGINNER_MODE] directive
    // that tells the AI to simplify its response and ask ONE clarifying question
    // instead of launching into a full compound/protocol dump.
    if (isBeginnerMode) {
      effectiveMessage = `[BEGINNER_MODE] The user appears to be new to peptide research. Do NOT dump a long list of compounds or protocols. Instead:
1. Open with "Great place to start!" or a similarly welcoming phrase.
2. Give a brief 2-sentence overview of the topic they asked about: "${messageText}".
3. Ask ONE simple clarifying question: "What's your primary research goal — [option A], [option B], or something else?"
4. Mention at most 2 relevant compounds to preview options.
Keep the tone accessible and friendly. Avoid jargon. No dosages yet.

${effectiveMessage}`;
    }

    // ── Phase 4 — Layer injection ──────────────────────────────────────────────
    // Append [LAYER:N] to the effective message so the system prompt can calibrate
    // response depth. Layer 1 = overview/intro, Layer 4 = advanced/mechanistic.
    effectiveMessage = `${effectiveMessage}\n\n[LAYER:${responseLayer}] Respond at depth level ${responseLayer}/4. ${
      responseLayer === 1 ? 'Give a concise overview. No dosages. No stacking. Invite follow-up.' :
      responseLayer === 2 ? 'Include key mechanisms and 1-2 protocols. Keep it focused.' :
      responseLayer === 3 ? 'Provide detailed analysis. Protocols, dosages, comparisons welcome.' :
      'Provide maximum scientific depth. Mechanisms, pharmacokinetics, receptor data welcome.'
    }`;

    try {

      const bodyStr = JSON.stringify({
          message: effectiveMessage,
          sessionId,
          query_type: detectedQueryType,
          intent: detectedIntent, // Phase 1 — canonical 9-type intent classification
          layer: responseLayer,   // Phase 4 — progressive depth layer (1–4)
          userLocale: (typeof navigator !== 'undefined' && navigator.language) ? navigator.language : 'en',
          context: {
            available_compounds: products.slice(0, 25).map(p => ({ name: p.name, displayName: p.displayName, slug: p.slug, id: p.id })).filter(p => p.name || p.displayName),
            current_page: location.pathname,
            page_params: location.search,
            research_mode: true,
            query_type: detectedQueryType,
            // Always send the extracted compound name so the backend can look it up
            // in Firestore — even when detectedCompound is null (compound not in local cache).
            compound_name: isCompoundQuery
              ? (detectedCompound?.displayName || detectedCompound?.name || compoundPatternMatch || undefined)
              : undefined,
            // Rules 10 — Phase 1: structured page context
            page_context: ((() => {
              const p = location.pathname;
              if (p.match(/^\/product\//)) return { pageType: 'peptide', slug: p.split('/').pop() };
              if (p.match(/^\/protocol\//)) return { pageType: 'protocol', slug: p.split('/').pop() };
              if (p.match(/^\/(category|collection)\//)) return { pageType: p.includes('category') ? 'category' : 'collection', name: p.split('/').pop()?.replace(/-/g, ' ') };
              if (p.startsWith('/protocol-finder') || p.startsWith('/protocols')) return { pageType: 'protocol-finder' };
              if (p.startsWith('/search')) return { pageType: 'search-results', query: location.search };
              if (p === '/' || p === '') return { pageType: 'homepage' };
              return { pageType: 'other', path: p };
            })()),
            // Rules 10 — Phase 4: journey stage derived from session activity
            journey_stage: ((() => {
              const act = activityRef.current;
              const msgCount = act.messagesSent || 0;
              const compCount = act.comparisonCount || 0;
              const intents = sessionIntents.length;
              if (msgCount === 0) return 'curious_beginner';
              if (msgCount <= 2 && intents <= 1) return 'exploring_options';
              if (compCount >= 2) return 'comparing_compounds';
              if (msgCount >= 4 && intents >= 2 && compCount < 2) return 'narrowing_protocols';
              if (msgCount >= 7) return 'advanced_exploration';
              return 'exploring_options';
            })()),
            session_explored_compounds: exploredCompoundsRef.current.slice(-5),
            instructions: `LANGUAGE DIRECTIVE: The user's browser language is "${(typeof navigator !== 'undefined' && navigator.language) ? navigator.language : 'en'}". Always respond in that language unless the user explicitly writes in a different language.
${compoundDataBlock}



## DYNAMIC SESSION CONTEXT

- Catalog: ${products.length} peptides, ${protocols.length} protocols.
- Query type: ${
  isCompoundQuery
    ? 'PEPTIDE_QUERY — ⚠️ PEPTIDE EDUCATION MODE ACTIVE. Respond ONLY with peptide information following the mandatory peptide_query format. DO NOT pivot to protocols, goals, or recommendations.'
    : isQueryAQuestion
      ? 'QUESTION — educational/explanatory format.'
      : 'GOAL/SEARCH — match peptides and protocols.'
}
${sessionIntentContext}
${rankedCompoundsBlock}
${rankedProtocolsBlock}

INSTRUCTION: ${isCompoundQuery
  ? '⚠️ PEPTIDE MODE: Use the peptide data injected above (===== COMPOUND DATA =====). DO NOT lead with protocols. DO NOT recommend a protocol as the first section. Follow the peptide_query mandatory format exactly. After your summary, always offer: "Would you like more detail?", "See similar peptides", or "Show protocols using this peptide".'
  : hasPreRankedResults
    ? `⚠️ GOAL_COMPREHENSIVE_MODE ACTIVE: USER GOAL = "${originalIntentLabel}". The PRE-RANKED COMPOUNDS and PRE-RANKED PROTOCOLS above were retrieved by the hybrid search engine. You MUST present ALL results immediately — frame EVERY section around the user's stated goal "${originalIntentLabel}". Do NOT re-label or rename the goal (e.g. do NOT call a "hair loss" query "anti-aging"). Show: (1) Peptides with [PRODUCT:slug] tags, (2) Protocols with [PROTOCOL:slug] tags, (3) Complementary supplements specific to "${originalIntentLabel}", (4) Brief research insights. NEVER say you have no results when the pre-ranked lists are non-empty.`
    : hasKnownIntent
      ? `⚠️ GOAL_COMPREHENSIVE_KNOWLEDGE_MODE ACTIVE: USER GOAL = "${originalIntentLabel}". The user's query maps to the known research theme "${matchedGoalTheme?.theme}". Provide a comprehensive response covering: (1) Key peptides with [PRODUCT:slug] tags, (2) Relevant protocols with [PROTOCOL:slug] tags, (3) Complementary supplements ALL specific to "${originalIntentLabel}", (4) Research insights. Do NOT rename the goal. Do NOT ask the user to choose — show all categories immediately.`
      : 'No strong pre-ranked matches found. Use your knowledge to answer this goal query comprehensively: list peptides with [PRODUCT:slug] tags, protocols with [PROTOCOL:slug] tags, complementary supplements, and key research insights.'}

## USER CONTEXT
${userContextBlock}

${buildProfessionalContextBlock(userCtx?.isProfessional || false)}

${buildClinicalAITrainingBlock()}${clinicalConfig ? `\n\n---\n\n## LIVE RULES FROM FIRESTORE\n${clinicalConfig.slice(0, 1500)}` : ''}`,
          },
          ...(user ? { userId: user.uid } : {}),
          history: messages
            .slice(-10)
            .filter(m => m.content && m.content.trim().length > 0)
            .slice(-5)
            .map(m => ({ role: m.role, content: m.content.trim() }))
      });

      // ── Payload Guard — warn in dev if body exceeds 100 KB ────────────
      if (process.env.NODE_ENV !== 'production') {
        const payloadKB = (new TextEncoder().encode(bodyStr).length / 1024).toFixed(1);
        console.info(`[ClinicalAI] Payload size: ${payloadKB} KB`);
        if (Number(payloadKB) > 100) {
          console.warn(`[ClinicalAI] ⚠️ Payload is ${payloadKB} KB — approaching Cloud Run body limit.`);
        }
      }

      const response = await fetch(API_ENDPOINT, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: bodyStr,
      });

      if (!response.ok) {
        const errBody = await response.json().catch(() => ({}));
        throw new Error(errBody?.error || errBody?.message || `API error ${response.status}`);
      }
      const data = await response.json();
      const fullReply = (data.reply || '').trim();

      // Phase 1a — accumulate explored compound names from [PRODUCT:slug] tags
      const productTagMatches = [...fullReply.matchAll(/\[PRODUCT:(.*?)\]/g)];
      productTagMatches.forEach(match => {
        const slug = match[1];
        const product = products.find(p => (p.slug || p.id) === slug);
        const name = product ? (product.displayName || product.name) : slug;
        if (name && !exploredCompoundsRef.current.includes(name)) {
          exploredCompoundsRef.current = [...exploredCompoundsRef.current, name].slice(-5);
        }
      });

      // Cache the result for future identical queries
      const contextualSuggestions = (data.suggestions && data.suggestions.length > 0)
        ? data.suggestions
        : generateFollowUps(fullReply, messageText, protocols, products, detectedIntent, responseLayer);
      queryCacheRef.current.set(cacheKey, { reply: fullReply, suggestions: contextualSuggestions });

      // ── Phase 1 — Proactive Product Cards ──────────────────────────────────
      // Run search engine on the user's message AFTER receiving the LLM reply.
      // Attach up to 3 confident matches so they appear below every AI answer.
      const proactiveCards = searchProducts(messageText, products, protocolIndex)
        .filter(p => (p.searchScore ?? p.score ?? 0) > 4)
        .slice(0, 3);

      // ── Phase 2 — Semantic Fallback Strip ──────────────────────────────────
      // If no confident match, expand query via synonym map and retry.
      const QUERY_SYNONYMS = {
        'anti aging':  'longevity epithalon nad ghk-cu',
        'anti-aging':  'longevity epithalon nad ghk-cu',
        'fat loss':    'weight loss semaglutide aod metabolic',
        'brain fog':   'cognitive focus semax selank',
        'gut health':  'bpc-157 leaky gut gastro',
        'energy':      'nad mots-c mitochondrial',
        'sleep':       'dsip cjc sleep',
        'muscle':      'ipamorelin cjc ghrp sermorelin',
        'injury':      'bpc-157 tb-500 tissue repair',
        'immune':      'thymosin ta-1 ll-37',
        'skin':        'ghk-cu collagen palmitoyl',
      };
      const expandQuery = (q) => {
        const lower = q.toLowerCase().trim();
        return QUERY_SYNONYMS[lower] || lower;
      };
      let fallbackCards = [];
      let fallbackLabel = '';
      if (proactiveCards.length === 0) {
        const expandedQuery = expandQuery(messageText);
        if (expandedQuery !== messageText.toLowerCase().trim()) {
          fallbackCards = searchProducts(expandedQuery, products, protocolIndex).slice(0, 3);
          if (fallbackCards.length > 0) {
            fallbackLabel = `Related to "${messageText}"`;
          }
        }
      }
      // Limit cache size to 50 entries
      if (queryCacheRef.current.size > 50) {
        const firstKey = queryCacheRef.current.keys().next().value;
        queryCacheRef.current.delete(firstKey);
      }

      // Insert or update the assistant message:
      // If we already pushed a pre-ranked placeholder, update it in-place.
      // Otherwise push a fresh message (compound queries, questions, etc.).
      setMessages(prev => {
        const last = prev[prev.length - 1];
        if (last && last.role === 'assistant' && last._isPreRankedPlaceholder) {
          const updated = [...prev];
          updated[updated.length - 1] = {
            ...last,
            content: '',
            fullContent: fullReply,
            proactiveCards,
            fallbackCards,
            fallbackLabel,
            _isPreRankedPlaceholder: false
          };
          return updated;
        }
        return [...prev, {
          role: 'assistant',
          content: '',
          fullContent: fullReply,
          proactiveCards,
          fallbackCards,
          fallbackLabel,
          timestamp: new Date()
        }];
      });

      setIsLoading(false);
      setIsTyping(true);

      let i = 0;
      if (typingIntervalRef.current) clearInterval(typingIntervalRef.current);
      typingIntervalRef.current = setInterval(() => {
        i++;
        setMessages(prev => {
          const updated = [...prev];
          const last = updated[updated.length - 1];
          if (last && last.role === 'assistant' && last.fullContent) {
            updated[updated.length - 1] = {
              ...last,
              content: last.fullContent.slice(0, i)
            };
          }
          return updated;
        });
        if (i >= fullReply.length) {
          clearInterval(typingIntervalRef.current);
          typingIntervalRef.current = null;
          setIsTyping(false);
          setSuggestions(contextualSuggestions);
          setHasNewActivity(true);
        }
      }, 14);

      return; // Skip the finally isLoading(false) — already called above
    } catch (err) {
      console.error('[ClinicalAssistant] API error:', err.message);
      const isContextError = err.message?.toLowerCase().includes('model output') || err.message?.toLowerCase().includes('empty');
      setMessages(prev => [...prev, {
        role: 'assistant',
        content: isContextError
          ? "My response was too complex to process. Please try rephrasing your question or breaking it into a shorter query."
          : "I'm currently recalibrating my neural links. Please try again in a moment or contact our technical department.",
        timestamp: new Date(),
        isError: true
      }]);
    } finally {
      setIsLoading(false);
    }
  };

  const ReconCalculator = ({ initialMg }) => {
    const [mg, setMg] = useState(initialMg || 5);
    const [ml, setMl] = useState(2);
    const [mcg, setMcg] = useState(250);

    const units = useMemo(() => {
      const m = parseFloat(mg);
      const l = parseFloat(ml);
      const d = parseFloat(mcg);
      if (!m || !l || !d || isNaN(m) || isNaN(l) || isNaN(d)) return '—';
      return ((d / (m * 1000)) * l * 100).toFixed(1);
    }, [mg, ml, mcg]);

    return (
      <div style={{
        marginTop: '1rem',
        padding: '1rem',
        background: '#f1f5f9',
        borderRadius: '16px',
        border: '1px solid #e2e8f0',
        display: 'flex',
        flexDirection: 'column',
        gap: '0.75rem'
      }}>
        <div style={{ display: 'flex', alignItems: 'center', gap: '0.5rem', marginBottom: '0.25rem' }}>
          <FlaskConical size={14} color="var(--primary)" />
          <span style={{ fontSize: '0.75rem', fontWeight: 800, color: 'var(--primary)', textTransform: 'uppercase' }}>Reconstitution Tool</span>
        </div>
        
        <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '0.5rem' }}>
          <div style={{ display: 'flex', flexDirection: 'column', gap: '0.25rem' }}>
            <label style={{ fontSize: '0.65rem', fontWeight: 700, color: '#64748b' }}>Vial Size (mg)</label>
            <input 
              type="number" 
              value={mg} 
              onChange={e => setMg(e.target.value)}
              style={{ padding: '0.4rem', borderRadius: '8px', border: '1px solid #cbd5e1', fontSize: '0.8rem' }}
            />
          </div>
          <div style={{ display: 'flex', flexDirection: 'column', gap: '0.25rem' }}>
            <label style={{ fontSize: '0.65rem', fontWeight: 700, color: '#64748b' }}>Water (ml)</label>
            <input 
              type="number" 
              value={ml} 
              onChange={e => setMl(e.target.value)}
              style={{ padding: '0.4rem', borderRadius: '8px', border: '1px solid #cbd5e1', fontSize: '0.8rem' }}
            />
          </div>
        </div>

        <div style={{ display: 'flex', flexDirection: 'column', gap: '0.25rem' }}>
          <label style={{ fontSize: '0.65rem', fontWeight: 700, color: '#64748b' }}>Desired Dose (mcg)</label>
          <input 
            type="number" 
            value={mcg} 
            onChange={e => setMcg(e.target.value)}
            style={{ padding: '0.4rem', borderRadius: '8px', border: '1px solid #cbd5e1', fontSize: '0.8rem' }}
          />
        </div>

        <div style={{ 
          marginTop: '0.5rem',
          padding: '0.75rem',
          background: 'var(--primary)',
          borderRadius: '12px',
          color: 'white',
          textAlign: 'center'
        }}>
          <div style={{ fontSize: '0.65rem', fontWeight: 700, opacity: 0.8, textTransform: 'uppercase' }}>Units to Inject (U-100)</div>
          <div style={{ fontSize: '1.25rem', fontWeight: 900 }}>{units} <span style={{ fontSize: '0.8rem', opacity: 0.8 }}>UNITS</span></div>
        </div>
      </div>
    );
  };

  return (
    <>
      {/* Floating Button — Premium Pill */}
      <style>{`
        @keyframes ca-pulse-ring {
          0% { transform: scale(1); opacity: 0.6; }
          100% { transform: scale(1.7); opacity: 0; }
        }
        @keyframes ca-glow-breathe {
          0%, 100% { box-shadow: 0 8px 32px rgba(0,75,135,0.45), 0 0 0 0 rgba(0,120,215,0.3); }
          50% { box-shadow: 0 16px 48px rgba(0,75,135,0.65), 0 0 0 12px rgba(0,120,215,0); }
        }
        @keyframes ca-icon-bounce {
          0%, 100% { transform: translateY(0); }
          50% { transform: translateY(-3px); }
        }
        @keyframes ca-shine-pill {
          0% { transform: translateX(-100%) skewX(-20deg); }
          100% { transform: translateX(300%) skewX(-20deg); }
        }
        @keyframes ca-dot-ping {
          0% { transform: scale(1); opacity: 1; }
          75%, 100% { transform: scale(2.2); opacity: 0; }
        }
        .ca-fab-btn {
          animation: ca-glow-breathe 3s ease-in-out infinite;
          transition: width 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), border-radius 0.4s ease !important;
        }
        .ca-fab-btn:hover .ca-fab-icon {
          animation: ca-icon-bounce 0.6s ease-in-out infinite;
        }
        .ca-fab-btn:hover {
          animation: none !important;
          box-shadow: 0 20px 60px rgba(0,75,135,0.6), 0 0 0 8px rgba(0,120,215,0.15) !important;
        }
        /* ── Mobile: lift agent above the sticky purchase bar ── */
        @media (max-width: 768px) {
          .ca-fab-mobile-lift {
            bottom: 145px !important;
            min-width: 52px !important;
            width: 52px !important;
            height: 52px !important;
            border-radius: 50% !important;
            padding-left: 0 !important;
            padding-right: 0 !important;
            justify-content: center !important;
          }
          .ca-pulse-mobile-lift {
            bottom: 145px !important;
          }
          .ca-chat-mobile {
            bottom: 215px !important;
            left: 1rem !important;
            right: 1rem !important;
            width: auto !important;
            max-width: none !important;
            height: calc(100vh - 230px) !important;
            max-height: calc(100vh - 230px) !important;
            border-radius: 20px !important;
          }
          .ca-support-mobile {
            bottom: 220px !important;
            left: 1rem !important;
            width: calc(100vw - 2rem) !important;
          }
          .ca-fab-text-hide {
            display: none !important;
          }
          /* ── Product page: hide FAB when inline ClinicalAI CTA is present ── */
          .ca-fab-hidden-on-product {
            display: none !important;
          }
          /* Hide Download utility button on mobile — only Clear + X remain */
          .ca-header-download-btn {
            display: none !important;
          }
        }
      `}</style>

      {/* Pulse rings behind button — hidden on product detail pages */}
      {!isOpen && !isProductPage && (
        <div
          className="ca-pulse-mobile-lift"
          style={{
            position: 'fixed',
            bottom: '2rem',
            left: '2rem',
            width: '64px',
            height: '64px',
            borderRadius: '50%',
            zIndex: 9997,
            pointerEvents: 'none',
          }}
        >
          <div style={{
            position: 'absolute',
            inset: 0,
            borderRadius: '50%',
            border: '2px solid rgba(0,120,215,0.4)',
            animation: 'ca-pulse-ring 2.5s cubic-bezier(0.215,0.61,0.355,1) infinite',
          }} />
          <div style={{
            position: 'absolute',
            inset: 0,
            borderRadius: '50%',
            border: '2px solid rgba(0,120,215,0.25)',
            animation: 'ca-pulse-ring 2.5s cubic-bezier(0.215,0.61,0.355,1) 0.6s infinite',
          }} />
        </div>
      )}

      {/* FAB is fully omitted from DOM on product detail pages — inline CTA handles it there */}
      {!isProductPage && <motion.button
        initial={{ scale: 0, opacity: 0, y: 20 }}
        animate={{ scale: 1, opacity: 1, y: 0 }}
        transition={{ type: 'spring', stiffness: 300, damping: 20, delay: 0.5 }}
        whileHover={{ scale: 1.04 }}
        whileTap={{ scale: 0.96 }}
        onClick={() => setIsOpen(!isOpen)}
        className="ca-fab-btn ca-fab-mobile-lift"
        style={{
          position: 'fixed',
          bottom: '2rem',
          left: '2rem',
          height: '56px',
          width: isOpen ? '56px' : 'auto',
          minWidth: isOpen ? '56px' : '180px',
          borderRadius: isOpen ? '50%' : '28px',
          background: isOpen
            ? 'linear-gradient(135deg, #1e3a5f 0%, #0d2137 100%)'
            : 'linear-gradient(135deg, #0078d7 0%, var(--primary, #004b87) 55%, #002f5c 100%)',
          color: 'white',
          display: 'flex',
          alignItems: 'center',
          justifyContent: isOpen ? 'center' : 'flex-start',
          gap: '0.6rem',
          paddingLeft: isOpen ? 0 : '1rem',
          paddingRight: isOpen ? 0 : '1.25rem',
          border: '1px solid rgba(255,255,255,0.18)',
          cursor: 'pointer',
          zIndex: 9999,
          overflow: 'hidden',
          flexShrink: 0,
          whiteSpace: 'nowrap',
        }}
      >
        {/* Shine sweep */}
        {!isOpen && (
          <div style={{
            position: 'absolute',
            top: 0,
            left: 0,
            width: '40%',
            height: '100%',
            background: 'linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent)',
            animation: 'ca-shine-pill 3.5s ease-in-out 2s infinite',
            pointerEvents: 'none',
          }} />
        )}

        {/* Icon */}
        <div className="ca-fab-icon" style={{
          display: 'flex',
          alignItems: 'center',
          justifyContent: 'center',
          width: '32px',
          height: '32px',
          borderRadius: '50%',
          backgroundColor: isOpen ? 'transparent' : 'rgba(255,255,255,0.15)',
          backdropFilter: 'blur(4px)',
          flexShrink: 0,
        }}>
          <AnimatePresence mode='wait'>
            {isOpen
              ? <motion.div key="close" initial={{ rotate: -90, opacity: 0 }} animate={{ rotate: 0, opacity: 1 }} exit={{ rotate: 90, opacity: 0 }} transition={{ duration: 0.2 }}><X size={20} /></motion.div>
              : <motion.div key="open" initial={{ rotate: 90, opacity: 0 }} animate={{ rotate: 0, opacity: 1 }} exit={{ rotate: -90, opacity: 0 }} transition={{ duration: 0.2 }}><Sparkles size={18} /></motion.div>
            }
          </AnimatePresence>
        </div>

        {/* Label (only when closed) */}
        <AnimatePresence>
          {!isOpen && (
            <motion.div
              className="ca-fab-text-hide"
              initial={{ opacity: 0, width: 0 }}
              animate={{ opacity: 1, width: 'auto' }}
              exit={{ opacity: 0, width: 0 }}
              transition={{ duration: 0.3 }}
              style={{ overflow: 'hidden', display: 'flex', flexDirection: 'column', alignItems: 'flex-start' }}
            >
              <span style={{ fontSize: '0.82rem', fontWeight: 800, letterSpacing: '0.01em', lineHeight: 1.2, whiteSpace: 'nowrap' }}>
                Ask Med-Peptides AI
              </span>
              <span style={{ fontSize: '0.62rem', opacity: 0.7, fontWeight: 600, letterSpacing: '0.04em', textTransform: 'uppercase', whiteSpace: 'nowrap' }}>
                Neural Link Active
              </span>
            </motion.div>
          )}
        </AnimatePresence>

        {/* Activity dot */}
        {!isOpen && hasNewActivity && (
          <div style={{ position: 'absolute', top: '10px', right: '10px', width: '10px', height: '10px', zIndex: 10 }}>
            <div style={{
              position: 'absolute', inset: 0, borderRadius: '50%',
              backgroundColor: '#ff4757',
              animation: 'ca-dot-ping 1.5s cubic-bezier(0,0,0.2,1) infinite'
            }} />
            <div style={{
              position: 'absolute', inset: 0, borderRadius: '50%',
              backgroundColor: '#ff4757',
              border: '1.5px solid white'
            }} />
          </div>
        )}
      </motion.button>}

      {/* Chat Window */}
      
      {/* Chat Window Implementation */}
      {(() => {
        const renderChatContent = () => (
          <div style={{ display: 'flex', flexDirection: 'column', height: '100%', overflow: 'hidden' }}>
            {/* Header */}
            <div style={{
              padding: '1.5rem',
              background: 'linear-gradient(135deg, var(--primary) 0%, #004b87 100%)',
              color: 'white',
              display: 'flex',
              alignItems: 'center',
              gap: '1rem'
            }}>
              <div style={{
                width: '44px',
                height: '44px',
                borderRadius: '14px',
                backgroundColor: 'rgba(255,255,255,0.15)',
                display: 'flex',
                alignItems: 'center',
                justifyContent: 'center',
                backdropFilter: 'blur(4px)'
              }}>
                <Sparkles size={22} className="text-blue-200" />
              </div>
              <div>
                <h3 style={{ margin: 0, fontSize: '1rem', fontWeight: 900, letterSpacing: '-0.02em' }}>Med-Peptides Clinical AI</h3>
                <div style={{ display: 'flex', alignItems: 'center', gap: '0.4rem', marginTop: '0.1rem' }}>
                  <div style={{ width: '6px', height: '6px', borderRadius: '50%', backgroundColor: '#4ade80', animation: 'pulse 2s infinite' }} />
                  <span style={{ fontSize: '0.7rem', opacity: 0.8, fontWeight: 700, textTransform: 'uppercase', letterSpacing: '0.05em' }}>Neural Link Active</span>
                </div>
              </div>
              {/* Header right actions */}
              <div style={{ marginLeft: 'auto', display: 'flex', alignItems: 'center', gap: '0.5rem' }}>
                {/* Utility buttons — hidden on mobile to avoid clutter */}
                {messages.length > 1 && (
                  <>
                    <button
                      onClick={exportSession}
                      title="Export session as .txt"
                      className="ca-header-download-btn"
                      style={{
                        width: '34px', height: '34px', borderRadius: '10px',
                        border: 'none', cursor: 'pointer',
                        backgroundColor: 'rgba(255,255,255,0.12)',
                        color: 'white', display: 'flex',
                        alignItems: 'center', justifyContent: 'center',
                        transition: 'background 0.2s'
                      }}
                      onMouseEnter={e => e.currentTarget.style.backgroundColor = 'rgba(255,255,255,0.22)'}
                      onMouseLeave={e => e.currentTarget.style.backgroundColor = 'rgba(255,255,255,0.12)'}
                    >
                      <Download size={15} color="white" strokeWidth={2} />
                    </button>
                    {/* Clear button — visible on all screen sizes */}
                    <button
                      onClick={clearSession}
                      title="Clear conversation"
                      style={{
                        height: '34px',
                        paddingLeft: '10px',
                        paddingRight: '10px',
                        borderRadius: '10px',
                        border: '1px solid rgba(255,255,255,0.25)',
                        cursor: 'pointer',
                        backgroundColor: 'rgba(255,255,255,0.12)',
                        color: 'white',
                        display: 'flex',
                        alignItems: 'center',
                        justifyContent: 'center',
                        gap: '5px',
                        transition: 'background 0.2s',
                        flexShrink: 0,
                      }}
                      onMouseEnter={e => e.currentTarget.style.backgroundColor = 'rgba(255,80,80,0.35)'}
                      onMouseLeave={e => e.currentTarget.style.backgroundColor = 'rgba(255,255,255,0.12)'}
                    >
                      <Trash2 size={14} color="white" strokeWidth={2.5} />
                      <span style={{ fontSize: '0.68rem', fontWeight: 700, letterSpacing: '0.03em', whiteSpace: 'nowrap' }}>Clear</span>
                    </button>
                  </>
                )}
                {/* Close button — always visible, prominent X */}
                <button
                  onClick={() => setIsOpen(false)}
                  title="Close"
                  style={{
                    width: '42px',
                    height: '42px',
                    borderRadius: '12px',
                    border: '2.5px solid rgba(255,255,255,0.6)',
                    cursor: 'pointer',
                    backgroundColor: 'rgba(255,255,255,0.22)',
                    display: 'flex',
                    alignItems: 'center',
                    justifyContent: 'center',
                    transition: 'background 0.2s, border-color 0.2s',
                    flexShrink: 0,
                    lineHeight: 1,
                  }}
                  onMouseEnter={e => {
                    e.currentTarget.style.backgroundColor = 'rgba(255,255,255,0.38)';
                    e.currentTarget.style.borderColor = 'rgba(255,255,255,0.9)';
                  }}
                  onMouseLeave={e => {
                    e.currentTarget.style.backgroundColor = 'rgba(255,255,255,0.22)';
                    e.currentTarget.style.borderColor = 'rgba(255,255,255,0.6)';
                  }}
                >
                  {/* Inline SVG × — always renders, never hidden by CSS resets */}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="white"
                    strokeWidth="2.8"
                    strokeLinecap="round"
                    strokeLinejoin="round"
                    style={{ display: 'block', flexShrink: 0 }}
                  >
                    <line x1="18" y1="6" x2="6" y2="18" />
                    <line x1="6" y1="6" x2="18" y2="18" />
                  </svg>
                </button>
              </div>
            </div>

            {/* Messages */}
            <div style={{ flex: 1, position: 'relative', overflow: 'hidden', display: 'flex', flexDirection: 'column' }}>

              {/* ── Scroll-to-bottom FAB ── */}
              <AnimatePresence>
                {showScrollBtn && (
                  <motion.button
                    key="scrollfab"
                    initial={{ opacity: 0, scale: 0.8, y: 8 }}
                    animate={{ opacity: 1, scale: 1, y: 0 }}
                    exit={{ opacity: 0, scale: 0.8, y: 8 }}
                    transition={{ duration: 0.18 }}
                    onClick={scrollToBottom}
                    title="Scroll to latest"
                    style={{
                      position: 'absolute',
                      bottom: '12px',
                      left: '50%',
                      transform: 'translateX(-50%)',
                      zIndex: 20,
                      display: 'flex',
                      alignItems: 'center',
                      gap: '0.4rem',
                      padding: '0.45rem 1rem',
                      borderRadius: '20px',
                      backgroundColor: 'var(--primary)',
                      color: 'white',
                      border: 'none',
                      fontSize: '0.72rem',
                      fontWeight: 700,
                      cursor: 'pointer',
                      boxShadow: '0 4px 16px rgba(0,75,135,0.35)',
                      letterSpacing: '0.02em',
                      whiteSpace: 'nowrap'
                    }}
                  >
                    <ChevronsDown size={14} />
                    Jump to latest
                  </motion.button>
                )}
              </AnimatePresence>

            <div 
              ref={scrollRef}
              onScroll={handleScrollMessages}
              style={{
                flex: 1,
                padding: '1.5rem',
                overflowY: 'auto',
                display: 'flex',
                flexDirection: 'column',
                gap: '1.25rem',
                backgroundColor: '#fcfdfe'
              }}
            >
              {/* ── Starter Prompts (only shown when conversation is at greeting state) ── */}
              {messages.length === 1 && !isLoading && (() => {
                const isOnProduct = location.pathname.match(/^\/product\/(.+)/);
                const isOnProtocol = location.pathname.match(/^\/protocol\/(.+)/);

                const basePrompts = [
                  { icon: <HelpCircle size={14} />, label: 'What compounds are available?', text: 'What research compounds are available in your catalog?' },
                  { icon: <ClipboardList size={14} />, label: 'Show weight-loss protocols', text: 'Show me peptide protocols for weight management research.' },
                  { icon: <Zap size={14} />, label: 'Reconstitution guide', text: 'How do I reconstitute a lyophilized peptide correctly?' },
                  { icon: <Beaker size={14} />, label: 'BPC-157 vs TB-500', text: 'Compare BPC-157 and TB-500 mechanisms and applications.' },
                ];

                const productPrompts = isOnProduct ? (() => {
                  const slug = isOnProduct[1];
                  const product = products.find(p => p.slug === slug || p.id === slug);
                  const name = product ? (product.displayName || product.name) : 'this compound';
                  return [
                    { icon: <FlaskConical size={14} />, label: `Mechanism of ${name}`, text: `Explain the mechanism of action of ${name}.` },
                    { icon: <Zap size={14} />, label: 'How to reconstitute', text: `How do I reconstitute ${name}? What volume of BAC water?` },
                    { icon: <ClipboardList size={14} />, label: 'Related protocols', text: `What research protocols include ${name}?` },
                  ];
                })() : [];

                const protocolPrompts = isOnProtocol ? [
                  { icon: <Beaker size={14} />, label: 'Compounds in this protocol', text: 'What compounds are used in this protocol and why?' },
                  { icon: <HelpCircle size={14} />, label: 'Dosing rationale', text: 'Explain the dosing logic for this protocol.' },
                  { icon: <ClipboardList size={14} />, label: 'Compare similar protocols', text: 'Are there similar research protocols I should be aware of?' },
                ] : [];

                const prompts = [...productPrompts, ...protocolPrompts, ...basePrompts].slice(0, 4);

                return (
                  <div style={{ marginTop: '0.5rem' }}>
                    <div style={{
                      fontSize: '0.65rem',
                      fontWeight: 700,
                      textTransform: 'uppercase',
                      letterSpacing: '0.08em',
                      color: 'var(--text-muted)',
                      marginBottom: '0.6rem'
                    }}>Quick Start</div>
                    <div style={{ display: 'flex', flexDirection: 'column', gap: '0.45rem' }}>
                      {prompts.map((p, idx) => (
                        <button
                          key={idx}
                          onClick={() => handleSend(p.text)}
                          style={{
                            display: 'flex',
                            alignItems: 'center',
                            gap: '0.6rem',
                            padding: '0.6rem 0.9rem',
                            borderRadius: '12px',
                            background: 'white',
                            border: '1.5px solid #e2e8f0',
                            color: 'var(--text-main)',
                            fontSize: '0.8rem',
                            fontWeight: 600,
                            cursor: 'pointer',
                            textAlign: 'left',
                            transition: 'all 0.18s',
                            width: '100%',
                            boxShadow: '0 1px 4px rgba(0,0,0,0.04)'
                          }}
                          onMouseOver={(e) => {
                            e.currentTarget.style.borderColor = 'var(--primary)';
                            e.currentTarget.style.background = 'rgba(0,75,135,0.04)';
                          }}
                          onMouseOut={(e) => {
                            e.currentTarget.style.borderColor = '#e2e8f0';
                            e.currentTarget.style.background = 'white';
                          }}
                        >
                          <span style={{ color: 'var(--primary)', flexShrink: 0 }}>{p.icon}</span>
                          {p.label}
                        </button>
                      ))}
                    </div>
                  </div>
                );
              })()}

              {messages.map((msg, msgIdx) => {
                if (typeof msg.content !== 'string') return null;
                const isLastAssistant = msg.role === 'assistant' && msgIdx === messages.length - 1;
                return (
                <div 
                  key={msgIdx}
                  ref={isLastAssistant ? lastAssistantMsgRef : null}
                  style={{
                    display: 'flex',
                    flexDirection: 'column',
                    alignItems: msg.role === 'user' ? 'flex-end' : 'flex-start',
                    maxWidth: '85%',
                    alignSelf: msg.role === 'user' ? 'flex-end' : 'flex-start'
                  }}
                >
                  <div style={{
                    padding: '1rem 1.35rem',
                    borderRadius: msg.role === 'user' ? '20px 20px 4px 20px' : '20px 20px 20px 4px',
                    background: msg.role === 'user'
                      ? 'linear-gradient(135deg, var(--primary) 0%, #0062b0 100%)'
                      : 'linear-gradient(145deg, #f7f9fc 0%, #eef3fa 100%)',
                    color: msg.role === 'user' ? 'white' : 'var(--text-main)',
                    fontSize: '0.92rem',
                    lineHeight: 1.6,
                    boxShadow: msg.role === 'user'
                      ? '0 6px 18px rgba(0,75,135,0.2)'
                      : '0 3px 12px rgba(0,0,0,0.05)',
                    border: msg.role === 'user' ? 'none' : '1px solid #dde8f5',
                    fontWeight: msg.role === 'user' ? 500 : 400
                  }}>
                    {(() => {
                      const rawContent = msg.content ?? '';
                      // Detect TYPE 1: message mentions a specific compound (has PRODUCT tags)
                      const isCompoundQuery = rawContent.includes('[PRODUCT:');

                      let processed = rawContent.replace(/\[RECON_TOOL:.*?\]/g, '');

                      // Replace PRODUCT tags with names inline
                      processed = processed.replace(/\[PRODUCT:(.*?)\]/g, (match, slug) => {
                        const product = products.find(p => p.slug === slug || p.id === slug);
                        return product ? (product.displayName || product.name) : slug;
                      });

                      if (isCompoundQuery) {
                        // TYPE 1 — strip PROTOCOL tags from text: they will appear in the dedicated
                        // "Included in Protocols" card below, not inline in the narrative.
                        processed = processed.replace(/\[PROTOCOL:(.*?)\]/g, '');
                        // Also clean up any orphaned "Protocols that include this compound:" lines
                        // left by the AI when the tags are stripped
                        processed = processed
                          .replace(/\*{0,2}RELATED PROTOCOLS[^*\n]*\*{0,2}\s*\n/gi, '')
                          .replace(/Protocols that include this compound:?\s*\n/gi, '');
                      } else {
                        // TYPE 2 / TYPE 3 — keep PROTOCOL tags as readable names inline
                        processed = processed.replace(/\[PROTOCOL:(.*?)\]/g, (match, slug) => {
                          const protocol = protocols.find(pr => pr.slug === slug || pr.id === slug);
                          return protocol ? (protocol.title || protocol.name || slug) : slug;
                        });
                      }

                      // Strip QUESTION tags from display (rendered separately as People Also Ask)
                      processed = processed.replace(/\[QUESTION:.*?\]/g, '');

                      // Strip FAMILY tags from display (rendered separately as Family badge)
                      processed = processed.replace(/\[FAMILY:.*?\]/g, '');

                      // Strip ROLE tags from display (rendered separately as Protocol Role badge)
                      processed = processed.replace(/\[ROLE:.*?\]/g, '');

                      // Strip RESEARCH_INTEREST tags from display (rendered separately)
                      processed = processed.replace(/\[RESEARCH_INTEREST:.*?\]/g, '');

                      // Strip STACK tags from display (rendered separately as stack blocks)
                      processed = processed.replace(/\[STACK:.*?\]/g, '');
                       // Strip MATURITY tags from display (rendered separately as badge)
                       processed = processed.replace(/\[MATURITY:.*?\]/g, '');

                       // Strip COMPARE_SUMMARY tags from display (rendered separately as VS banner)
                       processed = processed.replace(/\[COMPARE_SUMMARY:.*?\]/g, '');

                       // Strip SOURCES tags from display (rendered separately as Evidence row)
                       processed = processed.replace(/\[SOURCES:.*?\]/g, '');

                       // Strip SAFETY_LEVEL tags from display (rendered separately as Safety banner)
                       processed = processed.replace(/\[SAFETY_LEVEL:.*?\]/g, '');

                       // Strip RESEARCH_GAP tags from display (rendered separately as gap card)
                       processed = processed.replace(/\[RESEARCH_GAP:.*?\]/g, '');

                       // Strip SESSION_DIGEST token from display (rendered separately as digest card)
                       processed = processed.replace(/\[SESSION_DIGEST\]/g, '');

                       // Strip ABOUT_MEDPEPTIDES token from display (rendered separately as About card)
                       processed = processed.replace(/\[ABOUT_MEDPEPTIDES\]/g, '');

                      // Collapse any double-blank lines left by the strip
                      processed = processed.replace(/\n{3,}/g, '\n\n').trim();

                      return (
                        <div style={{ display: 'flex', flexDirection: 'column', gap: '0.65rem' }}>

                          {/* ── AI NARRATIVE (streams in first) ── */}
                          {renderAIMarkdown(processed)}

                          {/* ── HYBRID INSTANT RESULTS — Tabbed Compounds + Protocols ──── */}
                          {msg.role === 'assistant' && (msg.preRankedProducts?.length > 0 || msg.preRankedProtocols?.length > 0) && (
                            <InstantResultsTabs
                              preRankedProducts={msg.preRankedProducts || []}
                              preRankedProtocols={msg.preRankedProtocols || []}
                              navigate={navigate}
                              setIsOpen={setIsOpen}
                            />
                          )}
                        </div>
                      );
                    })()}

                     {/* Phase 15 — Session Research Digest Card */}
                    {msg.role === 'assistant' && (msg.fullContent || msg.content || '').includes('[SESSION_DIGEST]') && (
                      <div style={{
                        marginBottom: '1rem',
                        borderRadius: '18px',
                        overflow: 'hidden',
                        border: '1px solid #c7d7fc',
                        boxShadow: '0 4px 24px rgba(37,99,235,0.08)'
                      }}>
                        {/* Digest Header */}
                        <div style={{
                          background: 'linear-gradient(135deg, #1e40af 0%, #4f46e5 50%, #7c3aed 100%)',
                          padding: '0.9rem 1.1rem',
                          display: 'flex',
                          alignItems: 'center',
                          gap: '0.6rem'
                        }}>
                          <span style={{ fontSize: '1.1rem' }}>📑</span>
                          <div>
                            <div style={{ fontSize: '0.58rem', fontWeight: 800, textTransform: 'uppercase', letterSpacing: '0.1em', color: 'rgba(255,255,255,0.7)' }}>Session Summary</div>
                            <div style={{ fontSize: '0.82rem', fontWeight: 700, color: 'white' }}>Research Digest</div>
                          </div>
                          <div style={{
                            marginLeft: 'auto',
                            padding: '0.2rem 0.55rem',
                            borderRadius: '20px',
                            background: 'rgba(255,255,255,0.15)',
                            fontSize: '0.6rem',
                            fontWeight: 700,
                            color: 'white',
                            letterSpacing: '0.05em'
                          }}>
                            {new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
                          </div>
                        </div>
                        {/* Digest Body — rendered via markdown */}
                        <div style={{
                          padding: '1rem 1.1rem',
                          background: 'linear-gradient(135deg, #f0f4ff 0%, #f5f3ff 100%)'
                        }}>
                          {renderAIMarkdown(
                            (msg.fullContent || msg.content || '')
                              .replace(/\[SESSION_DIGEST\]/g, '')
                              .replace(/\[SOURCES:.*?\]/g, '')
                              .replace(/\[RESEARCH_GAP:.*?\]/g, '')
                              .replace(/\[SAFETY_LEVEL:.*?\]/g, '')
                              .replace(/\[COMPARE_SUMMARY:.*?\]/g, '')
                              .replace(/\n{3,}/g, '\n\n')
                              .trim()
                          )}
                        </div>
                      </div>
                    )}

                    {/* Phase 16 — About Med-Peptides Informational Card */}
                    {msg.role === 'assistant' && (msg.fullContent || msg.content || '').includes('[ABOUT_MEDPEPTIDES]') && (
                      <div style={{
                        marginBottom: '1rem',
                        borderRadius: '18px',
                        overflow: 'hidden',
                        border: '1px solid #bae6fd',
                        boxShadow: '0 4px 24px rgba(14,165,233,0.10)'
                      }}>
                        {/* Card Header */}
                        <div style={{
                          background: 'linear-gradient(135deg, #0369a1 0%, #0284c7 50%, #0ea5e9 100%)',
                          padding: '0.9rem 1.1rem',
                          display: 'flex',
                          alignItems: 'center',
                          gap: '0.6rem'
                        }}>
                          <span style={{ fontSize: '1.1rem' }}>🧬</span>
                          <div>
                            <div style={{ fontSize: '0.58rem', fontWeight: 800, textTransform: 'uppercase', letterSpacing: '0.1em', color: 'rgba(255,255,255,0.7)' }}>Platform Information</div>
                            <div style={{ fontSize: '0.82rem', fontWeight: 700, color: 'white' }}>About Med-Peptides</div>
                          </div>
                          <div style={{
                            marginLeft: 'auto',
                            padding: '0.2rem 0.7rem',
                            borderRadius: '20px',
                            background: 'rgba(255,255,255,0.15)',
                            fontSize: '0.6rem',
                            fontWeight: 700,
                            color: 'white',
                            letterSpacing: '0.05em'
                          }}>Research Platform</div>
                        </div>
                        {/* Card Body */}
                        <div style={{
                          padding: '1rem 1.1rem',
                          background: 'linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%)'
                        }}>
                          {renderAIMarkdown(
                            (msg.fullContent || msg.content || '')
                              .replace(/\[ABOUT_MEDPEPTIDES\]/g, '')
                              .replace(/\[SESSION_DIGEST\]/g, '')
                              .replace(/\[SOURCES:.*?\]/g, '')
                              .replace(/\[RESEARCH_GAP:.*?\]/g, '')
                              .replace(/\[SAFETY_LEVEL:.*?\]/g, '')
                              .replace(/\n{3,}/g, '\n\n')
                              .trim()
                          )}
                          {/* WhatsApp CTA */}
                          <a
                            href="https://wa.me/971564179256"
                            target="_blank"
                            rel="noopener noreferrer"
                            style={{
                              display: 'inline-flex',
                              alignItems: 'center',
                              gap: '0.5rem',
                              marginTop: '0.85rem',
                              padding: '0.5rem 1rem',
                              borderRadius: '24px',
                              background: 'linear-gradient(135deg, #16a34a 0%, #22c55e 100%)',
                              color: 'white',
                              fontWeight: 700,
                              fontSize: '0.72rem',
                              textDecoration: 'none',
                              letterSpacing: '0.02em',
                              boxShadow: '0 2px 10px rgba(34,197,94,0.25)',
                              transition: 'all 0.2s'
                            }}
                          >
                            <span style={{ fontSize: '1rem' }}>💬</span>
                            Chat with our team on WhatsApp
                          </a>
                        </div>
                      </div>
                    )}

                    {/* Phase 13 — Safety & Dosing Guardrails Banner */}
                    {msg.role === 'assistant' && (() => {
                      const raw = msg.fullContent || msg.content || '';
                      const safetyMatch = raw.match(/\[SAFETY_LEVEL:(\w[\w-]*)\]/);
                      if (!safetyMatch) return null;
                      const level = safetyMatch[1]?.toLowerCase();
                      if (level === 'standard') return null; // no banner for standard

                      const isHighRisk = level === 'high-risk';
                      const cfg = isHighRisk
                        ? {
                            bg: 'linear-gradient(135deg, #fff1f2 0%, #ffe4e6 100%)',
                            border: '#fca5a5',
                            iconBg: '#fee2e2',
                            iconColor: '#dc2626',
                            textColor: '#991b1b',
                            labelColor: '#dc2626',
                            icon: '⚠️',
                            label: 'HIGH-RISK PROTOCOL',
                            message: 'This response discusses high-dose, stacked, or complex protocols. Consult a qualified medical professional before considering any application.'
                          }
                        : {
                            bg: 'linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%)',
                            border: '#fcd34d',
                            iconBg: '#fef9c3',
                            iconColor: '#d97706',
                            textColor: '#92400e',
                            labelColor: '#b45309',
                            icon: '🔶',
                            label: 'DOSING GUIDANCE',
                            message: 'This response contains specific dosing or administration details for research context only. Always consult a licensed healthcare professional.'
                          };

                      return (
                        <div style={{
                          marginBottom: '0.75rem',
                          borderRadius: '14px',
                          background: cfg.bg,
                          border: `1px solid ${cfg.border}`,
                          padding: '0.7rem 1rem',
                          display: 'flex',
                          alignItems: 'flex-start',
                          gap: '0.65rem'
                        }}>
                          <div style={{
                            width: '32px', height: '32px', borderRadius: '50%',
                            background: cfg.iconBg,
                            display: 'flex', alignItems: 'center', justifyContent: 'center',
                            fontSize: '1rem', flexShrink: 0
                          }}>{cfg.icon}</div>
                          <div style={{ flex: 1 }}>
                            <div style={{ fontSize: '0.58rem', fontWeight: 800, textTransform: 'uppercase', letterSpacing: '0.08em', color: cfg.labelColor, marginBottom: '0.2rem' }}>{cfg.label}</div>
                            <div style={{ fontSize: '0.68rem', color: cfg.textColor, lineHeight: 1.45 }}>{cfg.message}</div>
                          </div>
                        </div>
                      );
                    })()}

                    {/* Phase 11 — Smart Comparison Banner */}
                    {msg.role === 'assistant' && (msg.fullContent || msg.content || '').includes('[COMPARE_SUMMARY:') && (() => {
                      const csMatch = (msg.fullContent || msg.content || '').match(/\[COMPARE_SUMMARY:(.*?)\]/);
                      if (!csMatch) return null;
                      const parts = csMatch[1].split('|');
                      const reason = parts[0]?.trim();
                      const compA = parts[1]?.trim();
                      const compB = parts[2]?.trim();
                      if (!reason || !compA || !compB) return null;

                      return (
                        <div style={{
                          marginBottom: '0.75rem',
                          borderRadius: '16px',
                          background: 'linear-gradient(135deg, #eff6ff 0%, #eef2ff 100%)',
                          border: '1px solid #c7d7fc',
                          padding: '0.75rem 1rem',
                          display: 'flex',
                          flexDirection: 'column',
                          gap: '0.55rem'
                        }}>
                          {/* VS Pill row */}
                          <div style={{ display: 'flex', alignItems: 'center', gap: '0.5rem', flexWrap: 'wrap' }}>
                            <button
                              onClick={() => handleSend(`Tell me about ${compA}`)}
                              style={{
                                padding: '0.3rem 0.75rem',
                                borderRadius: '20px',
                                background: 'linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%)',
                                border: 'none',
                                color: 'white',
                                fontSize: '0.72rem',
                                fontWeight: 700,
                                cursor: 'pointer',
                                transition: 'opacity 0.15s'
                              }}
                              onMouseOver={e => e.currentTarget.style.opacity = '0.82'}
                              onMouseOut={e => e.currentTarget.style.opacity = '1'}
                            >{compA}</button>
                            <div style={{
                              width: '28px', height: '28px', borderRadius: '50%',
                              background: 'white',
                              border: '1px solid #c7d7fc',
                              display: 'flex', alignItems: 'center', justifyContent: 'center',
                              fontSize: '0.62rem', fontWeight: 900, color: '#4f46e5',
                              flexShrink: 0
                            }}>VS</div>
                            <button
                              onClick={() => handleSend(`Tell me about ${compB}`)}
                              style={{
                                padding: '0.3rem 0.75rem',
                                borderRadius: '20px',
                                background: 'linear-gradient(135deg, #7c3aed 0%, #6d28d9 100%)',
                                border: 'none',
                                color: 'white',
                                fontSize: '0.72rem',
                                fontWeight: 700,
                                cursor: 'pointer',
                                transition: 'opacity 0.15s'
                              }}
                              onMouseOver={e => e.currentTarget.style.opacity = '0.82'}
                              onMouseOut={e => e.currentTarget.style.opacity = '1'}
                            >{compB}</button>
                          </div>
                          {/* Reason */}
                          <div style={{ fontSize: '0.68rem', color: '#3730a3', lineHeight: 1.4 }}>
                            <span style={{ fontWeight: 700, textTransform: 'uppercase', letterSpacing: '0.05em', fontSize: '0.58rem', marginRight: '0.35rem', opacity: 0.7 }}>Why researchers compare</span>
                            {reason}
                          </div>
                        </div>
                      );
                    })()}

                    {/* Phase 12 — Evidence Source Attribution Pills */}
                    {msg.role === 'assistant' && (msg.fullContent || msg.content || '').includes('[SOURCES:') && (() => {
                      const srcMatch = (msg.fullContent || msg.content || '').match(/\[SOURCES:(.*?)\]/);
                      if (!srcMatch) return null;
                      const types = srcMatch[1].split('|').map(s => s.trim()).filter(Boolean);
                      if (!types.length) return null;

                      const evidenceConfig = {
                        'Animal Studies':        { icon: '🐭', color: '#7c3aed', bg: '#f5f3ff', border: '#ddd6fe' },
                        'Human Case Reports':    { icon: '👤', color: '#0369a1', bg: '#f0f9ff', border: '#bae6fd' },
                        'Systematic Review':     { icon: '📊', color: '#065f46', bg: '#ecfdf5', border: '#a7f3d0' },
                        'RCT':                   { icon: '🔬', color: '#1e40af', bg: '#eff6ff', border: '#bfdbfe' },
                        'Observational Study':   { icon: '👁️', color: '#92400e', bg: '#fffbeb', border: '#fde68a' },
                        'In Vitro':              { icon: '🧪', color: '#9d174d', bg: '#fdf2f8', border: '#fbcfe8' },
                        'Expert Consensus':      { icon: '🏛️', color: '#374151', bg: '#f9fafb', border: '#e5e7eb' },
                        'Mechanistic Theory':    { icon: '⚙️', color: '#1e3a5f', bg: '#f0f4ff', border: '#c7d7fc' },
                        'Anecdotal / Community': { icon: '💬', color: '#6b7280', bg: '#f9fafb', border: '#e5e7eb' },
                        'N/A':                   { icon: '—',  color: '#9ca3af', bg: '#f9fafb', border: '#e5e7eb' },
                      };

                      return (
                        <div style={{ marginTop: '0.55rem', display: 'flex', flexDirection: 'column', gap: '0.3rem' }}>
                          <div style={{ fontSize: '0.58rem', fontWeight: 700, textTransform: 'uppercase', letterSpacing: '0.07em', color: '#94a3b8' }}>Evidence Base</div>
                          <div style={{ display: 'flex', flexWrap: 'wrap', gap: '0.35rem' }}>
                            {types.map((t, i) => {
                              const cfg = evidenceConfig[t] || { icon: '📄', color: '#374151', bg: '#f9fafb', border: '#e5e7eb' };
                              return (
                                <div key={i} style={{
                                  display: 'inline-flex',
                                  alignItems: 'center',
                                  gap: '0.28rem',
                                  padding: '0.22rem 0.58rem',
                                  borderRadius: '20px',
                                  background: cfg.bg,
                                  border: `1px solid ${cfg.border}`,
                                  fontSize: '0.65rem',
                                  fontWeight: 600,
                                  color: cfg.color,
                                  whiteSpace: 'nowrap'
                                }}>
                                  <span style={{ fontSize: '0.7rem' }}>{cfg.icon}</span>
                                  {t}
                                </div>
                              );
                            })}
                          </div>
                        </div>
                      );
                    })()}

                    {/* Phase 14 — Research Gap Callout */}
                    {msg.role === 'assistant' && (msg.fullContent || msg.content || '').includes('[RESEARCH_GAP:') && (() => {
                      const raw = msg.fullContent || msg.content || '';
                      const gapMatch = raw.match(/\[RESEARCH_GAP:(.*?)\]/);
                      if (!gapMatch) return null;
                      const gaps = gapMatch[1].split('|').map(s => s.trim()).filter(Boolean);
                      if (!gaps.length) return null;

                      // Use a local state-like pattern via data attribute trick with CSS
                      const detailsId = `gap-${msg.id || Math.random().toString(36).slice(2)}`;

                      return (
                        <details
                          id={detailsId}
                          style={{
                            marginTop: '0.5rem',
                            borderRadius: '12px',
                            background: 'linear-gradient(135deg, #fafafa 0%, #f3f4f6 100%)',
                            border: '1px dashed #d1d5db',
                            overflow: 'hidden'
                          }}
                        >
                          <summary style={{
                            padding: '0.6rem 0.9rem',
                            cursor: 'pointer',
                            fontSize: '0.65rem',
                            fontWeight: 700,
                            color: '#6b7280',
                            textTransform: 'uppercase',
                            letterSpacing: '0.07em',
                            listStyle: 'none',
                            display: 'flex',
                            alignItems: 'center',
                            gap: '0.4rem',
                            userSelect: 'none'
                          }}>
                            <span style={{ fontSize: '0.8rem' }}>🔍</span>
                            Open Research Questions ({gaps.length})
                            <span style={{ marginLeft: 'auto', fontSize: '0.7rem', opacity: 0.5 }}>▾</span>
                          </summary>
                          <div style={{ padding: '0 0.9rem 0.75rem', display: 'flex', flexDirection: 'column', gap: '0.45rem' }}>
                            {gaps.map((gap, i) => (
                              <div key={i} style={{ display: 'flex', alignItems: 'flex-start', gap: '0.5rem' }}>
                                <span style={{
                                  flexShrink: 0,
                                  width: '18px', height: '18px',
                                  borderRadius: '50%',
                                  background: '#e5e7eb',
                                  display: 'flex', alignItems: 'center', justifyContent: 'center',
                                  fontSize: '0.58rem', fontWeight: 800, color: '#9ca3af'
                                }}>{i + 1}</span>
                                <span style={{ fontSize: '0.68rem', color: '#374151', lineHeight: 1.5 }}>{gap}</span>
                              </div>
                            ))}
                          </div>
                        </details>
                      );
                    })()}

                    {/* ── HYBRID INSTANT RESULTS ─ moved to top of message bubble (see above) ── */}

                    {/* Render Product Cards if tags exist — deduplicated by base compound name */}
                     {msg.role === 'assistant' && (msg.content ?? '').includes('[PRODUCT:') && (() => {
                       const getBaseSlug = (slug) =>
                         (slug || '').replace(/[-]*(\d+(\.\d+)?[-]?(mg|mcg|iu|ml|g|kg)[-\w]*)$/i, '').replace(/-+$/, '') || slug;
                       const getBaseName = (name) =>
                         (name || '').replace(/[-\s]*(\d+(\.\d+)?\s*(mg|mcg|iu|ml|g|kg)[-\w]*)$/i, '').trim() || name;
                       const seenNames = new Set();
                       const uniqueProducts = Array.from((msg.content ?? '').matchAll(/\[PRODUCT:(.*?)\]/g))
                         .map(match => products.find(p => p.slug === match[1] || p.id === match[1]))
                         .filter(Boolean)
                         .filter(product => {
                           const baseName = getBaseName(product.displayName || product.name || '').toLowerCase();
                           if (seenNames.has(baseName)) return false;
                           seenNames.add(baseName);
                           return true;
                         });
                       if (!uniqueProducts.length) return null;
                       return (
                         <div style={{ marginTop: '1rem', display: 'flex', flexDirection: 'column', gap: '0.75rem' }}>
                           {uniqueProducts.map((product, idx) => (
                             <div
                               key={idx}
                               onClick={() => {
                                 navigate(`/product/${getBaseSlug(product.slug || product.id)}`);
                                 setIsOpen(false);
                               }}
                               style={{
                                 display: 'flex',
                                 alignItems: 'center',
                                 gap: '0.75rem',
                                 padding: '0.75rem',
                                 borderRadius: '14px',
                                 background: '#f8fafc',
                                 border: '1px solid #e2e8f0',
                                 cursor: 'pointer',
                                 transition: 'all 0.2s'
                               }}
                               onMouseOver={(e) => e.currentTarget.style.borderColor = 'var(--primary)'}
                               onMouseOut={(e) => e.currentTarget.style.borderColor = '#e2e8f0'}
                             >
                               <div style={{
                                 width: '40px',
                                 height: '40px',
                                 borderRadius: '8px',
                                 background: 'white',
                                 display: 'flex',
                                 alignItems: 'center',
                                 justifyContent: 'center',
                                 border: '1px solid #f1f5f9'
                               }}>
                                 <FlaskConical size={18} color="var(--primary)" />
                               </div>
                               <div style={{ flex: 1 }}>
                                 <div style={{ fontSize: '0.8rem', fontWeight: 700, color: 'var(--text-main)' }}>
                                   {getBaseName(product.displayName || product.name)}
                                 </div>
                                 <div style={{ fontSize: '0.65rem', color: 'var(--text-muted)' }}>{product.shortDescription || 'Research Compound'}</div>
                               </div>
                               <ChevronRight size={14} color="#94a3b8" />
                             </div>
                           ))}
                         </div>
                       );
                     })()}

                    {/* ── PHASE 2: Protocols for Peptide — collapsible premium card (TYPE 1 only) ── */}
                    {msg.role === 'assistant' && (msg.content ?? '').includes('[PRODUCT:') && (() => {
                      // Collect unique product slugs mentioned in this message
                      const productSlugs = [...new Set(
                        Array.from((msg.content ?? '').matchAll(/\[PRODUCT:(.*?)\]/g)).map(m => m[1])
                      )];

                      // Also collect any protocol slugs the AI explicitly tagged
                      const aiProtocolSlugs = [...new Set(
                        Array.from((msg.content ?? '').matchAll(/\[PROTOCOL:(.*?)\]/g)).map(m => m[1])
                      )];

                      // Gather protocols from product lookups
                      const relatedFromProducts = productSlugs.flatMap(slug =>
                        findProtocolsForProduct(slug, protocols)
                      );

                      // Gather protocols explicitly tagged by AI (resolve them)
                      const relatedFromAI = aiProtocolSlugs
                        .map(slug => protocols.find(pr => pr.slug === slug || pr.id === slug))
                        .filter(Boolean);

                      // Merge and de-duplicate
                      const allRelated = [...relatedFromAI, ...relatedFromProducts];
                      const uniqueProtocols = allRelated.filter(
                        (p, i, arr) => arr.findIndex(x => (x.slug || x.id) === (p.slug || p.id)) === i
                      );

                      if (!uniqueProtocols.length) return null;

                      const count = uniqueProtocols.length;
                      const msgKey = `proto-expand-${msgIdx}`;

                      return (
                        <ProtocolsForPeptideCard
                          key={msgKey}
                          protocols={uniqueProtocols}
                          count={count}
                          navigate={navigate}
                          setIsOpen={setIsOpen}
                          msgKey={msgKey}
                        />
                      );
                    })()}

                    {/* Phase 4 — Compound Family Badge */}
                    {msg.role === 'assistant' && (msg.fullContent || msg.content || '').includes('[FAMILY:') && (() => {
                      const familyMatch = (msg.fullContent || msg.content || '').match(/\[FAMILY:(.*?)\]/);
                      const familyName = familyMatch?.[1];
                      if (!familyName) return null;

                      // Determine sibling compounds in this family from products catalog
                      const familyKeywords = familyName.toLowerCase().split(/\s+/);
                      const siblings = products
                        .filter(p => {
                          const text = `${p.displayName || p.name || ''} ${p.category || ''} ${p.family || ''}`.toLowerCase();
                          return familyKeywords.some(kw => kw.length > 3 && text.includes(kw));
                        })
                        .slice(0, 4);

                      return (
                        <div style={{ marginTop: '0.9rem' }}>
                          <div style={{
                            display: 'inline-flex',
                            alignItems: 'center',
                            gap: '0.5rem',
                            padding: '0.35rem 0.75rem',
                            borderRadius: '20px',
                            background: 'linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%)',
                            border: '1px solid #6ee7b7',
                            marginBottom: siblings.length ? '0.55rem' : 0
                          }}>
                            <span style={{ fontSize: '0.65rem' }}>🧬</span>
                            <span style={{
                              fontSize: '0.65rem',
                              fontWeight: 800,
                              letterSpacing: '0.04em',
                              color: '#065f46'
                            }}>FAMILY</span>
                            <span style={{
                              fontSize: '0.72rem',
                              fontWeight: 700,
                              color: '#047857'
                            }}>{familyName}</span>
                          </div>
                          {siblings.length > 0 && (
                            <div style={{ display: 'flex', flexWrap: 'wrap', gap: '0.35rem' }}>
                              {siblings.map((s, si) => {
                                // Compute the canonical URL (strip dosage suffix from slug)
                                const siblingUrl = `/product/${(s.slug || s.id || '')
                                  .replace(/[-]*(\d+(\.\d+)?[-]?(mg|mcg|iu|ml|g|kg)[-\w]*)$/i, '')
                                  .replace(/-+$/, '') || s.slug || s.id}`;
                                // Display base compound name (without dosage suffix)
                                const siblingDisplayName = (s.displayName || s.name || '')
                                  .replace(/[-\s]*(\d+(\.\d+)?\s*(mg|mcg|iu|ml|g|kg)[-\w]*)$/i, '')
                                  .trim() || s.displayName || s.name;
                                return (
                                  <button
                                    key={si}
                                    onClick={() => {
                                      navigate(siblingUrl);
                                      setIsOpen(false);
                                    }}
                                    style={{
                                      padding: '0.3rem 0.65rem',
                                      borderRadius: '12px',
                                      background: 'white',
                                      border: '1px solid #a7f3d0',
                                      fontSize: '0.68rem',
                                      fontWeight: 700,
                                      color: '#065f46',
                                      cursor: 'pointer',
                                      transition: 'all 0.16s'
                                    }}
                                    onMouseOver={e => {
                                      e.currentTarget.style.background = '#ecfdf5';
                                      e.currentTarget.style.borderColor = '#10b981';
                                    }}
                                    onMouseOut={e => {
                                      e.currentTarget.style.background = 'white';
                                      e.currentTarget.style.borderColor = '#a7f3d0';
                                    }}
                                  >
                                    {siblingDisplayName}
                                  </button>
                                );
                              })}
                            </div>
                          )}
                        </div>
                      );
                    })()}

                    {/* Phase 5 — Protocol Role Badge */}
                    {msg.role === 'assistant' && (msg.fullContent || msg.content || '').includes('[ROLE:') && (() => {
                      const roleMatch = (msg.fullContent || msg.content || '').match(/\[ROLE:(.*?)\]/);
                      const roleName = roleMatch?.[1];
                      if (!roleName) return null;

                      const roleConfig = {
                        'Protocol Anchor':    { bg: 'linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%)', border: '#fcd34d', text: '#92400e', icon: '⚓' },
                        'Support Compound':   { bg: 'linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%)', border: '#fdba74', text: '#9a3412', icon: '🔗' },
                        'Stack Enhancer':     { bg: 'linear-gradient(135deg, #f5f3ff 0%, #ede9fe 100%)', border: '#c4b5fd', text: '#5b21b6', icon: '⚡' },
                        'Recovery Amplifier': { bg: 'linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%)', border: '#93c5fd', text: '#1e40af', icon: '🔄' },
                      };
                      const cfg = roleConfig[roleName] || { bg: '#f3f4f6', border: '#d1d5db', text: '#374151', icon: '🏷️' };

                      return (
                        <div style={{ marginTop: '0.65rem' }}>
                          <div style={{
                            display: 'inline-flex',
                            alignItems: 'center',
                            gap: '0.4rem',
                            padding: '0.3rem 0.7rem',
                            borderRadius: '20px',
                            background: cfg.bg,
                            border: `1px solid ${cfg.border}`,
                          }}>
                            <span style={{ fontSize: '0.65rem' }}>{cfg.icon}</span>
                            <span style={{
                              fontSize: '0.6rem',
                              fontWeight: 800,
                              letterSpacing: '0.06em',
                              color: cfg.text,
                              textTransform: 'uppercase'
                            }}>Protocol Role</span>
                            <span style={{
                              fontSize: '0.7rem',
                              fontWeight: 700,
                              color: cfg.text
                            }}>{roleName}</span>
                          </div>
                        </div>
                      );
                    })()}

                    {/* Phase 9 — Research Maturity Badge */}
                    {msg.role === 'assistant' && (msg.fullContent || msg.content || '').includes('[MATURITY:') && (() => {
                      const matMatch = (msg.fullContent || msg.content || '').match(/\[MATURITY:(.*?)\]/);
                      const matLevel = matMatch?.[1]?.trim();
                      if (!matLevel) return null;

                      const matConfig = {
                        'Emerging':    { bg: 'linear-gradient(135deg, #fff1f2 0%, #ffe4e6 100%)', border: '#fda4af', text: '#9f1239', dot: '#f43f5e', label: 'Research Maturity' },
                        'Moderate':    { bg: 'linear-gradient(135deg, #fffbeb 0%, #fef9c3 100%)', border: '#fde047', text: '#713f12', dot: '#eab308', label: 'Research Maturity' },
                        'Established': { bg: 'linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%)', border: '#86efac', text: '#14532d', dot: '#22c55e', label: 'Research Maturity' },
                      };
                      const cfg = matConfig[matLevel] || { bg: '#f3f4f6', border: '#d1d5db', text: '#374151', dot: '#9ca3af', label: 'Research Maturity' };

                      return (
                        <div style={{ marginTop: '0.45rem' }}>
                          <div style={{
                            display: 'inline-flex',
                            alignItems: 'center',
                            gap: '0.4rem',
                            padding: '0.28rem 0.65rem',
                            borderRadius: '20px',
                            background: cfg.bg,
                            border: `1px solid ${cfg.border}`,
                          }}>
                            <span style={{
                              width: '7px', height: '7px', borderRadius: '50%',
                              background: cfg.dot, flexShrink: 0,
                              boxShadow: `0 0 4px ${cfg.dot}99`
                            }} />
                            <span style={{
                              fontSize: '0.6rem',
                              fontWeight: 800,
                              letterSpacing: '0.06em',
                              color: cfg.text,
                              textTransform: 'uppercase'
                            }}>Research Maturity</span>
                            <span style={{
                              fontSize: '0.7rem',
                              fontWeight: 700,
                              color: cfg.text
                            }}>{matLevel}</span>
                          </div>
                        </div>
                      );
                    })()}

                    {/* Phase 6 — Why Researchers Explore This */}
                    {msg.role === 'assistant' && (msg.fullContent || msg.content || '').includes('[RESEARCH_INTEREST:') && (() => {
                      const riMatch = (msg.fullContent || msg.content || '').match(/\[RESEARCH_INTEREST:(.*?)\]/);
                      const riRaw = riMatch?.[1];
                      if (!riRaw) return null;
                      const reasons = riRaw.split('|').map(r => r.trim()).filter(Boolean).slice(0, 3);
                      if (!reasons.length) return null;

                      return (
                        <div style={{
                          marginTop: '0.85rem',
                          padding: '0.7rem 0.9rem',
                          borderRadius: '14px',
                          background: 'linear-gradient(135deg, #f0fdfa 0%, #e0f2fe 100%)',
                          border: '1px solid #99f6e4',
                        }}>
                          <div style={{
                            fontSize: '0.6rem',
                            fontWeight: 800,
                            letterSpacing: '0.07em',
                            textTransform: 'uppercase',
                            color: '#0f766e',
                            marginBottom: '0.45rem'
                          }}>🔬 Why Researchers Explore This</div>
                          <ul style={{
                            margin: 0,
                            padding: '0 0 0 1rem',
                            display: 'flex',
                            flexDirection: 'column',
                            gap: '0.22rem'
                          }}>
                            {reasons.map((r, i) => (
                              <li key={i} style={{
                                fontSize: '0.73rem',
                                color: '#134e4a',
                                fontWeight: 500,
                                lineHeight: 1.4
                              }}>{r}</li>
                            ))}
                          </ul>
                        </div>
                      );
                    })()}

                    {/* Phase 7 — Common Stack Visualization */}
                    {msg.role === 'assistant' && (msg.fullContent || msg.content || '').includes('[STACK:') && (() => {
                      const stackMatches = [...(msg.fullContent || msg.content || '').matchAll(/\[STACK:(.*?)\]/g)];
                      if (!stackMatches.length) return null;

                      const stackColors = [
                        { bg: 'linear-gradient(135deg, #fdf4ff 0%, #fae8ff 100%)', border: '#e879f9', header: '#7e22ce', chip: '#f0abfc', chipText: '#581c87' },
                        { bg: 'linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%)', border: '#fb923c', header: '#c2410c', chip: '#fed7aa', chipText: '#7c2d12' },
                        { bg: 'linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%)', border: '#4ade80', header: '#15803d', chip: '#bbf7d0', chipText: '#14532d' },
                      ];

                      return (
                        <div style={{ marginTop: '0.9rem', display: 'flex', flexDirection: 'column', gap: '0.55rem' }}>
                          <div style={{
                            fontSize: '0.6rem',
                            fontWeight: 800,
                            letterSpacing: '0.07em',
                            textTransform: 'uppercase',
                            color: '#6b7280',
                            marginBottom: '0.1rem'
                          }}>🧬 Commonly Used In</div>
                          {stackMatches.slice(0, 3).map((m, si) => {
                            const parts = m[1].split('|');
                            const name = parts[0]?.trim() || 'Research Stack';
                            const compounds = (parts[1] || '').split(',').map(c => c.trim()).filter(Boolean);
                            const col = stackColors[si % stackColors.length];
                            return (
                              <div key={si} style={{
                                padding: '0.6rem 0.75rem',
                                borderRadius: '12px',
                                background: col.bg,
                                border: `1px solid ${col.border}`,
                              }}>
                                <div style={{
                                  fontSize: '0.65rem',
                                  fontWeight: 800,
                                  color: col.header,
                                  marginBottom: '0.4rem',
                                  letterSpacing: '0.02em'
                                }}>{name}</div>
                                <div style={{ display: 'flex', flexWrap: 'wrap', gap: '0.3rem' }}>
                                  {compounds.map((c, ci) => (
                                    <button
                                      key={ci}
                                      onClick={() => handleSend(`Tell me about ${c}`)}
                                      style={{
                                        padding: '0.22rem 0.6rem',
                                        borderRadius: '10px',
                                        background: col.chip,
                                        border: 'none',
                                        fontSize: '0.68rem',
                                        fontWeight: 700,
                                        color: col.chipText,
                                        cursor: 'pointer',
                                        transition: 'opacity 0.15s'
                                      }}
                                      onMouseOver={e => e.currentTarget.style.opacity = '0.75'}
                                      onMouseOut={e => e.currentTarget.style.opacity = '1'}
                                    >{c}</button>
                                  ))}
                                </div>
                              </div>
                            );
                          })}
                        </div>
                      );
                    })()}

                    {/* ── Protocol Cards — for TYPE 2 / TYPE 3 (no PRODUCT tag) only ── */}
                    {msg.role === 'assistant'
                      && (msg.content ?? '').includes('[PROTOCOL:')
                      && !(msg.content ?? '').includes('[PRODUCT:')
                      && (
                      <div style={{ marginTop: '1rem', display: 'flex', flexDirection: 'column', gap: '0.75rem' }}>
                        {Array.from((msg.content ?? '').matchAll(/\[PROTOCOL:(.*?)\]/g)).map((match, idx) => {
                          const slug = match[1];
                          const protocol = protocols.find(pr => pr.slug === slug || pr.id === slug);
                          const title = protocol ? (protocol.title || protocol.name || slug) : slug;
                          const subtitle = protocol ? (protocol.goal || protocol.description || 'Research Protocol') : 'Research Protocol';
                          return (
                            <div
                              key={idx}
                              onClick={() => {
                                navigate(`/protocol/${slug}`);
                                setIsOpen(false);
                              }}
                              style={{
                                display: 'flex',
                                alignItems: 'center',
                                gap: '0.75rem',
                                padding: '0.75rem',
                                borderRadius: '14px',
                                background: 'linear-gradient(135deg, #f0f7ff 0%, #e8f4fd 100%)',
                                border: '1px solid #c7dff5',
                                cursor: 'pointer',
                                transition: 'all 0.2s'
                              }}
                              onMouseOver={(e) => e.currentTarget.style.borderColor = 'var(--primary)'}
                              onMouseOut={(e) => e.currentTarget.style.borderColor = '#c7dff5'}
                            >
                              <div style={{
                                width: '40px',
                                height: '40px',
                                borderRadius: '8px',
                                background: 'white',
                                display: 'flex',
                                alignItems: 'center',
                                justifyContent: 'center',
                                border: '1px solid #ddeeff',
                                flexShrink: 0
                              }}>
                                <ClipboardList size={18} color="var(--primary)" />
                              </div>
                              <div style={{ flex: 1, minWidth: 0 }}>
                                <div style={{ fontSize: '0.8rem', fontWeight: 700, color: 'var(--text-main)', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' }}>{title}</div>
                                <div style={{ fontSize: '0.65rem', color: 'var(--text-muted)', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' }}>{subtitle}</div>
                              </div>
                              <ChevronRight size={14} color="#94a3b8" style={{ flexShrink: 0 }} />
                            </div>
                          );
                        })}
                      </div>
                    )}

                    {/* ── Included Compounds (cross-nav) — only for TYPE 2/3, no PRODUCT tag ── */}
                    {msg.role === 'assistant'
                      && (msg.content ?? '').includes('[PROTOCOL:')
                      && !(msg.content ?? '').includes('[PRODUCT:')
                      && (() => {
                      const protocolSlugs = [...new Set(
                        Array.from((msg.content ?? '').matchAll(/\[PROTOCOL:(.*?)\]/g)).map(m => m[1])
                      )];
                      const allCompounds = protocolSlugs.flatMap(slug => {
                        const proto = protocols.find(p => p.slug === slug || p.id === slug);
                        return findProductsForProtocol(proto, products);
                      });
                      const unique = allCompounds.filter(
                        (c, i, arr) => arr.findIndex(x => x.slug === c.slug) === i
                      );
                      if (!unique.length) return null;
                      return (
                        <div style={{ marginTop: '1.1rem' }}>
                          <div style={{
                            fontSize: '0.65rem',
                            fontWeight: 700,
                            letterSpacing: '0.06em',
                            textTransform: 'uppercase',
                            color: 'var(--text-muted)',
                            marginBottom: '0.55rem'
                          }}>Included Compounds</div>
                          <div style={{ display: 'flex', flexDirection: 'column', gap: '0.55rem' }}>
                            {unique.map((compound, idx) => {
                              const prod = products.find(p => p.slug === compound.slug || p.id === compound.slug);
                              const displayName = prod?.displayName || prod?.name || compound.name;
                              const shortDesc = prod?.shortDescription || prod?.category || 'Research Compound';
                              return (
                                <div
                                  key={idx}
                                  onClick={() => { navigate(`/product/${compound.slug}`); setIsOpen(false); }}
                                  style={{
                                    display: 'flex',
                                    alignItems: 'center',
                                    gap: '0.7rem',
                                    padding: '0.7rem 0.85rem',
                                    borderRadius: '12px',
                                    background: '#f8fafc',
                                    border: '1px solid #e2e8f0',
                                    cursor: 'pointer',
                                    transition: 'all 0.2s'
                                  }}
                                  onMouseOver={e => e.currentTarget.style.borderColor = 'var(--primary)'}
                                  onMouseOut={e => e.currentTarget.style.borderColor = '#e2e8f0'}
                                >
                                  <div style={{
                                    width: '34px', height: '34px', borderRadius: '8px',
                                    background: 'white', display: 'flex', alignItems: 'center',
                                    justifyContent: 'center', border: '1px solid #f1f5f9', flexShrink: 0
                                  }}>
                                    <FlaskConical size={16} color="var(--primary)" />
                                  </div>
                                  <div style={{ flex: 1, minWidth: 0 }}>
                                    <div style={{ fontSize: '0.78rem', fontWeight: 700, color: 'var(--text-main)', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>{displayName}</div>
                                    <div style={{ fontSize: '0.63rem', color: 'var(--text-muted)', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>{shortDesc}</div>
                                  </div>
                                  <div style={{
                                    fontSize: '0.6rem', fontWeight: 700, color: 'var(--primary)',
                                    whiteSpace: 'nowrap', display: 'flex', alignItems: 'center', gap: '2px'
                                  }}>
                                    View <ChevronRight size={10} />
                                  </div>
                                </div>
                              );
                            })}
                          </div>
                        </div>
                      );
                    })()}

                    {/* Render Reconstitution Tool if tags exist */}
                    {msg.role === 'assistant' && msg.content.includes('[RECON_TOOL:') && (
                      <ReconCalculator initialMg={msg.content.match(/\[RECON_TOOL:(.*?)\]/)?.[1]} />
                    )}

                    {/* Phase 3 — People Also Ask */}
                    {msg.role === 'assistant' && (msg.fullContent || msg.content || '').includes('[QUESTION:') && (() => {
                      const questions = Array.from(
                        (msg.fullContent || msg.content || '').matchAll(/\[QUESTION:(.*?)\]/g)
                      ).map(m => m[1]).slice(0, 3);
                      if (!questions.length) return null;
                      return (
                        <div style={{ marginTop: '1.1rem' }}>
                          <div style={{
                            display: 'flex',
                            alignItems: 'center',
                            gap: '0.4rem',
                            marginBottom: '0.55rem'
                          }}>
                            <div style={{
                              width: '14px',
                              height: '2px',
                              borderRadius: '2px',
                              background: 'linear-gradient(90deg, #8b5cf6, #a78bfa)'
                            }} />
                            <span style={{
                              fontSize: '0.6rem',
                              fontWeight: 800,
                              letterSpacing: '0.07em',
                              textTransform: 'uppercase',
                              color: 'var(--text-muted)'
                            }}>People Also Ask</span>
                          </div>
                          <div style={{ display: 'flex', flexDirection: 'column', gap: '0.4rem' }}>
                            {questions.map((q, qi) => (
                              <button
                                key={qi}
                                onClick={() => handleSend(q)}
                                style={{
                                  display: 'flex',
                                  alignItems: 'center',
                                  gap: '0.5rem',
                                  padding: '0.5rem 0.75rem',
                                  borderRadius: '10px',
                                  background: 'white',
                                  border: '1px solid #e8e4f3',
                                  cursor: 'pointer',
                                  textAlign: 'left',
                                  fontSize: '0.73rem',
                                  fontWeight: 600,
                                  color: '#5b21b6',
                                  transition: 'all 0.18s',
                                  width: '100%'
                                }}
                                onMouseOver={e => {
                                  e.currentTarget.style.background = '#f5f3ff';
                                  e.currentTarget.style.borderColor = '#8b5cf6';
                                }}
                                onMouseOut={e => {
                                  e.currentTarget.style.background = 'white';
                                  e.currentTarget.style.borderColor = '#e8e4f3';
                                }}
                              >
                                <span style={{ fontSize: '0.7rem', opacity: 0.6, flexShrink: 0 }}>Q</span>
                                {q}
                              </button>
                            ))}
                          </div>
                        </div>
                      );
                    })()}

                     {/* ── Phase 1 — Proactive Product Cards (with Compare chips) ── */}
                     {msg.role === 'assistant' && Array.isArray(msg.proactiveCards) && msg.proactiveCards.length > 0 && (() => {
                       // Don't show if the AI already tagged explicit [PRODUCT:] links
                       const hasExplicitProducts = (msg.content ?? '').includes('[PRODUCT:');
                       if (hasExplicitProducts) return null;
                       return (
                         <div style={{ marginTop: '1rem' }}>
                           <div style={{
                             fontSize: '0.6rem',
                             fontWeight: 800,
                             letterSpacing: '0.07em',
                             textTransform: 'uppercase',
                             color: 'var(--text-muted)',
                             marginBottom: '0.5rem',
                             display: 'flex',
                             alignItems: 'center',
                             gap: '0.4rem'
                           }}>
                             <span>🔬</span> Related Compounds
                           </div>
                           <div style={{ display: 'flex', flexDirection: 'column', gap: '0.5rem' }}>
                             {msg.proactiveCards.map((product, pidx) => {
                               const slug = product.slug || product.id || '';
                               const name = product.displayName || product.name || slug;
                               const baseName = name.replace(/[-\s]*(\d+(\.\d+)?\s*(mg|mcg|iu|ml|g|kg)[\w-]*)$/i, '').trim() || name;
                               const similar = (SIMILAR_MAP[baseName] || []).slice(0, 2);
                               return (
                                 <div key={pidx} style={{
                                   borderRadius: '12px',
                                   background: 'linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%)',
                                   border: '1px solid #e2e8f0',
                                   overflow: 'hidden'
                                 }}>
                                   <div
                                     onClick={() => { navigate(`/product/${slug}`); setIsOpen(false); }}
                                     style={{
                                       display: 'flex',
                                       alignItems: 'center',
                                       gap: '0.65rem',
                                       padding: '0.65rem 0.8rem',
                                       cursor: 'pointer',
                                       transition: 'background 0.15s'
                                     }}
                                     onMouseOver={e => e.currentTarget.style.background = '#f0f4ff'}
                                     onMouseOut={e => e.currentTarget.style.background = 'transparent'}
                                   >
                                     <div style={{
                                       width: '32px', height: '32px', borderRadius: '8px',
                                       background: 'white', display: 'flex', alignItems: 'center',
                                       justifyContent: 'center', border: '1px solid #e8edf5', flexShrink: 0
                                     }}>
                                       <FlaskConical size={14} color="var(--primary)" />
                                     </div>
                                     <div style={{ flex: 1, minWidth: 0 }}>
                                       <div style={{ fontSize: '0.76rem', fontWeight: 700, color: 'var(--text-main)', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>{baseName}</div>
                                       <div style={{ fontSize: '0.62rem', color: 'var(--text-muted)', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>{product.shortDescription || product.category || 'Research Compound'}</div>
                                     </div>
                                     <ChevronRight size={13} color="#94a3b8" />
                                   </div>
                                   {similar.length > 0 && (
                                     <div style={{
                                       display: 'flex',
                                       gap: '0.35rem',
                                       padding: '0.35rem 0.8rem 0.5rem',
                                       borderTop: '1px solid #f1f5f9',
                                       flexWrap: 'wrap'
                                     }}>
                                       <span style={{ fontSize: '0.58rem', color: 'var(--text-muted)', fontWeight: 600, alignSelf: 'center' }}>Compare:</span>
                                       {similar.map((sim, si) => (
                                         <button
                                           key={si}
                                           onClick={() => handleSend(`Compare ${baseName} vs ${sim}`)}
                                           style={{
                                             padding: '0.2rem 0.55rem',
                                             borderRadius: '8px',
                                             background: 'white',
                                             border: '1px solid #c7d2fe',
                                             fontSize: '0.62rem',
                                             fontWeight: 700,
                                             color: '#4338ca',
                                             cursor: 'pointer',
                                             transition: 'all 0.15s'
                                           }}
                                           onMouseOver={e => { e.currentTarget.style.background = '#eef2ff'; e.currentTarget.style.borderColor = '#6366f1'; }}
                                           onMouseOut={e => { e.currentTarget.style.background = 'white'; e.currentTarget.style.borderColor = '#c7d2fe'; }}
                                         >
                                           vs {sim}
                                         </button>
                                       ))}
                                     </div>
                                   )}
                                 </div>
                               );
                             })}
                           </div>
                         </div>
                       );
                     })()}

                     {/* ── Phase 2 — "Did you mean?" Semantic Fallback Strip ── */}
                     {msg.role === 'assistant' && Array.isArray(msg.fallbackCards) && msg.fallbackCards.length > 0 && (() => {
                       return (
                         <div style={{ marginTop: '1rem' }}>
                           <div style={{
                             fontSize: '0.6rem',
                             fontWeight: 800,
                             letterSpacing: '0.07em',
                             textTransform: 'uppercase',
                             color: '#d97706',
                             marginBottom: '0.5rem',
                             display: 'flex',
                             alignItems: 'center',
                             gap: '0.4rem'
                           }}>
                             <span>💡</span> Did you mean? — {msg.fallbackLabel}
                           </div>
                           <div style={{ display: 'flex', flexDirection: 'column', gap: '0.45rem' }}>
                             {msg.fallbackCards.map((product, pidx) => {
                               const slug = product.slug || product.id || '';
                               const name = product.displayName || product.name || slug;
                               const baseName = name.replace(/[-\s]*(\d+(\.\d+)?\s*(mg|mcg|iu|ml|g|kg)[\w-]*)$/i, '').trim() || name;
                               return (
                                 <div
                                   key={pidx}
                                   onClick={() => { navigate(`/product/${slug}`); setIsOpen(false); }}
                                   style={{
                                     display: 'flex',
                                     alignItems: 'center',
                                     gap: '0.65rem',
                                     padding: '0.6rem 0.8rem',
                                     borderRadius: '12px',
                                     background: 'linear-gradient(135deg, #fffbeb 0%, #fef9c3 100%)',
                                     border: '1px solid #fde68a',
                                     cursor: 'pointer',
                                     transition: 'all 0.15s'
                                   }}
                                   onMouseOver={e => e.currentTarget.style.borderColor = '#f59e0b'}
                                   onMouseOut={e => e.currentTarget.style.borderColor = '#fde68a'}
                                 >
                                   <div style={{
                                     width: '30px', height: '30px', borderRadius: '8px',
                                     background: 'white', display: 'flex', alignItems: 'center',
                                     justifyContent: 'center', border: '1px solid #fde68a', flexShrink: 0
                                   }}>
                                     <Sparkles size={13} color="#d97706" />
                                   </div>
                                   <div style={{ flex: 1, minWidth: 0 }}>
                                     <div style={{ fontSize: '0.75rem', fontWeight: 700, color: '#92400e', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>{baseName}</div>
                                     <div style={{ fontSize: '0.61rem', color: '#b45309', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>{product.shortDescription || product.category || 'Research Compound'}</div>
                                   </div>
                                   <ChevronRight size={13} color="#d97706" />
                                 </div>
                               );
                             })}
                           </div>
                         </div>
                       );
                     })()}
                  </div>
                  <div style={{ display: 'flex', alignItems: 'center', justifyContent: msg.role === 'user' ? 'flex-end' : 'flex-start', gap: '0.75rem', marginTop: '0.4rem' }}>
                    <span style={{ fontSize: '0.65rem', color: 'var(--text-light)', fontWeight: 600 }}>
                      {msg.role === 'assistant' ? 'CLINICAL AI' : 'RESEARCHER'} • {msg.timestamp.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
                    </span>
                    {/* Copy button — only on completed assistant messages */}
                    {msg.role === 'assistant' && !isTyping && msgIdx > 0 && (
                      <button
                        onClick={() => copyMessage(msg.fullContent || msg.content, msgIdx)}
                        title="Copy message"
                        style={{
                          display: 'flex',
                          alignItems: 'center',
                          gap: '0.25rem',
                          padding: '2px 7px',
                          borderRadius: '8px',
                          border: `1px solid ${copiedMsgIdx === msgIdx ? '#10b981' : '#e2e8f0'}`,
                          background: copiedMsgIdx === msgIdx ? 'rgba(16,185,129,0.1)' : 'transparent',
                          color: copiedMsgIdx === msgIdx ? '#10b981' : '#94a3b8',
                          fontSize: '0.65rem',
                          fontWeight: 700,
                          cursor: 'pointer',
                          transition: 'all 0.2s',
                          lineHeight: 1
                        }}
                      >
                        {copiedMsgIdx === msgIdx
                          ? <><Check size={11} /> Copied</>
                          : <><Copy size={11} /> Copy</>}
                      </button>
                    )}
                    {/* Feedback buttons — only on completed assistant messages */}
                    {msg.role === 'assistant' && !isTyping && msgIdx > 0 && (
                      <div style={{ display: 'flex', gap: '0.25rem' }}>
                        {['up', 'down'].map(vote => {
                          const sent = feedbackSent[msgIdx];
                          const isThis = sent === vote;
                          const isOther = sent && sent !== vote;
                          return (
                            <button
                              key={vote}
                              title={vote === 'up' ? 'Helpful' : 'Not helpful'}
                              disabled={!!sent}
                              onClick={() => {
                                setFeedbackSent(prev => ({ ...prev, [msgIdx]: vote }));
                                submitFeedback({
                                  sessionId,
                                  messageIndex: msgIdx,
                                  rating: vote,
                                  messageContent: msg.fullContent || msg.content
                                });
                                // Phase 5 — track ai_feedback
                                trackAIFeedback(sessionId, msgIdx, vote);
                                // Negative feedback → escalation
                                if (vote === 'down') {
                                  activityRef.current.negFeedbackCount += 1;
                                  const contextHint =
                                    (msg.fullContent || msg.content || '')
                                      .match(/\*\*##?\s*([^*\n]+)\*\*/)?.[1] ||
                                    (msg.fullContent || msg.content || '')
                                      .match(/\[PROTOCOL:([^\]]+)\]/)?.[1]?.replace(/-/g, ' ') || '';
                                  setTimeout(() => maybeShowSupport('negative_feedback', contextHint), 800);
                                }
                              }}
                              style={{
                                background: isThis
                                  ? (vote === 'up' ? 'rgba(16,185,129,0.15)' : 'rgba(239,68,68,0.12)')
                                  : 'transparent',
                                border: `1px solid ${
                                  isThis
                                    ? (vote === 'up' ? '#10b981' : '#ef4444')
                                    : '#e2e8f0'
                                }`,
                                borderRadius: '8px',
                                padding: '2px 6px',
                                fontSize: '0.7rem',
                                cursor: sent ? 'default' : 'pointer',
                                opacity: isOther ? 0.3 : 1,
                                transition: 'all 0.2s',
                                lineHeight: 1,
                              }}
                            >
                              {vote === 'up' ? '👍' : '👎'}
                            </button>
                          );
                        })}
                      </div>
                    )}
                  </div>

                </div>
                );
              })}
              {isLoading && (
                <div style={{ display: 'flex', alignItems: 'center', gap: '0.75rem', color: 'var(--text-muted)' }}>
                  <div style={{ padding: '0.75rem', backgroundColor: 'white', borderRadius: '12px', border: '1px solid var(--border)' }}>
                    <Loader2 size={16} className="animate-spin" />
                  </div>
                  <span style={{ fontSize: '0.75rem', fontWeight: 600 }}>Processing scientific data...</span>
                </div>
              )}
              
              {suggestions.length > 0 && !isLoading && (
                <div style={{ marginTop: '0.75rem' }}>
                  {/* Phase 2 — Query Journey Engine label */}
                  <div style={{
                    display: 'flex',
                    alignItems: 'center',
                    gap: '0.4rem',
                    marginBottom: '0.5rem',
                    paddingLeft: '0.1rem'
                  }}>
                    <div style={{
                      width: '14px',
                      height: '2px',
                      borderRadius: '2px',
                      background: 'linear-gradient(90deg, var(--primary), #38bdf8)'
                    }} />
                    <span style={{
                      fontSize: '0.6rem',
                      fontWeight: 800,
                      letterSpacing: '0.07em',
                      textTransform: 'uppercase',
                      color: 'var(--text-muted)'
                    }}>Explore Further</span>
                  </div>
                  <div style={{ display: 'flex', flexWrap: 'wrap', gap: '0.5rem' }}>
                    {suggestions.map((s, idx) => {
                      const isAction = typeof s === 'object';
                      const label = isAction ? s.label : s;
                      const isNav = isAction && s.action === 'NAVIGATE';

                      return (
                        <button
                          key={idx}
                          onClick={() => handleSend(s)}
                          style={{
                            padding: '0.45rem 0.9rem',
                            borderRadius: '20px',
                            backgroundColor: isNav ? 'rgba(0,75,135,0.05)' : 'white',
                            border: `1.5px solid ${isNav ? 'var(--primary)' : 'var(--border)'}`,
                            color: 'var(--primary)',
                            fontSize: '0.73rem',
                            fontWeight: 700,
                            cursor: 'pointer',
                            transition: 'all 0.2s',
                            display: 'flex',
                            alignItems: 'center',
                            gap: '0.35rem',
                            boxShadow: '0 2px 8px rgba(0,0,0,0.03)'
                          }}
                          onMouseOver={(e) => {
                            e.currentTarget.style.backgroundColor = 'var(--primary)';
                            e.currentTarget.style.color = 'white';
                            e.currentTarget.style.borderColor = 'var(--primary)';
                          }}
                          onMouseOut={(e) => {
                            e.currentTarget.style.backgroundColor = isNav ? 'rgba(0,75,135,0.05)' : 'white';
                            e.currentTarget.style.color = 'var(--primary)';
                            e.currentTarget.style.borderColor = isNav ? 'var(--primary)' : 'var(--border)';
                          }}
                        >
                          {isNav ? <Eye size={11} /> : <Sparkles size={11} />}
                          {label}
                        </button>
                      );
                    })}
                  </div>
                </div>
              )}
            </div>

            {/* ── Quick-Match chip ─────────────────────────────────────── */}
            <AnimatePresence>
              {quickMatch && !isLoading && !isTyping && (
                <motion.div
                  key="quickmatch"
                  initial={{ opacity: 0, y: 8, scale: 0.97 }}
                  animate={{ opacity: 1, y: 0, scale: 1 }}
                  exit={{ opacity: 0, y: 8, scale: 0.97 }}
                  transition={{ duration: 0.18 }}
                  style={{
                    margin: '0 1.25rem 0.75rem',
                    padding: '0.65rem 1rem',
                    borderRadius: '14px',
                    background: 'linear-gradient(135deg, #eef5ff 0%, #e8f0fd 100%)',
                    border: '1.5px solid #c5d8f8',
                    display: 'flex',
                    alignItems: 'center',
                    gap: '0.6rem',
                    boxShadow: '0 2px 12px rgba(0,75,135,0.07)',
                  }}
                >
                  <div style={{
                    width: '28px', height: '28px', borderRadius: '8px',
                    background: 'var(--primary)', display: 'flex',
                    alignItems: 'center', justifyContent: 'center', flexShrink: 0
                  }}>
                    <Zap size={14} color="white" />
                  </div>
                  <div style={{ flex: 1, minWidth: 0 }}>
                    <div style={{ fontSize: '0.7rem', fontWeight: 800, color: 'var(--primary)', textTransform: 'uppercase', letterSpacing: '0.04em' }}>
                      🔬 Compound detected
                    </div>
                    <div style={{ fontSize: '0.8rem', fontWeight: 700, color: 'var(--text-main)', marginTop: '0.1rem', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' }}>
                      {quickMatch.displayName || quickMatch.name}
                    </div>
                  </div>
                  <div style={{ display: 'flex', gap: '0.4rem', flexShrink: 0 }}>
                    <button
                      onClick={() => { navigate(`/product/${quickMatch.slug || quickMatch.id}`); setIsOpen(false); }}
                      style={{
                        padding: '0.35rem 0.7rem', borderRadius: '10px',
                        background: 'var(--primary)', color: 'white',
                        border: 'none', fontSize: '0.7rem', fontWeight: 700,
                        cursor: 'pointer', whiteSpace: 'nowrap'
                      }}
                    >
                      View Profile
                    </button>
                    <button
                      onClick={() => handleSend(`Tell me about ${quickMatch.displayName || quickMatch.name}`)}
                      style={{
                        padding: '0.35rem 0.7rem', borderRadius: '10px',
                        background: 'white', color: 'var(--primary)',
                        border: '1.5px solid #c5d8f8', fontSize: '0.7rem', fontWeight: 700,
                        cursor: 'pointer', whiteSpace: 'nowrap'
                      }}
                    >
                      Ask AI
                    </button>
                  </div>
                </motion.div>
              )}
            </AnimatePresence>

            {/* Input */}
            <div style={{ padding: '1.25rem', borderTop: '1px solid var(--border)', backgroundColor: 'white' }}>

              {/* Phase 15 — Research Digest trigger button */}
              {messages.filter(m => m.role === 'assistant').length >= 3 && (
                <div style={{ marginBottom: '0.65rem', display: 'flex', justifyContent: 'flex-end' }}>
                  <button
                    onClick={() => handleSend('Please generate a research digest summarising all the compounds and key findings we have covered in this session.')}
                    title="Generate a session summary"
                    style={{
                      display: 'inline-flex',
                      alignItems: 'center',
                      gap: '0.35rem',
                      padding: '0.32rem 0.8rem',
                      borderRadius: '20px',
                      background: 'linear-gradient(135deg, #eff6ff 0%, #f5f3ff 100%)',
                      border: '1px solid #c7d7fc',
                      fontSize: '0.64rem',
                      fontWeight: 700,
                      color: '#4f46e5',
                      cursor: 'pointer',
                      transition: 'all 0.2s',
                      letterSpacing: '0.02em'
                    }}
                    onMouseOver={e => { e.currentTarget.style.background = 'linear-gradient(135deg, #dbeafe 0%, #ede9fe 100%)'; e.currentTarget.style.boxShadow = '0 2px 8px rgba(79,70,229,0.15)'; }}
                    onMouseOut={e => { e.currentTarget.style.background = 'linear-gradient(135deg, #eff6ff 0%, #f5f3ff 100%)'; e.currentTarget.style.boxShadow = 'none'; }}
                  >
                    <span style={{ fontSize: '0.75rem' }}>📑</span>
                    Research Digest
                  </button>
                </div>
              )}

              {/* Phase 16 — Contact Escalation WhatsApp Banner */}
              {(() => {
                const lastUserMsg = [...messages].reverse().find(m => m.role === 'user');
                const text = (lastUserMsg?.content || '').toLowerCase();
                const contactKeywords = ['contact', 'support', 'help me', 'customer service', 'how do i order', 'how to buy', 'where to buy', 'whatsapp', 'speak to someone', 'talk to someone', 'reach you', 'get in touch'];
                const isContactQuery = contactKeywords.some(kw => text.includes(kw));
                if (!isContactQuery) return null;
                return (
                  <div style={{
                    marginBottom: '0.65rem',
                    padding: '0.55rem 0.85rem',
                    borderRadius: '14px',
                    background: 'linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%)',
                    border: '1px solid #86efac',
                    display: 'flex',
                    alignItems: 'center',
                    gap: '0.6rem'
                  }}>
                    <span style={{ fontSize: '1.1rem' }}>💬</span>
                    <div style={{ flex: 1 }}>
                      <div style={{ fontSize: '0.62rem', fontWeight: 800, color: '#15803d', textTransform: 'uppercase', letterSpacing: '0.06em' }}>Need help from our team?</div>
                      <div style={{ fontSize: '0.68rem', color: '#166534', marginTop: '0.1rem' }}>Our team can guide you toward the most relevant protocols or compounds.</div>
                    </div>
                    <a
                      href="https://wa.me/971564179256"
                      target="_blank"
                      rel="noopener noreferrer"
                      style={{
                        display: 'inline-flex',
                        alignItems: 'center',
                        gap: '0.3rem',
                        padding: '0.35rem 0.75rem',
                        borderRadius: '20px',
                        background: 'linear-gradient(135deg, #16a34a 0%, #22c55e 100%)',
                        color: 'white',
                        fontWeight: 700,
                        fontSize: '0.65rem',
                        textDecoration: 'none',
                        whiteSpace: 'nowrap',
                        boxShadow: '0 2px 8px rgba(34,197,94,0.2)'
                      }}
                    >
                      WhatsApp
                    </a>
                  </div>
                );
              })()}
              <div style={{ 
                display: 'flex', 
                alignItems: 'center', 
                gap: '0.75rem',
                backgroundColor: '#f8fafc',
                padding: '0.5rem 0.5rem 0.5rem 1.25rem',
                borderRadius: '16px',
                border: '1.5px solid var(--border)',
                transition: 'border-color 0.2s'
              }}>
                <input 
                  value={input}
                  onChange={(e) => setInput(e.target.value)}
                  onKeyDown={(e) => e.key === 'Enter' && handleSend()}
                  placeholder="Ask about peptides, supplements or protocols..."
                  style={{
                    flex: 1,
                    border: 'none',
                    background: 'transparent',
                    fontSize: '0.9rem',
                    outline: 'none',
                    color: 'var(--text-main)',
                    fontWeight: 500
                  }}
                />
                {/* Voice button */}
                {voiceSupported && (
                  <button
                    onClick={isListening ? stopListening : startListening}
                    title={isListening ? 'Stop recording' : 'Speak your question'}
                    style={{
                      width: '40px',
                      height: '40px',
                      borderRadius: '12px',
                      border: 'none',
                      cursor: 'pointer',
                      display: 'flex',
                      alignItems: 'center',
                      justifyContent: 'center',
                      backgroundColor: isListening ? 'rgba(239,68,68,0.12)' : 'rgba(0,0,0,0.05)',
                      color: isListening ? '#ef4444' : 'var(--text-light)',
                      transition: 'all 0.2s',
                      animation: isListening ? 'pulse 1.2s ease-in-out infinite' : 'none',
                      flexShrink: 0
                    }}
                  >
                    {isListening ? <MicOff size={18} /> : <Mic size={18} />}
                  </button>
                )}

                {/* Send button */}
                <button 
                  onClick={handleSend}
                  disabled={!input.trim() || isLoading}
                  style={{
                    width: '40px',
                    height: '40px',
                    borderRadius: '12px',
                    backgroundColor: input.trim() ? 'var(--primary)' : 'rgba(0,0,0,0.05)',
                    color: 'white',
                    border: 'none',
                    cursor: 'pointer',
                    display: 'flex',
                    alignItems: 'center',
                    justifyContent: 'center',
                    transition: 'all 0.2s'
                  }}
                >
                  <Send size={18} />
                </button>
              </div>
              <p style={{ margin: '0.75rem 0 0', fontSize: '0.6rem', textAlign: 'center', color: 'var(--text-light)', fontWeight: 600, textTransform: 'uppercase', letterSpacing: '0.05em' }}>
                For research purposes only. Not clinical advice.
              </p>
            </div>
          </div>
          </div>
        );

        return isMobile ? (
          <BottomSheet 
            isOpen={isOpen} 
            onClose={() => setIsOpen(false)}
            title="Med-Peptides Clinical AI"
          >
            {renderChatContent()}
          </BottomSheet>
        ) : (
          <AnimatePresence>
            {isOpen && (
              <motion.div
                className="ca-chat-mobile"
                initial={{ opacity: 0, y: 20, scale: 0.95, transformOrigin: 'bottom left' }}
                animate={{ opacity: 1, y: 0, scale: 1 }}
                exit={{ opacity: 0, y: 20, scale: 0.95 }}
                style={{
                  position: 'fixed',
                  bottom: '6.5rem',
                  left: '2rem',
                  width: '520px',
                  maxWidth: 'calc(100vw - 4rem)',
                  height: '660px',
                  maxHeight: 'calc(100vh - 10rem)',
                  backgroundColor: 'white',
                  borderRadius: '28px',
                  boxShadow: '0 24px 64px rgba(0,0,0,0.15)',
                  display: 'flex',
                  flexDirection: 'column',
                  zIndex: 9998,
                  overflow: 'hidden',
                  border: '1px solid rgba(0,0,0,0.05)'
                }}
              >
                {renderChatContent()}
              </motion.div>
            )}
          </AnimatePresence>
        );
      })()}


      {/* WhatsApp Support Escalation Card */}
      <SupportEscalationCard />

      <style>{`
        @keyframes shine {
          0% { transform: translateX(-100%) translateY(-100%) rotate(45deg); }
          100% { transform: translateX(200%) translateY(200%) rotate(45deg); }
        }
        @keyframes pulse {
          0% { opacity: 1; transform: scale(1); }
          50% { opacity: 0.5; transform: scale(1.2); }
          100% { opacity: 1; transform: scale(1); }
        }
        .animate-spin {
          animation: spin 1s linear infinite;
        }
        @keyframes spin {
          from { transform: rotate(0deg); }
          to { transform: rotate(360deg); }
        }
      `}</style>
    </>
  );
}
