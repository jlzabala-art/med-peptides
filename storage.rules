rules_version = '2';

// Craft rules based on data in your Firestore database
// allow write: if firestore.get(
//    /databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin;
service firebase.storage {
  match /b/{bucket}/o {
    
    // Knowledge Base Access
    match /knowledge_base/{allPaths=**} {
      allow read, write, list: if request.auth != null;
    }
    
    // Default fallback (deny everything else by default)
    match /{allPaths=**} {
      allow read, write, list: if request.auth != null; // Restrict this further in production if needed
    }
  }
}
